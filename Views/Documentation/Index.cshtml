@{ ViewData["Title"] = "Dokumentasi Tema"; }

@section Styles {
    <style>
        .doc-section {
            background: #fff;
            border-radius: var(--radius-md);
            padding: 2.5rem;
            margin-bottom: 2rem;
            box-shadow: 0 4px 15px rgba(0,0,0,0.02);
            border: 1px solid var(--border-color);
        }
        .doc-title {
            color: var(--color-1);
            font-weight: 800;
            margin-bottom: 1.5rem;
            padding-bottom: 1rem;
            border-bottom: 2px solid var(--border-color);
            display: flex;
            align-items: center;
        }
        .doc-title i {
            color: var(--primary);
            margin-right: 12px;
        }
        .code-block {
            background: #f8fafc;
            border-radius: 8px;
            padding: 1rem 1.5rem;
            font-family: monospace;
            font-size: 0.9rem;
            color: #d63384;
            border: 1px solid #e2e8f0;
            overflow-x: auto;
            margin: 1rem 0;
            line-height: 1.6;
        }
        .code-block.html-block { color: #0ea5e9; }
        .code-block.css-block { color: #f59e0b; }
        
        .lib-table th { background: #f8fafc; color: var(--text-gray); font-weight: 600; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.5px; }
        .lib-table td { vertical-align: middle; }
        .lib-badge { font-family: monospace; font-size: 0.85rem; }
        
        .step-card {
            border-left: 4px solid var(--primary);
            background: #f8fafc;
            padding: 1.5rem;
            border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
            margin-bottom: 1.5rem;
        }
        .step-number {
            display: inline-flex;
            width: 30px; height: 30px;
            background: var(--primary);
            color: white;
            align-items: center; justify-content: center;
            border-radius: 50%;
            font-weight: bold;
            margin-right: 10px;
        }
        
        [data-theme="dark"] .code-block {
            background: #0f172a;
            border-color: #334155;
            color: #f472b6;
        }
        [data-theme="dark"] .step-card {
            background: #1e293b;
        }
        [data-theme="dark"] .lib-table th {
            background: #0f172a;
        }
    </style>
}

<div class="row">
    <div class="col-lg-12">
        <h4 class="mb-4 fw-bold">Dokumentasi Developer</h4>
        <p class="text-muted mb-4 text-lg">Panduan lengkap mengenai pustaka, struktur, dan langkah integrasi untuk Kuda Admin Template.</p>
    </div>

    <!-- 1. Libraries & Dependencies -->
    <div class="col-12">
        <div class="doc-section">
            <h3 class="doc-title"><i class="fas fa-cubes"></i> Pustaka (Library) & Dependencies</h3>
            <p class="text-muted mb-4">Template ini dibangun menggunakan teknologi web modern dan stabil. Berikut adalah daftar library utama yang terintegrasi di dalamnya.</p>
            
            <div class="table-responsive">
                <table class="table table-hover lib-table mb-0">
                    <thead>
                        <tr>
                            <th>Dependency</th>
                            <th>Versi</th>
                            <th>Tipe</th>
                            <th>Fungsi & Lokasi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="fw-bold text-dark"><i class="fab fa-bootstrap text-primary me-2"></i> Bootstrap</td>
                            <td><span class="badge bg-light text-primary lib-badge border">v5.3.2</span></td>
                            <td>CSS / JS Inti</td>
                            <td class="text-muted small">Sistem layout grid, komponen UI dasar (Accordion, Modal). Dimuat via CDN di <code class="text-danger">_Layout.cshtml</code></td>
                        </tr>
                        <tr>
                            <td class="fw-bold text-dark"><i class="fab fa-js text-warning me-2"></i> jQuery</td>
                            <td><span class="badge bg-light text-primary lib-badge border">v3.7.0</span></td>
                            <td>Utilitas JS</td>
                            <td class="text-muted small">Dibutuhkan untuk DataTables dan beberapa animasi Sidebar kustom. Dimuat via CDN di <code class="text-danger">_Layout.cshtml</code></td>
                        </tr>
                        <tr>
                            <td class="fw-bold text-dark"><i class="fas fa-table text-success me-2"></i> DataTables</td>
                            <td><span class="badge bg-light text-primary lib-badge border">v1.13.6</span></td>
                            <td>CSS / JS Plugin</td>
                            <td class="text-muted small">Tabel tingkat lanjut dengan fitur pagination, sorting. Dimuat via CDN.</td>
                        </tr>
                        <tr>
                            <td class="fw-bold text-dark"><i class="fab fa-font-awesome text-info me-2"></i> FontAwesome</td>
                            <td><span class="badge bg-light text-primary lib-badge border">v6.4.0</span></td>
                            <td>CSS (Icons)</td>
                            <td class="text-muted small">Ikon vektor yang dipakai di sidebar, card, dan tombol. Menggunakan Free tier via CDN.</td>
                        </tr>
                        <tr>
                            <td class="fw-bold text-dark"><i class="fas fa-chart-line text-danger me-2"></i> ApexCharts</td>
                            <td><span class="badge bg-light text-primary lib-badge border">Latest</span></td>
                            <td>JS Plugin</td>
                            <td class="text-muted small">Grafik SVG interaktif. Biasanya hanya dimuat pada halaman yang membutuhkannya (mis. Dashboard, SEO).</td>
                        </tr>
                        <tr>
                            <td class="fw-bold text-dark"><i class="fas fa-font text-secondary me-2"></i> Fonts</td>
                            <td><span class="badge bg-light text-primary lib-badge border">N/A</span></td>
                            <td>Typography</td>
                            <td class="text-muted small"><strong>KalbeGeometric</strong> (WOFF2 lokal di <code class="text-danger">wwwroot/font/</code> saja, tidak ada font eksternal)</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- 2. Folder Structure & Assets -->
    <div class="col-12">
        <div class="doc-section">
            <h3 class="doc-title"><i class="fas fa-folder-tree"></i> Arsitektur CSS & Aset Lokal</h3>
            <p class="text-muted mb-4">Anda tidak perlu pusing menulis kode CSS tebal dari nol. Template ini menimpa desain bawaan Bootstrap melalui 2 file CSS utama yang dipanggil di akhir tag <code>&lt;head&gt;</code>:</p>

            <div class="row g-4 mb-4">
                <div class="col-md-6">
                    <div class="card h-100 border-0 bg-light">
                        <div class="card-body">
                            <h5 class="fw-bold text-primary">1. theme.css</h5>
                            <p class="small text-muted mb-3">Menyimpan seluruh variabel CSS global (warna, font), reset tipografi dasar, serta utilitas umum lainnya (termasuk kesiapan Dark Mode).</p>
                            <code>wwwroot/css/theme.css</code>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card h-100 border-0 bg-light">
                        <div class="card-body">
                            <h5 class="fw-bold text-info">2. components.css</h5>
                            <p class="small text-muted mb-3">Menyimpan desain yang spesifik untuk mekanika Tata Letak (Sidebar, Topbar) serta UI Widgets (Card, Modal, timpaan Forms).</p>
                            <code>wwwroot/css/components.css</code>
                        </div>
                    </div>
                </div>
            </div>

            <div class="alert alert-warning border-0 shadow-sm align-items-center d-flex mt-2">
                <i class="fas fa-exclamation-circle fa-2x pt-1 me-3 opacity-75 align-self-start"></i>
                <div>
                    <strong>Aturan Hirarki Penting:</strong><br/>
                    Selalu pastikan <code>bootstrap.min.css</code> dimuat <strong>sebelum</strong> <code>theme.css</code> dan <code>components.css</code>. Ini krusial agar desain kustom kita bisa mereplace desain bawaan Bootstrap secara sempurna.
                </div>
            </div>
        </div>
    </div>

    <!-- 3. Implementation Steps -->
    <div class="col-12">
        <div class="doc-section">
            <h3 class="doc-title"><i class="fas fa-code-branch"></i> Cara Menggunakan (Panduan Pengembang)</h3>
            
            <ul class="nav nav-pills mb-4 mt-3" id="pills-tab" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active fw-bold px-4 rounded-pill" id="pills-new-tab" data-bs-toggle="pill" data-bs-target="#pills-new" type="button" role="tab" aria-controls="pills-new" aria-selected="true">Proyek ASP.NET Baru</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-bold px-4 rounded-pill" id="pills-existing-tab" data-bs-toggle="pill" data-bs-target="#pills-existing" type="button" role="tab" aria-controls="pills-existing" aria-selected="false">Migrasi Web Eksisting</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-bold px-4 rounded-pill bg-primary bg-opacity-10 text-primary" id="pills-cdn-tab" data-bs-toggle="pill" data-bs-target="#pills-cdn" type="button" role="tab" aria-controls="pills-cdn" aria-selected="false"><i class="fas fa-server me-1"></i> Gunakan via CDN (External)</button>
                </li>
            </ul>
            
            <div class="tab-content" id="pills-tabContent">
                <!-- Tab: New Project -->
                <div class="tab-pane fade show active" id="pills-new" role="tabpanel" aria-labelledby="pills-new-tab">
                    <div class="step-card">
                        <h5 class="fw-bold mb-3"><span class="step-number">1</span> Kopi Struktur Views/Shared</h5>
                        <p class="text-muted mb-2">Pindahkan file struktur dasar berikut ke direktori MVC <code>Views/Shared/</code> Anda:</p>
                        <ul class="text-muted mb-0 small">
                            <li><code class="text-dark">_Layout.cshtml</code> (Halaman master yang memuat CDN link CSS/JS)</li>
                            <li><code class="text-dark">_Sidebar.cshtml</code> (Logika komponen navigasi kiri)</li>
                            <li><code class="text-dark">_Header.cshtml</code> (Komponen menu atas / topbar)</li>
                        </ul>
                    </div>
                    
                    <div class="step-card">
                        <h5 class="fw-bold mb-3"><span class="step-number">2</span> Kopi Aset ke wwwroot</h5>
                        <p class="text-muted mb-2">Salin file pemetaan CSS dan berkas Font luring ke <code>wwwroot/</code>:</p>
                        <ul class="text-muted mb-0 small">
                            <li><code class="text-dark">wwwroot/css/theme.css</code> dan <code class="text-dark">components.css</code></li>
                            <li><code class="text-dark">wwwroot/font/geometric/</code> (Lokasi woff font Kalbe)</li>
                        </ul>
                    </div>

                    <div class="step-card">
                        <h5 class="fw-bold mb-3"><span class="step-number">3</span> Hubungkan _ViewStart.cshtml</h5>
                        <p class="text-muted mb-2">Pastikan file <code>Views/_ViewStart.cshtml</code> Anda menarget layout baru:</p>
                        <div class="code-block html-block">
@{
    Layout = "_Layout";
}
                        </div>
                    </div>
                </div>

                <!-- Tab: Existing Project -->
                <div class="tab-pane fade" id="pills-existing" role="tabpanel" aria-labelledby="pills-existing-tab">
                    <p class="text-muted mb-4">Apabila Anda sudah merajut proyek ASP.NET dan sekadar ingin "menyuntikkan" tema tanpa membongkar logika backend berjalan, ini caranya:</p>
                    
                    <div class="step-card">
                        <h5 class="fw-bold mb-3"><span class="step-number">A</span> Suntik Tag CSS di Head</h5>
                        <p class="text-muted mb-2">Buka file <code>Views/Shared/_Layout.cshtml</code> bawaan Anda. Timpa style head Anda dengan referensi di bawah ini:</p>
                        <div class="code-block html-block">
&lt;!-- Bootstrap 5.3 CDN --&gt;
&lt;link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" /&gt;
&lt;!-- FontAwesome 6.4 CDN --&gt;
&lt;link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"&gt;
&lt;!-- Custom Kuda Theme --&gt;
&lt;link rel="stylesheet" href="~/css/theme.css" /&gt;
&lt;link rel="stylesheet" href="~/css/components.css" /&gt;
                        </div>
                    </div>

                    <div class="step-card border-warning">
                        <h5 class="fw-bold mb-3"><span class="step-number bg-warning text-dark">B</span> Sesuaikan Struktur Flexbox</h5>
                        <p class="text-muted mb-2">Template ini mewajibkan struktur <code>.wrapper</code> dan <code>.dashboard-container</code> agar pergerakan sidebar berfungsi mulus. <strong>Jangan menaruh RenderBody langsung di body</strong>. Posisikan seperti ini:</p>
                        <div class="code-block html-block">
&lt;div class="wrapper"&gt;
    &lt;div class="dashboard-container"&gt;
        
        &lt;!-- Suntik Komponen Sidebar --&gt;
        &lt;partial name="_Sidebar" /&gt;
        
        &lt;div class="main-content"&gt;
            &lt;!-- Suntik Komponen Topbar --&gt;
            &lt;partial name="_Header" /&gt;
            
            &lt;main class="pb-3" style="flex:1;"&gt;
                @@RenderBody()
            &lt;/main&gt;
        &lt;/div&gt;

    &lt;/div&gt;
&lt;/div&gt;
                        </div>
                    </div>

                    <div class="step-card text-success border-success">
                        <h5 class="fw-bold mb-3"><span class="step-number bg-success">C</span> Lengkapi Javascript Penutup</h5>
                        <p class="text-muted mb-2">Tepat sebelum tag penutup <code>&lt;/body&gt;</code>, load logika JS intinya:</p>
                        <div class="code-block html-block">
&lt;script src="https://code.jquery.com/jquery-3.7.0.min.js"&gt;&lt;/script&gt;
&lt;script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"&gt;&lt;/script&gt;
&lt;!-- Paste kode skrip Sidebar Toggle / LocalStorage Theme di sini --&gt;
                        </div>
                    </div>
                </div>

                <!-- Tab: Use as CDN -->
                <div class="tab-pane fade" id="pills-cdn" role="tabpanel" aria-labelledby="pills-cdn-tab">
                    <div class="alert alert-info border-0 shadow-sm align-items-center d-flex mb-4">
                        <i class="fas fa-server fa-2x pt-1 me-3 opacity-75 align-self-start"></i>
                        <div>
                            <strong>Iya, Tentu Saja Bisa!</strong><br/>
                            Ketika aplikasi Dashboard Web Kuda ini telah <em>deploy</em> ke dalam peladen publik (misalnya: <code>https://kuda-dashboard.com</code>), Anda secara langsung mampu menerapkan pewarnaan CSS ini ke dalam platform eksternal lain (PHP Statis, Aplikasi Vue/React, dll) tanpa buang-buang waktu mengkopi file kasarnya.
                        </div>
                    </div>

                    <div class="step-card border-primary">
                        <h5 class="fw-bold mb-3"><span class="step-number bg-primary">1</span> CSS Imports via URL Penuh</h5>
                        <p class="text-muted mb-2">Taruh saja baris tautan <code>&lt;link&gt;</code> berikut di dalam kepala tag HTML <code>&lt;head&gt;</code> di web lain yang anda kerjakan.</p>
                        <div class="code-block html-block">
&lt;!-- Anggap "https://kuda-dashboard.com" adalah URL hosting Anda --&gt;

&lt;link rel="stylesheet" href="https://kuda-dashboard.com/css/theme.css" /&gt;

&lt;link rel="stylesheet" href="https://kuda-dashboard.com/css/components.css" /&gt;
                        </div>
                    </div>

                    <div class="step-card">
                        <h5 class="fw-bold text-success mb-3"><span class="step-number bg-success">2</span> Rintangan CORS Font Teratasi!</h5>
                        <p class="text-muted mb-2">Masalah utama dalam memanggil tautan aset eksternal biasanya terletak pada file ber-eksistensi Font (*WOFF2*) yang dijegal oleh parameter keamanan browser. <strong>Lupakan soal itu!</strong> Sistem landasan di <code>Program.cs</code> pada projek template ini sudah mendayagunakan fitur pelemahan izin CORS. Hasilnya, Chrome atau Safari tidak akan memblokir download Font KalbeGeometric sama sekali!</p>
                        <div class="code-block csharp-block text-success border-success bg-success bg-opacity-10">
// Bukti konfigurasi otomatis CDN statis pada server ASP.Net:
app.UseStaticFiles(new StaticFileOptions {
    OnPrepareResponse = ctx => {
        ctx.Context.Response.Headers.Append("Access-Control-Allow-Origin", "*");
    }
});
                        </div>
                    </div>
                </div>

            </div>

        </div>
    </div>
</div>
