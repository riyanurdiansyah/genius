@{
    ViewData["Title"] = "Buttons";
}

<div class="row">
    <!-- Solid Buttons -->
    <div class="col-12 mb-4">
        <div class="card">
            <div class="card-header">Solid Buttons</div>
            <div class="card-body">
                <p class="text-muted mb-3">Primary styles based on the provided dark green palette.</p>
                <button type="button" class="btn btn-primary mb-2 me-2">Primary</button>
                <button type="button" class="btn btn-secondary mb-2 me-2">Secondary</button>
                <button type="button" class="btn btn-success mb-2 me-2">Success</button>
                <button type="button" class="btn btn-danger mb-2 me-2">Danger</button>
                <button type="button" class="btn btn-warning mb-2 me-2">Warning</button>
                <button type="button" class="btn btn-info mb-2 me-2">Info</button>
                <button type="button" class="btn btn-dark mb-2 me-2">Dark</button>
            </div>
        </div>
    </div>
    
    <!-- Outline Buttons -->
    <div class="col-12 mb-4">
        <div class="card">
            <div class="card-header">Outline Buttons</div>
            <div class="card-body">
                <p class="text-muted mb-3">Buttons with a transparent background and outline border.</p>
                <button type="button" class="btn btn-outline-primary mb-2 me-2">Primary Outline</button>
            </div>
        </div>
    </div>
    
    <!-- Button Sizes -->
    <div class="col-md-6 mb-4">
        <div class="card h-100">
            <div class="card-header">Button Sizes</div>
            <div class="card-body">
                <div class="mb-3">
                    <button type="button" class="btn btn-primary btn-sm me-2">Small Button</button>
                    <button type="button" class="btn btn-secondary btn-sm">Small Button</button>
                </div>
                <div class="mb-3">
                    <button type="button" class="btn btn-primary me-2">Default Button</button>
                    <button type="button" class="btn btn-secondary">Default Button</button>
                </div>
                <div>
                    <button type="button" class="btn btn-primary btn-lg me-2">Large Button</button>
                    <button type="button" class="btn btn-secondary btn-lg">Large Button</button>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Icon Buttons -->
    <div class="col-md-6 mb-4">
        <div class="card h-100">
            <div class="card-header">Icon Buttons</div>
            <div class="card-body">
                <button type="button" class="btn btn-primary mb-2 me-2"><i class="fas fa-save"></i> Save</button>
                <button type="button" class="btn btn-secondary mb-2 me-2"><i class="fas fa-edit"></i> Edit</button>
                <button type="button" class="btn btn-danger mb-2 me-2"><i class="fas fa-trash"></i> Delete</button>
                <button type="button" class="btn btn-warning mb-2 me-2"><i class="fas fa-exclamation-triangle"></i> Warning</button>
                
                <h6 class="mt-4 mb-3">Icon Only</h6>
                <button type="button" class="btn btn-primary btn-sm mb-2 me-2"><i class="fas fa-plus"></i></button>
                <button type="button" class="btn btn-success btn-sm mb-2 me-2"><i class="fas fa-check"></i></button>
                <button type="button" class="btn btn-danger btn-sm mb-2 me-2"><i class="fas fa-times"></i></button>
            </div>
        </div>
    </div>
</div>
