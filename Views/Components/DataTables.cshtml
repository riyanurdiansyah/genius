@{
    ViewData["Title"] = "DataTables";
}

@section Styles {
    <!-- DataTables Buttons CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">
    <!-- Select CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/select/1.7.0/css/select.dataTables.min.css">
    <!-- FixedColumns CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/fixedcolumns/4.3.0/css/fixedColumns.dataTables.min.css">
    <!-- Responsive CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/responsive/2.5.0/css/responsive.dataTables.min.css">
    
    <style>
        .custom-dt-container {
            padding: 30px;
            background: #fff;
            border-radius: 25px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.01);
            border: 1px solid rgba(0,0,0,0.03);
            margin-bottom: 30px;
        }

        .dt-header-flex {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
        }

        .dt-header-title {
            font-size: 20px;
            font-weight: 600;
            color: var(--text-dark);
            display: flex;
            align-items: center;
            gap: 15px;
        }
        
        .dt-header-actions {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .dt-icon {
            background: var(--green-light);
            color: var(--green-accent);
            width: 45px;
            height: 45px;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 18px;
        }

        .dataTables_wrapper .dataTables_filter {
            margin-bottom: 25px;
        }
        .dataTables_wrapper .dataTables_filter input {
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 8px 15px;
            outline: none;
            transition: border-color 0.2s;
            background: #f9fafb;
            font-size: 13px;
        }
        .dataTables_wrapper .dataTables_filter input:focus {
            border-color: var(--green-accent);
            background: #fff;
        }

        .dataTables_wrapper .dataTables_paginate .paginate_button.current, 
        .dataTables_wrapper .dataTables_paginate .paginate_button.current:hover {
            background: var(--green-accent) !important;
            color: #fff !important;
            border: none;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(59, 157, 130, 0.3);
            font-weight: 600;
        }

        .dataTables_wrapper .dataTables_paginate .paginate_button {
            border-radius: 10px;
            border: none;
            font-size: 13px;
            margin: 0 3px;
        }
        
        .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
            background: var(--green-light) !important;
            color: var(--green-accent) !important;
            border: none;
        }

        /* Inline Editing styling */
        .editable {
            position: relative;
            cursor: pointer;
            transition: background 0.2s;
        }
        .editable:hover {
            background-color: #f3f4f6;
            border-radius: 6px;
        }
        .editable:hover::after {
            content: "\f304";
            font-family: "Font Awesome 6 Free";
            font-weight: 900;
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-gray);
            font-size: 13px;
        }
        .editing-input {
            width: 100%;
            border: 1px solid var(--green-accent);
            border-radius: 8px;
            padding: 6px 10px;
            font-family: inherit;
            outline: none;
            box-shadow: 0 0 0 3px rgba(59, 157, 130, 0.15);
            font-size: 14px;
        }

        /* Column filter inputs (integrated inside header) */
        .col-search-input {
            width: 100%;
            border: 1px solid #e5e7eb;
            border-radius: 6px;
            padding: 4px 8px;
            font-size: 11px;
            outline: none;
            box-sizing: border-box;
            background: #fff;
            font-weight: 400;
            margin-top: 8px;
            display: block;
        }
        .col-search-input:focus {
            border-color: var(--green-accent);
        }

        /* Minimal Table Styling */
        table.dataTable {
            margin-top: 15px !important;
            margin-bottom: 20px !important;
            border-collapse: collapse !important;
        }
        table.dataTable thead th, table.dataTable tfoot th {
            border-bottom: 1px solid #e5e7eb;
            color: var(--text-gray);
            font-weight: 600;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 12px 10px;
        }
        table.dataTable.no-footer {
            border-bottom: 1px solid #e5e7eb;
        }
        table.dataTable tbody td {
            padding: 16px 10px;
            vertical-align: middle;
            font-size: 14px;
            color: var(--text-dark);
            border-bottom: 1px solid #f3f4f6;
        }
        table.dataTable tbody tr {
            transition: background-color 0.2s;
        }
        table.dataTable tbody tr:hover {
            background-color: #fcfcfd !important;
        }

        /* Status badges inside table */
        .table-badge {
            padding: 5px 12px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 600;
        }
        .badge-success { background: #e6f4ea; color: #1e8e3e; }
        .badge-warning { background: #fef7e0; color: #b08d00; }
        .badge-danger { background: #fce8e6; color: #d93025; }
        .badge-info { background: #e8f0fe; color: #1a73e8; }
        
        /* DataTable actions wrapper customized */
        .dt-top-flex {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            flex-wrap: wrap;
            gap: 15px;
        }
        
        .dt-buttons .btn {
            border-radius: 10px;
            font-size: 13px;
            padding: 6px 14px;
            margin-right: 5px;
            box-shadow: none;
            background: #fff;
            border-color: #e5e7eb;
            color: var(--text-dark);
        }
        
        .dt-buttons .btn:hover {
            background: #f9fafb;
            color: var(--green-accent);
            border-color: var(--green-accent);
        }

        /* Detail table row styling */
        td.details-control {
            text-align: center;
            color: var(--green-accent);
            cursor: pointer;
            width: 30px;
        }
        td.details-control::after {
            content: "\f055"; /* fontawesome fa-circle-plus */
            font-family: inherit;
        }
        tr.shown td.details-control::after {
            content: "\f056"; /* fontawesome fa-circle-minus */
            color: var(--danger);
        }
        
        .dt-details-table {
            background-color: #f9fafb;
            border-radius: 8px;
            padding: 15px;
            border: 1px dashed #e5e7eb;
        }
        
        /* Revert padding on basic nested progress bar */
        .table td .progress {
            margin-bottom: 0;
            background-color: #e9ecef;
            border-radius: 3px;
        }
    </style>
}

