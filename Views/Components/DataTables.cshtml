@section Scripts {
    <!-- Extend DataTables with Buttons and Select -->
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/vfs_fonts.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>
    <script src="https://cdn.datatables.net/select/1.7.0/js/dataTables.select.min.js"></script>
    <script src="https://cdn.datatables.net/fixedcolumns/4.3.0/js/dataTables.fixedColumns.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>

    <script>
        $(document).ready(function() {
            // STEP 1: CACHE RAW HTML FOR COPY BUTTONS
            // Cache raw html of components before DataTables injects DOM elements
            $('.custom-dt-container').each(function() {
                var btn = $(this).find('.btn-copyHtml');
                if (btn.length) {
                    var rawHtml = $(this).prop('outerHTML');
                    btn.data('raw-html', rawHtml);
                }
            });

            // 0. Basic and Action initialized
            $('#table-basic').DataTable({ "pageLength": 5, "lengthChange": false });
            $('#table-action').DataTable({ "pageLength": 5, "lengthChange": false });
            
            // 1. Inline Editing Example
            var tableInline = $('#table-inline-edit').DataTable({
                "pageLength": 5,
                "lengthChange": false
            });

            $('#table-inline-edit tbody').on('dblclick', 'td.editable', function () {
                var cell = tableInline.cell(this);
                var originalValue = cell.data();
                if ($(this).find('input').length > 0) return;
                $(this).html('<input type="text" class="editing-input" value="' + originalValue + '">');
                var inputElement = $(this).find('input');
                inputElement.focus();
                var val = inputElement.val(); inputElement.val(''); inputElement.val(val);
                inputElement.on('blur keypress', function (e) {
                    if (e.type === 'keypress' && e.which !== 13) return;
                    cell.data($(this).val()).draw();
                });
            });

            // 2. Column Search Initialization
            // Inject search inputs into header cols that have data-search="true"
            $('#table-col-search thead th[data-search="true"]').each(function () {
                var title = $(this).text();
                $(this).append('<input type="text" class="col-search-input" placeholder="Search '+title+'" />');
            });
            // Stop sorting when clicking on search inputs inside header
            $('.col-search-input').on('click mousedown keydown', function(e) {
                e.stopPropagation();
            });

            var tableSearch = $('#table-col-search').DataTable({
                "pageLength": 5,
                "lengthChange": false,
                initComplete: function () {
                    this.api().columns().every(function () {
                        var that = this;
                        // find input in header
                        var input = $(this.header()).find('input');
                        if (input.length) {
                            input.on('keyup change clear', function () {
                                if (that.search() !== this.value) {
                                    that.search(this.value).draw();
                                }
                            });
                        }
                    });
                }
            });

            // 3. Export & Row Selection
            $('#table-export').DataTable({
                dom: '<"dt-top-flex"Bf>rt<"dt-bottom-flex d-flex justify-content-between mt-3"ip>',
                pageLength: 5,
                columnDefs: [ { orderable: false, className: 'select-checkbox', targets: 0 } ],
                select: { style: 'multi', selector: 'td:first-child' },
                order: [[ 1, 'asc' ]],
                buttons: [
                    { extend: 'copy', className: 'btn', text: '<i class="fa-regular fa-copy"></i> Copy' },
                    { extend: 'csv', className: 'btn', text: '<i class="fa-solid fa-file-csv"></i> CSV' },
                    { extend: 'excel', className: 'btn', text: '<i class="fa-regular fa-file-excel"></i> Excel' },
                    { extend: 'pdf', className: 'btn', text: '<i class="fa-regular fa-file-pdf"></i> PDF' },
                    { extend: 'print', className: 'btn', text: '<i class="fa-solid fa-print"></i> Print' }
                ]
            });
            
            // 4. Row Details & Modals
            var tableDetails = $('#table-row-details').DataTable({
                "pageLength": 5,
                 "lengthMenu": [5, 10, 25, 50],
            });
            
            function format ( rowData, taskDesc ) {
                return '<div class="dt-details-table">' +
                    '<h6 class="mb-2 text-dark"><i class="fa-solid fa-align-left me-2"></i>Task Execution Plan</h6>'+
                    '<p class="mb-3 text-secondary text-sm" style="font-size: 13px;">' + taskDesc + '</p>' +
                    '<button class="btn btn-sm btn-success me-2" onclick="alert(\'Approving task...\')"><i class="fa-solid fa-check me-1"></i> Approve</button>' +
                    '<button class="btn btn-sm btn-outline-danger" onclick="alert(\'Rejecting task...\')"><i class="fa-solid fa-xmark me-1"></i> Reject</button>' +
                '</div>';
            }

            $('#table-row-details tbody').on('click', 'td.details-control', function () {
                var tr = $(this).closest('tr');
                var row = tableDetails.row( tr );
                var desc = tr.data('desc');

                if ( row.child.isShown() ) {
                    row.child.hide();
                    tr.removeClass('shown');
                } else {
                    row.child( format(row.data(), desc) ).show();
                    tr.addClass('shown');
                }
            });

            // 5. Expand / Collapse Group Data
            var groupColumn = 2; // Group based on Location column
            var tableGroup = $('#table-group').DataTable({
                pageLength: 25,
                lengthChange: false,
                columnDefs: [ { visible: false, targets: groupColumn } ],
                order: [[ groupColumn, 'asc' ]],
                drawCallback: function ( settings ) {
                    var api = this.api();
                    var rows = api.rows( {page:'current'} ).nodes();
                    var last = null;
         
                    api.column(groupColumn, {page:'current'} ).data().each( function ( group, i ) {
                        if ( last !== group ) {
                            var groupId = group.replace(/\s+/g, '-').toLowerCase();
                            $(rows).eq( i ).before(
                                '<tr class="group-header" data-group="'+groupId+'" style="background-color: var(--green-light); cursor: pointer;"><td colspan="5" class="text-dark"><i class="fa-solid fa-angle-down group-toggle me-2" style="color: var(--green-accent)"></i><strong>' + group + '</strong></td></tr>'
                            );
                            last = group;
                        }
                        var currentGroupId = group.replace(/\s+/g, '-').toLowerCase();
                        $(rows).eq(i).addClass('group-row-' + currentGroupId);
                    } );
                }
            });

            $('#table-group tbody').on('click', 'tr.group-header', function () {
                var groupId = $(this).data('group');
                var rows = $('.group-row-' + groupId);
                var icon = $(this).find('.group-toggle');
                
                if(rows.is(':visible')){
                    rows.hide();
                    icon.removeClass('fa-angle-down').addClass('fa-angle-right');
                } else {
                    rows.show();
                    icon.removeClass('fa-angle-right').addClass('fa-angle-down');
                }
            });

            // 6. Frozen / Fixed Columns DataTable
            $('#table-fixed-cols').DataTable({
                pageLength: 5,
                scrollX: true,
                fixedColumns: {
                    leftColumns: 1,  // Freeze first 1 column (First name)
                    rightColumns: 1  // Freeze last 1 column (E-mail)
                }
            });

            // 7. Responsive Auto-hide columns DataTable
            $('#table-responsive').DataTable({
                responsive: true,
                pageLength: 5,
                columnDefs: [
                    { responsivePriority: 1, targets: 0 },
                    { responsivePriority: 2, targets: -1 }
                ]
            });

            // Adjust buttons styling manually
            setTimeout(() => {
                $('.dt-button').removeClass('dt-button');
            }, 100);

            // Copy HTML functionality
            $('.btn-copyHtml').on('click', function() {
                var rawHtml = $(this).data('raw-html');
                
                // create a temporary textarea to copy from
                var $temp = $("<textarea>");
                $("body").append($temp);
                $temp.val(rawHtml).select();
                document.execCommand("copy");
                $temp.remove();

                // Show toast
                const toast = $('#copyToast');
                toast.fadeIn(300);
                setTimeout(function(){ toast.fadeOut(500); }, 3000);
            });

        });
    </script>
}
