@{ ViewData["Title"] = "Alerts & Notifications"; }
<div class="row">
    <div class="col-md-6 mb-4">
        <div class="card">
            <div class="card-header border-0"><h5 class="mb-0 fw-bold">Standard Alerts</h5></div>
            <div class="card-body">
                <div class="alert alert-primary" role="alert">A simple primary alert—check it out!</div>
                <div class="alert alert-success" role="alert">A simple success alert—check it out!</div>
                <div class="alert alert-danger" role="alert">A simple danger alert—check it out!</div>
                <div class="alert alert-warning" role="alert">A simple warning alert—check it out!</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-4">
        <div class="card">
            <div class="card-header border-0"><h5 class="mb-0 fw-bold">Modern Icon Alerts</h5></div>
            <div class="card-body">
                <div class="alert alert-success d-flex align-items-center" role="alert">
                  <i class="fas fa-check-circle fa-2x me-3"></i>
                  <div><strong>Success!</strong> Your operation was completed successfully.</div>
                </div>
                <div class="alert alert-warning d-flex align-items-center" role="alert">
                  <i class="fas fa-exclamation-triangle fa-2x me-3"></i>
                  <div><strong>Warning:</strong> Please review your inputs before proceeding.</div>
                </div>
                <div class="alert alert-danger d-flex align-items-center alert-dismissible fade show" role="alert">
                  <i class="fas fa-times-circle fa-2x me-3"></i>
                  <div><strong>Error!</strong> An unexpected issue occurred during processing.</div>
                  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 mb-4">
        <div class="card">
            <div class="card-header border-0"><h5 class="mb-0 fw-bold">Soft Styling Alerts</h5></div>
            <div class="card-body">
                <div class="alert bg-success bg-opacity-10 text-success border-0 border-start border-success border-4" role="alert">
                  Everything looks great! You are ready to launch your application.
                </div>
                <div class="alert bg-danger bg-opacity-10 text-danger border-0 border-start border-danger border-4" role="alert">
                  Oops! We couldn't connect to the database. Please check your credentials.
                </div>
            </div>
        </div>
    </div>
</div>
