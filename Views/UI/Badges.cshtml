@{ ViewData["Title"] = "Badges"; }
<div class="row">
    <div class="col-md-6 mb-4">
        <div class="card h-100">
            <div class="card-header border-0"><h5 class="mb-0 fw-bold">Contextual Badges</h5></div>
            <div class="card-body">
                <span class="badge bg-primary">Primary</span>
                <span class="badge bg-secondary">Secondary</span>
                <span class="badge bg-success">Success</span>
                <span class="badge bg-danger">Danger</span>
                <span class="badge bg-warning text-dark">Warning</span>
                <span class="badge bg-info text-dark">Info</span>
                <span class="badge bg-light text-dark">Light</span>
                <span class="badge bg-dark">Dark</span>
                
                <h6 class="mt-4 mb-3">Pill Badges</h6>
                <span class="badge rounded-pill bg-primary">Primary</span>
                <span class="badge rounded-pill bg-success">Success</span>
                <span class="badge rounded-pill bg-danger">Danger</span>
                <span class="badge rounded-pill bg-info text-dark">Info</span>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-4">
        <div class="card h-100">
            <div class="card-header border-0"><h5 class="mb-0 fw-bold">Soft & Icon Badges</h5></div>
            <div class="card-body">
                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary">Soft Primary</span>
                <span class="badge bg-success bg-opacity-10 text-success border border-success">Soft Success</span>
                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger">Soft Danger</span>
                <span class="badge bg-warning bg-opacity-10 text-warning border border-warning">Soft Warning</span>
                
                <h6 class="mt-4 mb-3">Icon Badges</h6>
                <span class="badge bg-primary rounded-pill px-3 py-2"><i class="fas fa-check me-1"></i> Verified</span>
                <span class="badge bg-danger rounded-pill px-3 py-2"><i class="fas fa-times me-1"></i> Failed</span>
                <span class="badge bg-warning text-dark rounded-pill px-3 py-2"><i class="fas fa-clock me-1"></i> Pending</span>
            </div>
        </div>
    </div>
</div>
