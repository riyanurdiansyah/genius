@{ ViewData["Title"] = "Badges"; }

<div class="row g-4">
    <!-- Existing Contextual Badges -->
    <div class="col-md-6">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-header bg-white border-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold"><i class="fas fa-tags text-primary me-2"></i>Contextual Badges</h5>
                <button class="btn btn-sm btn-outline-primary copy-btn" data-target="contextualBadges"><i class="fa-regular fa-copy"></i> Copy HTML</button>
            </div>
            <div class="card-body" id="contextualBadges">
                <p class="text-muted small mb-3">Default solid color badges to express state or category.</p>
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge bg-primary">Primary</span>
                    <span class="badge bg-secondary">Secondary</span>
                    <span class="badge bg-success">Success</span>
                    <span class="badge bg-danger">Danger</span>
                    <span class="badge bg-warning text-dark">Warning</span>
                    <span class="badge bg-info text-dark">Info</span>
                    <span class="badge bg-light text-dark">Light</span>
                    <span class="badge bg-dark">Dark</span>
                </div>

                <h6 class="mt-4 mb-2 fw-semibold">Pill Badges</h6>
                <p class="text-muted small mb-3">Use the <code>.rounded-pill</code> modifier class to make badges more rounded.</p>
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge rounded-pill bg-primary">Primary</span>
                    <span class="badge rounded-pill bg-success">Success</span>
                    <span class="badge rounded-pill bg-danger">Danger</span>
                    <span class="badge rounded-pill bg-warning text-dark">Warning</span>
                    <span class="badge rounded-pill bg-info text-dark">Info</span>
                    <span class="badge rounded-pill bg-dark">Dark</span>
                </div>
                
                <h6 class="mt-4 mb-2 fw-semibold">Outline Badges</h6>
                <p class="text-muted small mb-3">Badges with a transparent background and colored borders.</p>
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge bg-transparent border border-primary text-primary">Primary</span>
                    <span class="badge bg-transparent border border-success text-success">Success</span>
                    <span class="badge bg-transparent border border-danger text-danger">Danger</span>
                    <span class="badge bg-transparent border border-warning text-warning">Warning</span>
                    <span class="badge bg-transparent border border-info text-info">Info</span>
                    <span class="badge bg-transparent border border-dark text-dark">Dark</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Soft & Icon Badges -->
    <div class="col-md-6">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-header bg-white border-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold"><i class="fas fa-star text-warning me-2"></i>Soft & Icon Badges</h5>
                <button class="btn btn-sm btn-outline-primary copy-btn" data-target="softIconBadges"><i class="fa-regular fa-copy"></i> Copy HTML</button>
            </div>
            <div class="card-body" id="softIconBadges">
                <h6 class="mb-2 fw-semibold">Soft Backgrounds & Borders</h6>
                <p class="text-muted small mb-3">Badges with semi-transparent backgrounds for a softer look.</p>
                <div class="d-flex flex-wrap gap-2 mb-3">
                    <span class="badge bg-primary bg-opacity-10 text-primary">Soft Primary</span>
                    <span class="badge bg-success bg-opacity-10 text-success">Soft Success</span>
                    <span class="badge bg-danger bg-opacity-10 text-danger">Soft Danger</span>
                    <span class="badge bg-warning bg-opacity-10 text-warning">Soft Warning</span>
                    <span class="badge bg-info bg-opacity-10 text-info">Soft Info</span>
                    <span class="badge bg-dark bg-opacity-10 text-dark">Soft Dark</span>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary">Bordered Soft Primary</span>
                    <span class="badge bg-success bg-opacity-10 text-success border border-success">Bordered Soft Success</span>
                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger">Bordered Soft Danger</span>
                </div>
                
                <h6 class="mt-4 mb-2 fw-semibold">Icon Badges</h6>
                <p class="text-muted small mb-3">Combine icons with badges to convey more context.</p>
                <div class="d-flex flex-wrap gap-2 mb-2">
                    <span class="badge bg-primary rounded-pill px-3 py-2"><i class="fas fa-check me-1"></i> Verified</span>
                    <span class="badge bg-danger rounded-pill px-3 py-2"><i class="fas fa-times me-1"></i> Failed</span>
                    <span class="badge bg-warning text-dark rounded-pill px-3 py-2"><i class="fas fa-clock me-1"></i> Pending</span>
                    <span class="badge bg-info text-dark rounded-pill px-3 py-2"><i class="fas fa-info-circle me-1"></i> Info</span>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-3 py-2"><i class="fas fa-arrow-trend-up me-1"></i> +14.5%</span>
                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger rounded-pill px-3 py-2"><i class="fas fa-arrow-trend-down me-1"></i> -3.2%</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Notification & Counter Badges -->
    <div class="col-md-6">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-header bg-white border-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold"><i class="fas fa-bell text-danger me-2"></i>Counters & Notifications</h5>
                <button class="btn btn-sm btn-outline-primary copy-btn" data-target="counterNotifications"><i class="fa-regular fa-copy"></i> Copy HTML</button>
            </div>
            <div class="card-body" id="counterNotifications">
                <h6 class="mb-2 fw-semibold">Button Counters</h6>
                <p class="text-muted small mb-3">Badges can be used as part of links or buttons to provide a counter.</p>
                
                <div class="d-flex flex-wrap gap-3 mb-4">
                    <button type="button" class="btn btn-primary d-flex align-items-center">
                        Notifications <span class="badge bg-white text-primary ms-2 rounded-pill">4</span>
                    </button>
                    <button type="button" class="btn btn-outline-secondary d-flex align-items-center">
                        Messages <span class="badge bg-danger ms-2">99+</span>
                    </button>
                    <button type="button" class="btn btn-success d-flex align-items-center">
                        <i class="fas fa-inbox me-2"></i> Inbox <span class="badge rounded-pill bg-white text-success ms-2">New</span>
                    </button>
                </div>
                
                <h6 class="mt-4 mb-2 fw-semibold">Positioned Badges (Corner)</h6>
                <p class="text-muted small mb-3">Position badges at the corner of an element using utilities.</p>
                <div class="d-flex flex-wrap gap-4 mt-3 pb-2 pt-2">
                    <!-- Button with badge -->
                    <button type="button" class="btn btn-primary position-relative">
                        Inbox
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-2 border-white">
                            99+
                            <span class="visually-hidden">unread messages</span>
                        </span>
                    </button>
                    <!-- Button with dot -->
                    <button type="button" class="btn btn-outline-dark position-relative">
                        Profile
                        <span class="position-absolute top-0 start-100 translate-middle p-2 bg-success border border-2 border-white rounded-circle">
                            <span class="visually-hidden">New alerts</span>
                        </span>
                    </button>
                    <!-- Icon with badge -->
                    <div class="position-relative d-inline-block bg-light p-3 rounded text-secondary">
                        <i class="fas fa-bell fs-4"></i>
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger shadow-sm" style="transform: translate(-30%, -30%) !important;">
                            5
                        </span>
                    </div>
                    <!-- Icon with dot -->
                    <div class="position-relative d-inline-block bg-light p-3 rounded text-secondary">
                        <i class="fas fa-envelope fs-4"></i>
                        <span class="position-absolute top-0 start-100 translate-middle p-2 bg-warning border border-2 border-white rounded-circle" style="transform: translate(-30%, -30%) !important;"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Avatar Status & Ribbons -->
    <div class="col-md-6">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-header bg-white border-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold"><i class="fas fa-user-circle text-info me-2"></i>Status Indicators & Ribbons</h5>
                <button class="btn btn-sm btn-outline-primary copy-btn" data-target="statusIndicators"><i class="fa-regular fa-copy"></i> Copy HTML</button>
            </div>
            <div class="card-body" id="statusIndicators">
                <h6 class="mb-2 fw-semibold">Dot Indicators (List)</h6>
                <div class="d-flex flex-row flex-wrap gap-3 mb-4">
                    <div class="d-flex align-items-center"><span class="badge bg-success p-1 rounded-circle me-2" style="width: 10px; height: 10px; display: inline-block;"></span> Online</div>
                    <div class="d-flex align-items-center"><span class="badge bg-warning p-1 rounded-circle me-2" style="width: 10px; height: 10px; display: inline-block;"></span> Away</div>
                    <div class="d-flex align-items-center"><span class="badge bg-danger p-1 rounded-circle me-2" style="width: 10px; height: 10px; display: inline-block;"></span> Busy</div>
                    <div class="d-flex align-items-center"><span class="badge bg-secondary p-1 rounded-circle me-2" style="width: 10px; height: 10px; display: inline-block;"></span> Offline</div>
                </div>
                
                <h6 class="mt-4 mb-3 fw-semibold">Avatar Status Elements</h6>
                <div class="d-flex flex-wrap gap-4 align-items-center mb-4">
                    <div class="position-relative d-inline-block">
                        <img src="https://ui-avatars.com/api/?name=John+Doe&background=random" class="rounded-circle shadow-sm" width="56" height="56" alt="User">
                        <span class="position-absolute bottom-0 end-0 p-1 bg-success border border-2 border-white rounded-circle" style="width: 16px; height: 16px;"></span>
                    </div>
                    <div class="position-relative d-inline-block">
                        <img src="https://ui-avatars.com/api/?name=Jane+Smith&background=random" class="rounded-circle shadow-sm" width="56" height="56" alt="User">
                        <span class="position-absolute bottom-0 end-0 badge rounded-pill bg-danger border border-2 border-white shadow-sm" style="font-size: 0.7rem; padding: 3px 6px; transform: translate(15%, 15%);">3</span>
                    </div>
                    <div class="position-relative d-inline-block">
                        <div class="bg-primary text-white d-flex align-items-center justify-content-center rounded-circle fw-bold shadow-sm" style="width: 56px; height: 56px; font-size: 1.2rem;">KT</div>
                        <span class="position-absolute top-0 end-0 p-1 bg-warning border border-2 border-white rounded-circle" style="width: 16px; height: 16px;"></span>
                    </div>
                </div>

                <style>
                    .ribbon-wrapper {
                        width: 85px;
                        height: 85px;
                        overflow: hidden;
                        position: absolute;
                        top: -3px;
                        right: -3px;
                        z-index: 10;
                    }
                    .ribbon {
                        font-size: 11px;
                        font-weight: 700;
                        color: #FFF;
                        text-transform: uppercase;
                        text-align: center;
                        line-height: 24px;
                        transform: rotate(45deg);
                        width: 120px;
                        display: block;
                        box-shadow: 0 4px 6px rgba(0,0,0,.15);
                        position: absolute;
                        top: 15px;
                        right: -30px;
                    }
                    .ribbon-danger-gradient { background: linear-gradient(135deg, var(--bs-danger), #b01a1a); }
                    .ribbon-warning-gradient { background: linear-gradient(135deg, var(--bs-warning), #d69e00); color: #000; }
                    .ribbon-success-gradient { background: linear-gradient(135deg, var(--bs-success), #146c43); text-shadow: 0 1px 1px rgba(0,0,0,0.2); }
                </style>
                <h6 class="mt-4 mb-3 fw-semibold">Card Corner Ribbons</h6>
                <div class="row g-3">
                    <div class="col-6">
                        <div class="card position-relative border border-danger border-opacity-25 shadow-sm" style="background:#fff5f5;">
                            <div class="ribbon-wrapper"><div class="ribbon ribbon-danger-gradient">NEW</div></div>
                            <div class="card-body p-3">
                                <p class="mb-0 fw-bold text-danger">New Feature</p>
                                <small class="text-danger text-opacity-75">Check this out</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="card bg-white position-relative border-0 shadow-sm">
                            <div class="ribbon-wrapper"><div class="ribbon ribbon-success-gradient">PRO</div></div>
                            <div class="card-body p-3">
                                <p class="mb-0 fw-bold">Premium Plan</p>
                                <small class="text-muted">Unlock features</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
