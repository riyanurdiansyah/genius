                <nav class="navbar navbar-expand-lg navbar-dark px-4 py-2 w-100 shadow" style="background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(15px); -webkit-backdrop-filter: blur(15px); border: 1px solid rgba(255, 255, 255, 0.2); border-radius: 16px;">
                  <div class="container-fluid">
                    <a class="navbar-brand fw-bold text-white d-flex align-items-center" href="#">
                        <i class="fas fa-cube me-2 text-white"></i> GLASS UI
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarGlass" aria-controls="navbarGlass" aria-expanded="false" aria-label="Toggle navigation">
                      <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="navbarGlass">
                        <ul class="navbar-nav ms-auto mb-2 mb-lg-0 fw-medium gap-2">
                            <li class="nav-item"><a class="nav-link text-white fw-semibold" href="#">Home</a></li>
                            <li class="nav-item"><a class="nav-link text-white opacity-75" href="#">Features</a></li>
                            <li class="nav-item"><a class="nav-link text-white opacity-75" href="#">Pricing</a></li>
                            <li class="nav-item ms-2">
                                <button class="btn btn-light rounded-pill px-4 fw-medium text-primary">Login</button>
                            </li>
                        </ul>
                    </div>
                  </div>
                </nav>
            </div>
        </div>
    </div>

    <!-- 4. Clean Underline Navbar (Minimalist Profile) -->
    <div class="col-12 mb-4">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-header border-0 bg-white"><h5 class="mb-0 fw-bold">Clean Minimalist Navbar</h5></div>
            <div class="card-body bg-light rounded" style="padding: 2rem;">
                <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm px-4 py-0">
                  <div class="container-fluid">
                    <a class="navbar-brand fw-bolder fs-4" href="#" style="letter-spacing: -0.5px; color: #111827;">
                        MINIMAL.
                    </a>
                    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMinimal" aria-controls="navbarMinimal">
                      <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="navbarMinimal">
                      <ul class="navbar-nav me-auto mb-0" style="min-height: 60px;">
                        <li class="nav-item d-flex align-items-center">
                          <a class="nav-link active px-3 h-100 d-flex align-items-center text-primary" style="border-bottom: 2px solid var(--bs-primary);" href="#">Overview</a>
                        </li>
                        <li class="nav-item d-flex align-items-center">
                          <a class="nav-link px-3 h-100 d-flex align-items-center" href="#">Components</a>
                        </li>
                        <li class="nav-item d-flex align-items-center">
                          <a class="nav-link px-3 h-100 d-flex align-items-center" href="#">Templates</a>
                        </li>
                      </ul>
                      <div class="d-flex align-items-center gap-3 py-2">
                        <div class="input-group input-group-sm" style="width: 200px;">
                            <span class="input-group-text bg-light border-end-0 text-muted"><i class="fas fa-search"></i></span>
                            <input type="text" class="form-control bg-light border-start-0 ps-0" placeholder="Search...">
                        </div>
                        <a href="#" class="text-muted"><i class="fab fa-github fa-lg"></i></a>
                        <a href="#" class="text-muted"><i class="fab fa-twitter fa-lg"></i></a>
                      </div>
                    </div>
                  </div>
