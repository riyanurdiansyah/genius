@{ ViewData["Title"] = "Toasts"; }
<div class="row">
    <div class="col-md-6 mb-4">
        <div class="card h-100">
            <div class="card-header border-0"><h5 class="mb-0 fw-bold">Live Demonstration</h5></div>
            <div class="card-body">
                <p>Click the buttons below to trigger toast notifications. They will stack at the bottom right corner.</p>
                <button type="button" class="btn btn-primary mb-2" id="liveToastBtn1">Show Success Toast</button>
                <button type="button" class="btn btn-danger mb-2" id="liveToastBtn2">Show Error Toast</button>
                
                <!-- Static Example -->
                <h6 class="mt-4 mb-3">Static Layout</h6>
                <div class="toast show" role="alert" aria-live="assertive" aria-atomic="true">
                  <div class="toast-header">
                    <i class="fas fa-bell text-primary me-2"></i>
                    <strong class="me-auto">Notification</strong>
                    <small>11 mins ago</small>
                    <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
                  </div>
                  <div class="toast-body">
                    Hello, world! This is a toast message.
                  </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Toast Container -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1060;">
  
    <div id="liveToast1" class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
      <div class="d-flex">
        <div class="toast-body">
          <i class="fas fa-check-circle me-2"></i> Document saved successfully!
        </div>
        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
      </div>
    </div>
    
    <div id="liveToast2" class="toast align-items-center text-white bg-danger border-0" role="alert" aria-live="assertive" aria-atomic="true">
      <div class="d-flex">
        <div class="toast-body">
          <i class="fas fa-times-circle me-2"></i> Failed to submit the form. Try again.
        </div>
        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
      </div>
    </div>

</div>

@section Scripts {
    <script>
        document.getElementById('liveToastBtn1').addEventListener('click', function () {
            var toastElList1 = [].slice.call(document.querySelectorAll('#liveToast1'))
            var toastList1 = toastElList1.map(function (toastEl) {
              return new bootstrap.Toast(toastEl)
            })
            toastList1.forEach(toast => toast.show())
        });
        
        document.getElementById('liveToastBtn2').addEventListener('click', function () {
            var toastElList2 = [].slice.call(document.querySelectorAll('#liveToast2'))
            var toastList2 = toastElList2.map(function (toastEl) {
              return new bootstrap.Toast(toastEl)
            })
            toastList2.forEach(toast => toast.show())
        });
    </script>
}
