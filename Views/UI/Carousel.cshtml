@{ ViewData["Title"] = "Carousel & Sliders"; }

<style>
    /* Carousel shared classes */
    .carousel-item img {
        object-fit: cover;
    }
    .carousel-caption-glass {
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 12px;
        bottom: 2rem;
        left: 10%;
        right: 10%;
        padding: 1.5rem;
    }
    
    .carousel-caption-dark-glass {
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        bottom: 2rem;
    }
    
    .carousel-indicators-dots [data-bs-target] {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        margin: 0 6px;
        background-color: #fff;
    }
    
    .carousel-indicators-lines [data-bs-target] {
        width: 30px;
        height: 4px;
        border-radius: 2px;
        background-color: #fff;
    }
    
    /* Overlay effects */
    .overlay-gradient-bottom {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 60%;
        background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 100%);
        z-index: 1;
    }
    
    .overlay-primary {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(13, 110, 253, 0.4);
        z-index: 1;
        mix-blend-mode: multiply;
    }

    .carousel-caption {
        z-index: 2;
    }

    /* Testimonial styling */
    .testimonial-card {
        background: transparent;
        border: none;
    }
    .testimonial-avatar {
        width: 80px;
        height: 80px;
        object-fit: cover;
        border: 4px solid var(--bs-primary);
    }
    .testimonial-carousel .carousel-indicators {
        bottom: -20px;
    }
    .testimonial-carousel .carousel-indicators [data-bs-target] {
        background-color: var(--bs-primary);
    }
</style>

<div class="row g-4 mb-5">
    <div class="col-12">
        <h4 class="fw-bold mb-1">Carousel & Sliders</h4>
        <p class="text-muted">Modern slideshows for images, text, and interactive content.</p>
    </div>

    <!-- 1. Modern Glassmorphism Carousel -->
    <div class="col-md-6">
        <div class="card shadow-sm border-0 h-100 overflow-hidden">
            <div class="card-header bg-white border-0 pt-4 pb-3 d-flex justify-content-between align-items-start">
                <div>
                    <h5 class="mb-0 fw-bold"><i class="fas fa-layer-group text-primary me-2"></i>Glassmorphism overlay</h5>
                    <p class="text-muted small mb-0 mt-1">Trendy frosted glass effect with dot indicators.</p>
                </div>
                <button class="btn btn-sm btn-outline-primary copy-btn" data-target="carouselGlassmorphism"><i class="fa-regular fa-copy"></i> Copy HTML</button>
            </div>
            <div class="card-body p-0" id="carouselGlassmorphism">
                <div id="carouselGlass" class="carousel slide" data-bs-ride="carousel">
                    <div class="carousel-indicators carousel-indicators-dots z-3">
                        <button type="button" data-bs-target="#carouselGlass" data-bs-slide-to="0" class="active" aria-current="true"></button>
                        <button type="button" data-bs-target="#carouselGlass" data-bs-slide-to="1"></button>
                        <button type="button" data-bs-target="#carouselGlass" data-bs-slide-to="2"></button>
                    </div>
                    
                    <div class="carousel-inner">
                        <div class="carousel-item active">
                            <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=1200&q=80" class="d-block w-100" style="height: 350px;" alt="...">
                            <div class="carousel-caption carousel-caption-glass d-none d-md-block shadow-sm">
                                <h5 class="fw-bold text-dark mb-1">Modern Workspace</h5>
                                <p class="text-dark opacity-100 mb-0 small fw-medium">Design your office with minimal aesthetics and productivity in mind.</p>
                            </div>
                        </div>
                        <div class="carousel-item">
                            <img src="https://images.unsplash.com/photo-1542744173-8e7e53415bb0?auto=format&fit=crop&w=1200&q=80" class="d-block w-100" style="height: 350px;" alt="...">
                            <div class="carousel-caption carousel-caption-glass d-none d-md-block shadow-sm">
                                <h5 class="fw-bold text-dark mb-1">Team Collaboration</h5>
                                <p class="text-dark opacity-100 mb-0 small fw-medium">Connect your team with seamless digital communication tools.</p>
                            </div>
                        </div>
                        <div class="carousel-item">
                            <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=1200&q=80" class="d-block w-100" style="height: 350px;" alt="...">
                            <div class="carousel-caption carousel-caption-glass d-none d-md-block shadow-sm">
                                <h5 class="fw-bold text-dark mb-1">Data Analytics</h5>
                                <p class="text-dark opacity-100 mb-0 small fw-medium">Track performance visually and boost operational metrics.</p>
                            </div>
                        </div>
                    </div>
                    <button class="carousel-control-prev" type="button" data-bs-target="#carouselGlass" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Previous</span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#carouselGlass" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Next</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- 2. Cinematic Crossfade -->
    <div class="col-md-6">
        <div class="card shadow-sm border-0 h-100 overflow-hidden">
            <div class="card-header bg-white border-0 pt-4 pb-3 d-flex justify-content-between align-items-start">
                <div>
                    <h5 class="mb-0 fw-bold"><i class="fas fa-film text-danger me-2"></i>Crossfade Cinematic</h5>
                    <p class="text-muted small mb-0 mt-1">Uses <code>.carousel-fade</code>, dark gradient overlay, and line indicators.</p>
                </div>
                <button class="btn btn-sm btn-outline-primary copy-btn" data-target="carouselCrossfade"><i class="fa-regular fa-copy"></i> Copy HTML</button>
            </div>
            <div class="card-body p-0" id="carouselCrossfade">
                <div id="carouselFade" class="carousel slide carousel-fade" data-bs-ride="carousel">
                    <div class="carousel-indicators carousel-indicators-lines z-3">
                        <button type="button" data-bs-target="#carouselFade" data-bs-slide-to="0" class="active"></button>
                        <button type="button" data-bs-target="#carouselFade" data-bs-slide-to="1"></button>
                        <button type="button" data-bs-target="#carouselFade" data-bs-slide-to="2"></button>
                    </div>
                    
                    <div class="carousel-inner">
                        <div class="carousel-item active">
                            <div class="overlay-gradient-bottom"></div>
                            <img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=1200&q=80" class="d-block w-100" style="height: 350px;" alt="...">
                            <div class="carousel-caption d-none d-md-block text-start" style="bottom: 3rem; left: 8%;">
                                <span class="badge bg-danger rounded-pill px-3 mb-2">HOT TREND</span>
                                <h3 class="fw-bold text-white mb-2">Future of Big Data</h3>
                                <button class="btn btn-outline-light btn-sm rounded-pill px-4">Read Article</button>
                            </div>
                        </div>
                        <div class="carousel-item">
                            <div class="overlay-gradient-bottom"></div>
                            <img src="https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&fit=crop&w=1200&q=80" class="d-block w-100" style="height: 350px;" alt="...">
                            <div class="carousel-caption d-none d-md-block text-start" style="bottom: 3rem; left: 8%;">
                                <span class="badge bg-primary rounded-pill px-3 mb-2">CYBERSECURITY</span>
                                <h3 class="fw-bold text-white mb-2">Protecting Cloud Assets</h3>
                                <button class="btn btn-primary btn-sm rounded-pill px-4 border-0">Learn More</button>
                            </div>
                        </div>
                        <div class="carousel-item">
                            <div class="overlay-gradient-bottom"></div>
                            <img src="https://images.unsplash.com/photo-1504384308090-c894fdcc538d?auto=format&fit=crop&w=1200&q=80" class="d-block w-100" style="height: 350px;" alt="...">
                            <div class="carousel-caption d-none d-md-block text-start" style="bottom: 3rem; left: 8%;">
                                <span class="badge bg-warning text-dark rounded-pill px-3 mb-2">NEW FEATURE</span>
                                <h3 class="fw-bold text-white mb-2">Team Sync Update V2</h3>
                                <button class="btn btn-warning text-dark btn-sm rounded-pill px-4 border-0 fw-bold">Update Now</button>
                            </div>
                        </div>
                    </div>
                    <button class="carousel-control-prev z-3" type="button" data-bs-target="#carouselFade" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Previous</span>
                    </button>
                    <button class="carousel-control-next z-3" type="button" data-bs-target="#carouselFade" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Next</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- 3. Testimonial / Text-Only Carousel -->
    <div class="col-md-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white border-0 pt-4 pb-0 d-flex justify-content-between align-items-start">
                <div>
                    <h5 class="mb-0 fw-bold"><i class="fas fa-quote-left text-success me-2"></i>Testimonial Slider</h5>
                    <p class="text-muted small mb-0 mt-1">Perfect for reviews, quotes, and pure text sliding.</p>
                </div>
                <button class="btn btn-sm btn-outline-primary copy-btn" data-target="carouselTestimonialTarget"><i class="fa-regular fa-copy"></i> Copy HTML</button>
            </div>
            <div class="card-body d-flex align-items-center bg-light rounded-bottom m-3 p-4" id="carouselTestimonialTarget">
                
                <div id="carouselTestimonial" class="carousel slide testimonial-carousel w-100" data-bs-ride="carousel">
                    <div class="carousel-indicators mb-0">
                        <button type="button" data-bs-target="#carouselTestimonial" data-bs-slide-to="0" class="active rounded-circle" style="width:10px;height:10px;"></button>
                        <button type="button" data-bs-target="#carouselTestimonial" data-bs-slide-to="1" class="rounded-circle" style="width:10px;height:10px;"></button>
                        <button type="button" data-bs-target="#carouselTestimonial" data-bs-slide-to="2" class="rounded-circle" style="width:10px;height:10px;"></button>
                    </div>
                    
                    <div class="carousel-inner text-center pb-4">
                        <div class="carousel-item active">
                            <img src="https://ui-avatars.com/api/?name=Sarah+Johnson&background=0D8ABC&color=fff" class="rounded-circle testimonial-avatar shadow-sm mb-3">
                            <h5 class="fw-bold mb-1">Sarah Johnson</h5>
                            <span class="text-warning small d-block mb-3">
                                <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
                            </span>
                            <p class="text-muted fst-italic px-4 mx-auto">"This framework drastically improved our team's delivery time. The UI components are beautiful and ready to use."</p>
                        </div>
                        <div class="carousel-item">
                            <img src="https://ui-avatars.com/api/?name=Michael+Chen&background=f0ad4e&color=fff" class="rounded-circle testimonial-avatar shadow-sm mb-3">
                            <h5 class="fw-bold mb-1">Michael Chen</h5>
                            <span class="text-warning small d-block mb-3">
                                <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star-half-alt"></i>
                            </span>
                            <p class="text-muted fst-italic px-4 mx-auto">"I've worked with many dashboard templates before, but this one stands out due to its modular architecture and elegance."</p>
                        </div>
                        <div class="carousel-item">
                            <img src="https://ui-avatars.com/api/?name=Emily+Davis&background=d9534f&color=fff" class="rounded-circle testimonial-avatar shadow-sm mb-3">
                            <h5 class="fw-bold mb-1">Emily Davis</h5>
                            <span class="text-warning small d-block mb-3">
                                <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
                            </span>
                            <p class="text-muted fst-italic px-4 mx-auto">"The amount of built-in UI components and tools is staggering. It serves all our SaaS application needs perfectly."</p>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- 4. Colored Filter & Dark Theme -->
    <div class="col-md-6">
        <div class="card shadow-sm border-0 h-100 overflow-hidden">
            <div class="card-header bg-white border-0 pt-4 pb-3 d-flex justify-content-between align-items-start">
                <div>
                    <h5 class="mb-0 fw-bold"><i class="fas fa-swatchbook text-info me-2"></i>Dark Overlay & Filters</h5>
                    <p class="text-muted small mb-0 mt-1">Blend modes and dark frosted glass for typography focus.</p>
                </div>
                <button class="btn btn-sm btn-outline-primary copy-btn" data-target="carouselDarkOverlay"><i class="fa-regular fa-copy"></i> Copy HTML</button>
            </div>
            <div class="card-body p-0" id="carouselDarkOverlay">
                <div id="carouselFilter" class="carousel slide" data-bs-ride="carousel" data-bs-interval="3500">
                    <div class="carousel-indicators carousel-indicators-lines z-3">
                        <button type="button" data-bs-target="#carouselFilter" data-bs-slide-to="0" class="active"></button>
                        <button type="button" data-bs-target="#carouselFilter" data-bs-slide-to="1"></button>
                    </div>
                    
                    <div class="carousel-inner">
                        <div class="carousel-item active position-relative">
                            <div class="overlay-primary"></div>
                            <img src="https://images.unsplash.com/photo-1519389950473-47ba0277781c?auto=format&fit=crop&w=1200&q=80" class="d-block w-100 grayscale hover-color" style="height: 350px;" alt="...">
                            <div class="carousel-caption carousel-caption-dark-glass d-none d-md-block shadow-lg p-4">
                                <h4 class="fw-bold text-white mb-2"><i class="fas fa-rocket text-primary me-2"></i>Productivity Boost</h4>
                                <p class="text-white opacity-75 mb-0">Experience a blue color filter overlay combining beautifully with dark glass cards to emphasize your branding.</p>
                            </div>
                        </div>
                        <div class="carousel-item position-relative">
                            <!-- Orange/Danger filter -->
                            <div class="overlay-primary" style="background: rgba(220, 53, 69, 0.4);"></div>
                            <img src="https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&w=1200&q=80" class="d-block w-100" style="height: 350px;" alt="...">
                            <div class="carousel-caption carousel-caption-dark-glass d-none d-md-block shadow-lg p-4">
                                <h4 class="fw-bold text-white mb-2"><i class="fas fa-chart-line text-danger me-2"></i>Analytics Tracking</h4>
                                <p class="text-white opacity-75 mb-0">Dynamic overlays change the mood of the image entirely to match the action taking place.</p>
                            </div>
                        </div>
                    </div>
                    
                    <button class="carousel-control-prev z-3" type="button" data-bs-target="#carouselFilter" data-bs-slide="prev">
                        <div class="bg-dark bg-opacity-50 p-2 rounded-circle">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        </div>
                    </button>
                    <button class="carousel-control-next z-3" type="button" data-bs-target="#carouselFilter" data-bs-slide="next">
                        <div class="bg-dark bg-opacity-50 p-2 rounded-circle">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        </div>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
