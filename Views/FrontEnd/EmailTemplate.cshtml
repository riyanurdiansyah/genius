@{
    ViewData["Title"] = "Pro Email Template Variants";
}

<style>
    /* ═══════════════════════════════════════════════
       MODERN EMAIL TEMPLATE GALLERY — Ultra Dynamic
    ═══════════════════════════════════════════════ */
    :root {
        --e-primary: #3b9d82;
        --e-bg: #f8fafc;
        --e-card: #ffffff;
        --e-text: #1e293b;
        --e-font: var(--font-family-primary);
    }

    [data-theme="dark"] {
        --e-bg: #0f172a;
        --e-card: #1e293b;
        --e-text: #f1f5f9;
    }

    .variant-pills {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 30px;
        padding: 10px;
        background: rgba(59, 157, 130, 0.05);
        border-radius: 100px;
        width: max-content;
    }

    .pill-item {
        padding: 10px 24px;
        border-radius: 100px;
        font-weight: 700;
        font-size: 0.85rem;
        cursor: pointer;
        transition: all 0.3s;
        border: 1px solid transparent;
        color: #64748b;
        background: transparent;
    }

    .pill-item:hover {
        background: rgba(59, 157, 130, 0.1);
        color: var(--e-primary);
    }

    .pill-item.active {
        background: var(--e-primary);
        color: white;
        box-shadow: 0 10px 20px rgba(59, 157, 130, 0.2);
    }

    .email-preview-wrapper {
        display: grid;
        grid-template-columns: 1fr 400px;
        gap: 30px;
    }

    /* Email Body Mockup */
    .email-frame {
        background: #f1f5f9;
        padding: 60px 20px;
        border-radius: 24px;
        border: 1px solid #e2e8f0;
        display: flex;
        justify-content: center;
        min-height: 700px;
    }
    [data-theme="dark"] .email-frame { background: #0f172a; border-color: #334155; }

    .email-content-card {
        width: 100%;
        max-width: 600px;
        background: #ffffff;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 20px 50px rgba(0,0,0,0.05);
        animation: k-fade-in 0.5s ease-out;
    }
    @@keyframes k-fade-in { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    .email-header {
        padding: 40px;
        background: var(--e-primary);
        text-align: center;
        position: relative;
    }
    .email-header .logo {
        font-family: var(--font-family-primary);
        font-weight: 800;
        font-size: 1.5rem;
        color: white;
        letter-spacing: -0.5px;
    }
    .email-header .icon-bg {
        position: absolute;
        bottom: -25px; left: 50%; transform: translateX(-50%);
        width: 50px; height: 50px;
        background: #fff;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        color: var(--e-primary);
        font-size: 1.25rem;
    }

    .email-body {
        padding: 60px 40px 40px;
        font-family: var(--font-family-primary);
        color: #334155;
        line-height: 1.6;
    }

    .email-body h1 {
        font-size: 1.75rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 24px;
        font-family: var(--font-family-primary);
        text-align: center;
    }

    .email-body p { margin-bottom: 20px; font-size: 1rem; }

    .email-btn {
        display: inline-block;
        background: var(--e-primary);
        color: white !important;
        padding: 16px 40px;
        border-radius: 100px;
        text-decoration: none !important;
        font-weight: 700;
        margin: 20px 0;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 0.85rem;
        transition: transform 0.2s;
    }
    .email-btn:hover { transform: scale(1.05); }

    .email-footer {
        padding: 40px;
        background: #f8fafc;
        border-top: 1px solid #f1f5f9;
        text-align: center;
        font-size: 0.85rem;
        color: #64748b;
    }

    /* Control Panel */
    .email-controls {
        background: var(--e-card);
        border-radius: 20px;
        padding: 30px;
        border: 1px solid #e2e8f0;
        height: min-content;
        position: sticky;
        top: 100px;
    }
    [data-theme="dark"] .email-controls { border-color: #334155; }

    .control-group { margin-bottom: 20px; }
    .control-group label {
        display: block; font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
        color: var(--e-primary); margin-bottom: 8px; letter-spacing: 1px;
    }
    .control-group input, .control-group textarea {
        width: 100%; padding: 12px; border: 1px solid #e2e8f0; border-radius: 10px;
        font-size: 0.9rem; background: #f8fafc;
    }
    [data-theme="dark"] .control-group input, [data-theme="dark"] .control-group textarea {
        background: #0f172a; border-color: #334155; color: #fff;
    }

    /* Variation Specific Styles */
    .invoice-info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        padding: 24px;
        background: #f8fafc;
        border-radius: 12px;
        margin: 24px 0;
    }
    .invoice-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; color: #64748b; }
    .invoice-value { font-weight: 800; color: #0f172a; font-size: 1.1rem; }

    .code-block {
        display: block;
        padding: 20px;
        background: #f1f5f9;
        border-radius: 12px;
        text-align: center;
        font-family: var(--font-family-primary);
        font-size: 2rem;
        font-weight: 800;
        letter-spacing: 10px;
        color: var(--e-primary);
        margin: 20px 0;
    }

    @@media (max-width: 1100px) {
        .email-preview-wrapper { grid-template-columns: 1fr; }
        .email-controls { position: static; }
        .variant-pills { width: 100%; justify-content: center; }
    }
</style>

<div id="page-wrapper">
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-1">Email Template Gallery</h4>
            <p class="text-muted small mb-0">Select a variation to customize and preview.</p>
        </div>
    </div>

    <!-- Variants Switcher -->
    <div class="variant-pills">
        <div class="pill-item active" onclick="switchVariant('verify')">Verification</div>
        <div class="pill-item" onclick="switchVariant('invoice')">Invoice Billing</div>
        <div class="pill-item" onclick="switchVariant('welcome')">Welcome</div>
        <div class="pill-item" onclick="switchVariant('alert')">Security Alert</div>
        <div class="pill-item" onclick="switchVariant('notif')">Notification</div>
    </div>

    <div class="email-preview-wrapper">
        <!-- Email Preview -->
        <div class="email-frame">
            <div class="email-content-card" id="emailDraft">
                <div class="email-header" id="emailHeader">
                    <div class="logo">KUDA<span>.</span></div>
                    <div class="icon-bg" id="headerIcon">
                        <i class="fas fa-user-check"></i>
                    </div>
                </div>
                <div class="email-body">
                    <h1 id="view-title">Verify Your Protocol</h1>
                    <div id="dynamic-content-wrap">
                        <!-- Dynamic content injected here -->
                        <p id="view-desc">Your access token has been generated. Use the code below to finalize your authentication process within the next 10 minutes.</p>
                        <div class="code-block" id="view-code">829 415</div>
                    </div>
                    <div class="text-center" id="btn-container">
                        <a href="#" class="email-btn" id="view-btn">FINALIZE ACCESS</a>
                    </div>
                </div>
                <div class="email-footer">
                    <p>&copy; 2026 Kuda Innovation Ltd. Jakarta, Indonesia.</p>
                    <p>Designed for professionals. Engineered for impact.</p>
                    <div class="social-links d-flex justify-content-center gap-3 mt-3">
                        <a href="#" class="text-muted"><i class="fab fa-twitter"></i></a>
                        <a href="#" class="text-muted"><i class="fab fa-github"></i></a>
                        <a href="#" class="text-muted"><i class="fab fa-linkedin"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Controls -->
        <div class="email-controls">
            <h6 class="fw-bold mb-4 d-flex align-items-center">
                <i class="fas fa-sliders h-5 text-primary me-2"></i> LIVE CUSTOMIZER
            </h6>
            
            <div class="control-group">
                <label>Headline</label>
                <input type="text" id="input-title" value="Verify Your Protocol" oninput="liveUpdate()">
            </div>

            <div class="control-group">
                <label>Main Body Text</label>
                <textarea rows="6" id="input-desc" oninput="liveUpdate()">Your access token has been generated. Use the code below to finalize your authentication process within the next 10 minutes.</textarea>
            </div>

            <div class="control-group" id="btn-label-group">
                <label>Button Label</label>
                <input type="text" id="input-btn" value="FINALIZE ACCESS" oninput="liveUpdate()">
            </div>

            <div class="control-group">
                <label>Theme Accent</label>
                <div class="d-flex gap-2">
                    <div class="color-dot active" style="width:32px; height:32px; background:#3b9d82; border-radius:50%; cursor:pointer; border: 2px solid #fff; box-shadow: 0 0 0 2px #3b9d82;" onclick="updateColor('#3b9d82', this)"></div>
                    <div class="color-dot" style="width:32px; height:32px; background:#6366f1; border-radius:50%; cursor:pointer;" onclick="updateColor('#6366f1', this)"></div>
                    <div class="color-dot" style="width:32px; height:32px; background:#f43f5e; border-radius:50%; cursor:pointer;" onclick="updateColor('#f43f5e', this)"></div>
                    <div class="color-dot" style="width:32px; height:32px; background:#0f172a; border-radius:50%; cursor:pointer;" onclick="updateColor('#0f172a', this)"></div>
                </div>
            </div>

            <button class="btn btn-primary w-100 py-3 rounded-12 fw-bold mt-3" onclick="copyHTML()">
                <i class="fas fa-copy me-2"></i> COPY HTML CODE
            </button>
        </div>
    </div>
</div>

<script>
    const variants = {
        verify: {
            title: "Verify Your Protocol",
            desc: "Your access token has been generated. Use the code below to finalize your authentication process within the next 10 minutes.",
            btn: "FINALIZE ACCESS",
            icon: "fas fa-user-check",
            html: (desc) => `<p id="view-desc">${desc}</p><div class="code-block" id="view-code">829 415</div>`
        },
        invoice: {
            title: "Invoice #INV-2026-042",
            desc: "A new billing statement has been generated for your recent subscription activity. You can review the details and proceed with payment below.",
            btn: "PROCEED TO PAYMENT",
            icon: "fas fa-file-invoice-dollar",
            html: (desc) => `<p id="view-desc">${desc}</p>
                <div class="invoice-info-grid">
                    <div>
                        <div class="invoice-label">Project Name</div>
                        <div class="invoice-value">Nexus Cloud</div>
                    </div>
                    <div>
                        <div class="invoice-label">Due Date</div>
                        <div class="invoice-value">Mar 25, 2026</div>
                    </div>
                    <div style="grid-column: span 2; border-top: 1px solid rgba(0,0,0,0.05); padding-top: 15px;">
                        <div class="invoice-label">Total Amount Due</div>
                        <div class="invoice-value" style="color:var(--e-primary); font-size: 1.5rem;">$12,450.00</div>
                    </div>
                </div>`
        },
        welcome: {
            title: "Welcome to the Grid",
            desc: "We are thrilled to have you join our elite circle of innovators. Your workspace is initialized and your team is ready to scale the extraordinary.",
            btn: "GET STARTED NOW",
            icon: "fas fa-rocket",
            html: (desc) => `<p id="view-desc">${desc}</p>
                <div style="text-align:center; padding: 20px 0;">
                    <img src="https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&fit=crop&w=400&q=80" style="width: 100%; border-radius: 12px;" />
                </div>`
        },
        alert: {
            title: "Security Alert: Node-X",
            desc: "A new login attempt was detected from an unrecognized node. If this was you, please confirm. If not, secure your account immediately.",
            btn: "SECURE MY ACCOUNT",
            icon: "fas fa-shield-alt",
            html: (desc) => `<p id="view-desc">${desc}</p>
                <div style="background: rgba(244, 63, 94, 0.05); padding: 20px; border-radius: 12px; border-left: 4px solid #f43f5e;">
                    <div class="small fw-bold text-danger mb-1">DETECTION LOG</div>
                    <div class="small opacity-70">Location: Jakarta, ID</div>
                    <div class="small opacity-70">IP Address: 110.12.45.82</div>
                    <div class="small opacity-70">Device: MacOS / Safari 17.2</div>
                </div>`
        },
        notif: {
            title: "System Maintenance",
            desc: "We will be performing a routine protocol update on March 12, 2026. Some services might experience momentary latency between 02:00 - 04:00 UTC.",
            btn: "LEARN MORE",
            icon: "fas fa-info-circle",
            html: (desc) => `<p id="view-desc">${desc}</p>`
        }
    };

    let currentVariant = 'verify';

    function switchVariant(v) {
        currentVariant = v;
        const data = variants[v];
        
        // Update Pills
        document.querySelectorAll('.pill-item').forEach(p => p.classList.remove('active'));
        event.target.classList.add('active');

        // Update Inputs
        document.getElementById('input-title').value = data.title;
        document.getElementById('input-desc').value = data.desc;
        document.getElementById('input-btn').value = data.btn;

        // Update Preview
        renderPreview();
    }

    function liveUpdate() {
        const title = document.getElementById('input-title').value;
        const desc = document.getElementById('input-desc').value;
        const btn = document.getElementById('input-btn').value;

        document.getElementById('view-title').innerText = title;
        document.getElementById('view-btn').innerText = btn;
        
        // Re-render HTML part to include updated description inside variant logic
        const htmlContent = variants[currentVariant].html(desc);
        document.getElementById('dynamic-content-wrap').innerHTML = htmlContent;
    }

    function renderPreview() {
        const data = variants[currentVariant];
        document.getElementById('view-title').innerText = data.title;
        document.getElementById('headerIcon').innerHTML = `<i class="${data.icon}"></i>`;
        
        const htmlContent = data.html(data.desc);
        document.getElementById('dynamic-content-wrap').innerHTML = htmlContent;
        document.getElementById('view-btn').innerText = data.btn;
    }

    function updateColor(color, el) {
        document.documentElement.style.setProperty('--e-primary', color);
        document.getElementById('emailHeader').style.backgroundColor = color;
        document.getElementById('view-btn').style.backgroundColor = color;
        
        // Update Dots UI
        document.querySelectorAll('.color-dot').forEach(d => {
            d.classList.remove('active');
            d.style.border = 'none';
            d.style.boxShadow = 'none';
        });
        el.classList.add('active');
        el.style.border = '2px solid #fff';
        el.style.boxShadow = `0 0 0 2px ${color}`;
    }

    function copyHTML() {
        const html = document.documentElement.outerHTML;
        navigator.clipboard.writeText(html).then(() => {
            const btn = document.getElementById('btnCopyHTML');
            if(btn) {
                const original = btn.innerHTML;
                btn.innerHTML = '<i class="fas fa-check me-2"></i> COPIED!';
                btn.style.backgroundColor = '#10b981';
                btn.style.borderColor = '#10b981';
                btn.style.color = '#fff';
                setTimeout(() => {
                    btn.innerHTML = original;
                    btn.style.backgroundColor = '#1e293b';
                    btn.style.borderColor = 'rgba(255,255,255,0.1)';
                }, 2000);
            }
        });
    }
</script>

</div>
<!-- Unified Copy HTML Button -->
<button class="btn btn-sm btn-outline-primary copy-btn shadow" style="position: fixed; bottom: 30px; right: 30px; z-index: 9999; background: white; border-radius: 6px;" data-target="page-wrapper"><i class="fa-regular fa-copy"></i> Copy HTML</button>
