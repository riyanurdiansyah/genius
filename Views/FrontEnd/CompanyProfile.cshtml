                        </div>
                    </div>
                    <div class="col-6">
                        <div class="hero-card">
                            <div class="hero-card-num">98%</div>
                            <div class="hero-card-label">Client Satisfaction</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="hero-card">
                            <div class="hero-card-num">12+</div>
