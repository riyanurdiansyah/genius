@{
    ViewData["Title"] = "Kuda — Company Profile";
    Layout = "_FrontLayout";
}

@section Styles {
<style>
/* ── Tokens ─────────────────────────── */
:root {
    --green: #3b9d82;
    --green-dark: #2d7a64;
    --navy: #0f172a;
    --slate: #1e293b;
    --muted: #64748b;
    --light-bg: #f8fafc;
    --radius: 20px;
}

/* ── Global ─────────────────────────── */
section { scroll-margin-top: 80px; }
.lp-tag {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(59,157,130,.1); color: var(--green);
    border: 1px solid rgba(59,157,130,.25); border-radius: 50px;
    padding: 6px 18px; font-size: .8rem; font-weight: 700;
    letter-spacing: .8px; text-transform: uppercase; margin-bottom: 20px;
}
.lp-title { font-size: clamp(2rem,4vw,2.8rem); font-weight: 800; line-height: 1.2; color: var(--navy); }
.lp-sub { color: var(--muted); font-size: 1.1rem; line-height: 1.8; max-width: 560px; }
.sep { width: 48px; height: 4px; background: var(--green); border-radius: 4px; margin: 20px 0; }

/* ── Hero ───────────────────────────── */
.hero {
    min-height: 100vh; display: flex; align-items: center;
    background: var(--navy);
    position: relative; overflow: hidden; padding: 120px 0 80px;
}
.hero-grid {
    position: absolute; inset: 0; z-index: 0;
    background-image:
        linear-gradient(rgba(59,157,130,.07) 1px, transparent 1px),
        linear-gradient(90deg, rgba(59,157,130,.07) 1px, transparent 1px);
    background-size: 60px 60px;
}
.hero-glow {
    position: absolute; width: 700px; height: 700px; border-radius: 50%;
    background: radial-gradient(circle, rgba(59,157,130,.18) 0%, transparent 70%);
    top: -200px; right: -200px; pointer-events: none;
}
.hero-glow2 {
    position: absolute; width: 400px; height: 400px; border-radius: 50%;
    background: radial-gradient(circle, rgba(59,157,130,.1) 0%, transparent 70%);
    bottom: -100px; left: -100px; pointer-events: none;
}
.hero-content { position: relative; z-index: 1; }
.hero-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 900;
    line-height: 1.1; color: #fff; letter-spacing: -2px; margin-bottom: 24px;
}
.hero-title span { color: var(--green); }
.hero-sub { color: #94a3b8; font-size: 1.2rem; line-height: 1.8; margin-bottom: 40px; }
.btn-green {
    background: var(--green); color: #fff; border: none;
    padding: 14px 36px; border-radius: 50px; font-weight: 700;
    font-size: 1rem; transition: all .25s; box-shadow: 0 8px 24px rgba(59,157,130,.4);
}
.btn-green:hover { background: var(--green-dark); color: #fff; transform: translateY(-2px); box-shadow: 0 12px 30px rgba(59,157,130,.5); }
.btn-ghost {
    background: rgba(255,255,255,.06); color: #fff; border: 1px solid rgba(255,255,255,.15);
    padding: 14px 36px; border-radius: 50px; font-weight: 600;
    font-size: 1rem; transition: all .25s;
}
.btn-ghost:hover { background: rgba(255,255,255,.12); color: #fff; }
.hero-badge {
    display: inline-flex; gap: 6px; align-items: center;
    background: rgba(59,157,130,.15); border: 1px solid rgba(59,157,130,.3);
    color: #5ec9a8; border-radius: 50px; padding: 8px 20px;
    font-size: .82rem; font-weight: 600; margin-bottom: 28px;
}
.hero-badge span { width: 8px; height: 8px; background: #3b9d82; border-radius: 50%; animation: pulse 2s infinite; }
@@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.6;transform:scale(1.4)} }
.hero-card {
    background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08);
    border-radius: var(--radius); padding: 28px; backdrop-filter: blur(10px);
    transition: border-color .3s;
}
.hero-card:hover { border-color: rgba(59,157,130,.4); }
.hero-card-num { font-size: 2.2rem; font-weight: 900; color: var(--green); }
.hero-card-label { color: #94a3b8; font-size: .85rem; margin-top: 4px; }

/* ── Logos / Clients ─────────────────── */
.clients-bar { background: var(--slate); padding: 40px 0; border-top: 1px solid rgba(255,255,255,.04); border-bottom: 1px solid rgba(255,255,255,.04); }
.client-logo { opacity: .35; font-weight: 800; font-size: 1.1rem; color: #fff; letter-spacing: -1px; transition: opacity .2s; }
.client-logo:hover { opacity: .7; }

/* ── About ───────────────────────────── */
.about-section { padding: 120px 0; }
.feat-item { display: flex; gap: 18px; margin-bottom: 32px; }
.feat-icon {
    flex-shrink: 0; width: 52px; height: 52px; border-radius: 14px;
    background: rgba(59,157,130,.1); color: var(--green);
    display: flex; align-items: center; justify-content: center; font-size: 1.3rem;
}
.about-img-wrap { position: relative; }
.about-img-wrap img { border-radius: var(--radius); width: 100%; object-fit: cover; height: 500px; }
.about-bubble {
    position: absolute; bottom: -24px; left: -24px;
    background: var(--green); color: #fff; border-radius: 18px;
    padding: 20px 28px; box-shadow: 0 16px 40px rgba(59,157,130,.4);
}
.about-bubble .big { font-size: 2rem; font-weight: 900; line-height: 1; }
.about-bubble .sm { font-size: .8rem; opacity: .85; }

/* ── Stats ───────────────────────────── */
.stats-section { background: linear-gradient(135deg, var(--navy) 0%, #162032 100%); padding: 80px 0; }
.stat-card { text-align: center; padding: 40px 20px; border: 1px solid rgba(255,255,255,.06); border-radius: var(--radius); transition: border-color .3s; }
.stat-card:hover { border-color: rgba(59,157,130,.4); }
.stat-num { font-size: 3rem; font-weight: 900; color: var(--green); }
.stat-label { color: #94a3b8; font-size: .9rem; margin-top: 4px; text-transform: uppercase; letter-spacing: .6px; }

/* ── Services ─────────────────────────── */
.services-section { padding: 120px 0; background: var(--light-bg); }
.svc-card {
    background: #fff; border-radius: var(--radius); padding: 40px;
    border: 1px solid #e8f0ee; transition: all .3s;
    height: 100%;
}
.svc-card:hover { transform: translateY(-8px); box-shadow: 0 24px 48px rgba(0,0,0,.07); border-color: rgba(59,157,130,.3); }
.svc-icon { width: 64px; height: 64px; border-radius: 18px; display: flex; align-items: center; justify-content: center; font-size: 1.6rem; margin-bottom: 24px; }

/* ── Process ──────────────────────────── */
.process-section { padding: 120px 0; }
.process-step { display: flex; gap: 24px; margin-bottom: 40px; }
.step-num {
    flex-shrink: 0; width: 52px; height: 52px; border-radius: 14px;
    background: var(--navy); color: var(--green); font-weight: 900;
    font-size: 1.1rem; display: flex; align-items: center; justify-content: center;
    border: 2px solid rgba(59,157,130,.3);
}
.process-img { border-radius: var(--radius); width: 100%; object-fit: cover; height: 460px; }
.process-img-wrap { position: relative; }
.process-float {
    position: absolute; top: -20px; right: -20px;
    background: #fff; border: 1px solid #e2e8f0; border-radius: 16px;
    padding: 18px 24px; box-shadow: 0 12px 32px rgba(0,0,0,.08);
}
.process-float .pf-num { font-size: 1.8rem; font-weight: 900; color: var(--green); }
.process-float .pf-label { font-size: .78rem; color: var(--muted); }

/* ── Testimonials ────────────────────── */
.testi-section { padding: 120px 0; background: var(--navy); }
.testi-card {
    background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.07);
    border-radius: var(--radius); padding: 36px; transition: border-color .3s;
}
.testi-card:hover { border-color: rgba(59,157,130,.35); }
.testi-quote { color: var(--green); font-size: 2rem; margin-bottom: 16px; line-height: 1; }
.testi-text { color: #cbd5e1; line-height: 1.8; font-size: 1rem; margin-bottom: 24px; }
.testi-author img { width: 46px; height: 46px; border-radius: 50%; object-fit: cover; border: 2px solid rgba(59,157,130,.4); }
.testi-name { color: #fff; font-weight: 700; font-size: .95rem; }
.testi-role { color: #64748b; font-size: .82rem; }
.stars { color: var(--green); font-size: .85rem; margin-bottom: 14px; }

/* ── Team ─────────────────────────────── */
.team-section { padding: 120px 0; }
.team-card { border-radius: var(--radius); overflow: hidden; background: #fff; border: 1px solid #e8f0ee; transition: all .3s; }
.team-card:hover { transform: translateY(-6px); box-shadow: 0 20px 40px rgba(0,0,0,.07); }
.team-card img { width: 100%; height: 280px; object-fit: cover; object-position: top; }
.team-info { padding: 24px; }
.team-name { font-weight: 800; font-size: 1.05rem; color: var(--navy); }
.team-role { color: var(--green); font-size: .85rem; font-weight: 600; }
.team-social a { color: var(--muted); font-size: .95rem; margin-right: 12px; transition: color .2s; }
.team-social a:hover { color: var(--green); }

/* ── Pricing ──────────────────────────── */
.pricing-section { padding: 120px 0; background: var(--light-bg); }
.pricing-card {
    background: #fff; border-radius: var(--radius); padding: 44px 36px;
    border: 1px solid #e8f0ee; transition: all .3s; height: 100%;
}
.pricing-card.featured {
    background: var(--navy); border-color: rgba(59,157,130,.4);
    box-shadow: 0 24px 60px rgba(15,23,42,.25);
}
.pricing-card:hover { transform: translateY(-6px); }
.pricing-price { font-size: 3rem; font-weight: 900; color: var(--navy); }
.pricing-card.featured .pricing-price { color: var(--green); }
.pricing-card.featured .pricing-title,
.pricing-card.featured .pricing-period,
.pricing-card.featured ul li { color: #e2e8f0; }
.pricing-check { color: var(--green); margin-right: 10px; }
.pricing-card ul li { padding: 8px 0; border-bottom: 1px solid rgba(0,0,0,.05); font-size: .93rem; }
.pricing-card.featured ul li { border-bottom-color: rgba(255,255,255,.06); }

/* ── FAQ ──────────────────────────────── */
.faq-section { padding: 120px 0; }
.faq-item {
    border: 1px solid #e8f0ee; border-radius: 14px; margin-bottom: 12px;
    overflow: hidden; transition: border-color .2s;
}
.faq-item:has(.faq-body.show) { border-color: rgba(59,157,130,.35); }
.faq-q {
    padding: 20px 24px; font-weight: 700; color: var(--navy); cursor: pointer;
    display: flex; justify-content: space-between; align-items: center; user-select: none;
}
.faq-q i { color: var(--green); transition: transform .3s; flex-shrink: 0; }
.faq-q.open i { transform: rotate(45deg); }
.faq-body { display: none; padding: 0 24px 20px; color: var(--muted); line-height: 1.8; }
.faq-body.show { display: block; }

/* ── Contact ──────────────────────────── */
.contact-section { padding: 120px 0; background: var(--navy); }
.contact-form-wrap {
    background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.07);
    border-radius: var(--radius); padding: 48px;
}
.contact-form-wrap input,
.contact-form-wrap textarea,
.contact-form-wrap select {
    background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1);
    color: #e2e8f0; border-radius: 10px; padding: 14px 18px;
}
.contact-form-wrap input::placeholder,
.contact-form-wrap textarea::placeholder { color: #64748b; }
.contact-form-wrap input:focus,
.contact-form-wrap textarea:focus { border-color: var(--green); background: rgba(255,255,255,.08); color: #e2e8f0; box-shadow: none; outline: none; }
.contact-info-item { display: flex; gap: 18px; align-items: flex-start; margin-bottom: 32px; }
.ci-icon {
    flex-shrink: 0; width: 52px; height: 52px; border-radius: 14px;
    background: rgba(59,157,130,.15); color: var(--green);
    display: flex; align-items: center; justify-content: center; font-size: 1.2rem;
}
.ci-label { color: #94a3b8; font-size: .8rem; text-transform: uppercase; letter-spacing: .6px; margin-bottom: 4px; }
.ci-value { color: #fff; font-weight: 600; }

/* ── Footer ───────────────────────────── */
.lp-footer { background: #060d18; padding: 80px 0 40px; }
.footer-brand { font-size: 1.6rem; font-weight: 900; color: #fff; letter-spacing: -1px; }
.footer-brand span { color: var(--green); }
.footer-desc { color: #64748b; line-height: 1.8; max-width: 260px; margin: 16px 0 28px; }
.footer-col-title { color: #fff; font-weight: 700; font-size: .85rem; text-transform: uppercase; letter-spacing: .8px; margin-bottom: 20px; }
.footer-links { list-style: none; padding: 0; }
.footer-links li { margin-bottom: 10px; }
.footer-links a { color: #64748b; text-decoration: none; font-size: .9rem; transition: color .2s; }
.footer-links a:hover { color: var(--green); }
.social-btn {
    width: 40px; height: 40px; border-radius: 10px;
    background: rgba(255,255,255,.05); color: #64748b;
    display: inline-flex; align-items: center; justify-content: center;
    transition: all .2s; text-decoration: none; font-size: 1rem;
}
.social-btn:hover { background: var(--green); color: #fff; }
.footer-bottom { border-top: 1px solid rgba(255,255,255,.05); padding-top: 32px; margin-top: 60px; color: #475569; font-size: .85rem; }

/* ── Scroll animations ───────────────── */
.reveal { opacity: 0; transform: translateY(30px); transition: opacity .6s ease, transform .6s ease; }
.reveal.visible { opacity: 1; transform: none; }
</style>
}

<!-- ══════════════ HERO ══════════════ -->
<section class="hero" id="home">
    <div class="hero-grid"></div>
    <div class="hero-glow"></div>
    <div class="hero-glow2"></div>
    <div class="container hero-content">
        <div class="row align-items-center">
            <div class="col-lg-7 mb-5 mb-lg-0">
                <div class="hero-badge">
                    <span></span> Now accepting new clients for Q2 2026
                </div>
