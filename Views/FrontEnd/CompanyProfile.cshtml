                <div class="feat-item">
                    <div class="feat-icon"><i class="fas fa-rocket"></i></div>
                    <div>
                        <h5 class="fw-bold mb-1" style="color:var(--navy)">Agile & Fast</h5>
                        <p class="text-muted mb-0 small">We ship production-ready features in days, not months, thanks to our battle-tested agile workflow.</p>
                    </div>
                </div>
                <div class="feat-item">
                    <div class="feat-icon"><i class="fas fa-shield-halved"></i></div>
                    <div>
                        <h5 class="fw-bold mb-1" style="color:var(--navy)">Security First</h5>
                        <p class="text-muted mb-0 small">End-to-end encryption, OWASP compliance, and regular penetration testing baked into every project.</p>
                    </div>
                </div>
                <div class="feat-item">
                    <div class="feat-icon"><i class="fas fa-chart-line"></i></div>
                    <div>
                        <h5 class="fw-bold mb-1" style="color:var(--navy)">Data-Driven</h5>
                        <p class="text-muted mb-0 small">Every design decision and feature is backed by user research, analytics, and real-world testing.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ══════════════ STATS ══════════════ -->
<section class="stats-section">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-3 col-6 reveal"><div class="stat-card"><div class="stat-num">150+</div><div class="stat-label">Projects Delivered</div></div></div>
