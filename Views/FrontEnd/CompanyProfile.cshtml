@{
    ViewData["Title"] = "Kuda. — Intelligence & Design";
    Layout = "_FrontLayout";
}

@section Styles {
<!-- Premium Typography -->

<style>
    /* ═══════════════════════════════════════════════
       THE NEXUS DESIGN SYSTEM — Ultra Modern
    ═══════════════════════════════════════════════ */
    
    :root {
        --n-bg: #030712;
        --n-primary: #3b9d82; /* Template Primary Green */
        --n-secondary: #5a9c88; /* Sidebar Green */
        --n-accent: #8fb69c; /* Lighter Green from theme */
        --n-glass: rgba(255, 255, 255, 0.02);
        --n-glass-border: rgba(255, 255, 255, 0.08);
        --n-font: var(--font-family-primary);
    }

    body {
        font-family: var(--n-font);
        background-color: var(--n-bg);
        color: #94a3b8;
        overflow-x: hidden;
        cursor: default;
    }

    /* ── Atmospheric Canvas ────────────────── */
    .n-canvas {
        position: fixed;
        top: 0; left: 0; width: 100%; height: 100%;
        z-index: -1;
        background: 
            radial-gradient(circle at 0% 0%, rgba(59, 157, 130, 0.08) 0%, transparent 40%),
            radial-gradient(circle at 100% 100%, rgba(90, 156, 136, 0.08) 0%, transparent 40%),
            linear-gradient(to bottom, #030712, #060d18);
    }
    
    .n-grid-bg {
        position: absolute;
        inset: 0;
        background-image: 
            linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
        background-size: 80px 80px;
        mask-image: radial-gradient(circle at 50% 50%, black, transparent 80%);
        pointer-events: none;
    }

    /* ── Kinetic Hero ──────────────────────── */
    .n-hero {
        min-height: 100vh;
        display: flex;
        align-items: center;
        padding: 180px 0 120px;
        position: relative;
    }
    
    .n-hero-label {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 6px 14px;
        background: rgba(99, 102, 241, 0.1);
        border: 1px solid rgba(99, 102, 241, 0.2);
        border-radius: 100px;
        color: var(--n-primary);
        font-weight: 700;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        margin-bottom: 2rem;
        backdrop-filter: blur(10px);
    }

    .n-hero-title {
        font-family: var(--font-family-primary);
        font-weight: 800;
        font-size: clamp(3.5rem, 10vw, 7.5rem);
        line-height: 0.9;
        letter-spacing: -5px;
        color: #fff;
        margin-bottom: 2.5rem;
        perspective: 1000px;
    }
    
    .n-hero-title span {
        display: block;
        background: linear-gradient(135deg, #fff 0%, #94a3b8 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: k-reveal-text 1.2s cubic-bezier(0.2, 0.8, 0.2, 1);
    }
    
    .n-hero-title .accent {
        background: linear-gradient(135deg, var(--n-primary) 0%, var(--n-secondary) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    @@keyframes k-reveal-text {
        from { transform: translateY(50px) rotateX(-20deg); opacity: 0; }
        to { transform: translateY(0) rotateX(0); opacity: 1; }
    }

    .n-btn-nexus {
        position: relative;
        padding: 18px 48px;
        font-family: var(--font-family-primary);
        font-weight: 700;
        font-size: 1rem;
        text-decoration: none;
        color: #fff;
        background: #fff;
        color: #030712;
        border-radius: 12px;
        overflow: hidden;
        transition: all 0.3s;
        box-shadow: 0 20px 40px rgba(255, 255, 255, 0.1);
        display: inline-flex; align-items: center; gap: 12px;
    }
    .n-btn-nexus:hover { transform: translateY(-5px); box-shadow: 0 30px 60px rgba(59, 157, 130, 0.3); background: var(--n-primary); color: #fff; }

    /* ── Bento Grid Evolution ──────────────── */
    .n-bento-container {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        grid-auto-rows: 220px;
        gap: 1.5rem;
        margin-bottom: 6rem;
    }
    
    .n-bento-card {
        background: var(--n-glass);
        border: 1px solid var(--n-glass-border);
        border-radius: 32px;
        padding: 2.5rem;
        position: relative;
        overflow: hidden;
        transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        backdrop-filter: blur(20px);
    }
    
    .n-bento-card:hover {
        background: rgba(255,255,255,0.05);
        border-color: rgba(99, 102, 241, 0.4);
        transform: translateY(-8px) scale(1.01);
        box-shadow: 0 40px 80px rgba(0,0,0,0.5);
    }

    .span-3 { grid-column: span 3; }
    .span-4 { grid-column: span 4; }
    .span-2 { grid-column: span 2; }
    .row-2 { grid-row: span 2; }

    .n-card-tag { font-size: 0.65rem; font-weight: 800; color: var(--n-primary); letter-spacing: 1.5px; margin-bottom: 12px; text-transform: uppercase; display: block; }
    .n-card-title { font-family: var(--font-family-primary); font-weight: 700; font-size: 1.75rem; color: #fff; margin-bottom: 1rem; line-height: 1.2; }
    .n-card-desc { font-size: 0.95rem; line-height: 1.6; opacity: 0.6; }

    /* ── Floating Visual Element ───────────── */
    .n-visual-element {
        position: absolute;
        bottom: -20px; right: -20px;
        width: 150px; height: 150px;
        background: var(--n-primary);
        filter: blur(80px);
        opacity: 0.2;
        transition: all 0.5s;
    }
    .n-bento-card:hover .n-visual-element { opacity: 0.5; width: 200px; height: 200px; }

    /* ── Interaction Reveal ────────────────── */
    .n-reveal { opacity: 0; transform: translateY(40px); transition: all 1s cubic-bezier(0.2, 0.8, 0.2, 1); }
    .n-reveal.n-active { opacity: 1; transform: translateY(0); }

    /* ── Floating Dashboard Mockup ───────────── */
    .n-mockup-frame {
        background: rgba(0,0,0,0.4);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 24px;
        padding: 10px;
        box-shadow: 0 100px 200px -50px rgba(0,0,0,0.8);
        transform: perspective(1200px) rotateX(10deg) rotateY(-15deg);
        transition: transform 0.8s;
    }
    .n-mockup-frame:hover { transform: perspective(1200px) rotateX(0deg) rotateY(0deg); }
    .n-mockup-screen {
        background: #0f172a;
        border-radius: 16px;
        width: 100%; height: 400px;
        overflow: hidden;
        position: relative;
    }

    /* ── Statistics / Data ─────────────────── */
    .n-data-cluster {
        padding: 100px 0;
        background: linear-gradient(to bottom, transparent, rgba(99,102,241,0.02), transparent);
    }
    .n-stat h3 { font-family: var(--font-family-primary); font-weight: 800; font-size: 4rem; color: #fff; line-height: 1; margin-bottom: 10px; }
    .n-stat p { font-size: 0.8rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--n-primary); }

    /* ── Custom Cursor Glow ────────────────── */
    .n-cursor-glow {
        position: fixed;
        width: 600px; height: 600px;
        background: radial-gradient(circle, rgba(59, 157, 130, 0.05) 0%, transparent 70%);
        border-radius: 50%;
        pointer-events: none;
        z-index: -1;
        transform: translate(-50%, -50%);
        transition: width 0.3s, height 0.3s;
    }

    @@media (max-width: 992px) {
        .n-bento-container { grid-template-columns: 1fr; grid-auto-rows: auto; }
        .span-3, .span-4, .span-2, .row-2 { grid-column: span 1; grid-row: span 1; }
        .n-hero-title { font-size: 3.5rem; letter-spacing: -2px; }
    }
</style>
}

