            <span class="client-logo">FIGMA</span>
            <span class="client-logo">VERCEL</span>
        </div>
    </div>
</div>

<!-- ══════════════ ABOUT ══════════════ -->
<section class="about-section" id="about">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-5 reveal">
                <div class="about-img-wrap">
                    <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=800&q=80" alt="Team">
                    <div class="about-bubble">
                        <div class="big">🏆</div>
                        <div class="big">12 Awards</div>
