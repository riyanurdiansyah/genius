</section>

<!-- ══════════════ CLIENTS BAR ══════════════ -->
<div class="clients-bar">
    <div class="container">
        <div class="d-flex flex-wrap justify-content-center align-items-center gap-5">
            <span class="client-logo">NVIDIA</span>
            <span class="client-logo">STRIPE</span>
            <span class="client-logo">SHOPIFY</span>
            <span class="client-logo">ATLASSIAN</span>
