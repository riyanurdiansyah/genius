@{
    ViewData["Title"] = "Collapsed Menu";
}

@section Styles {
    <style>
        .layout-demo { padding: 3rem 2rem; background: #fff; border-radius: var(--radius-lg); border: 1px dashed #cbd5e1; text-align: center; }
        .wf-container { max-width: 700px; margin: 2rem auto; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); background: #f8fafc; overflow: hidden; display: flex; height: 350px; border: 1px solid #e2e8f0; }
        .wf-nav { width: 70px; background: var(--sidebar-bg); display: flex; flex-direction: column; align-items: center; padding-top: 20px; gap: 15px; border-right: 1px solid rgba(255,255,255,0.05); }
        .wf-menu-item { width: 35px; height: 35px; border-radius: 8px; background: rgba(255,255,255,0.1); }
        .wf-menu-item.active { background: var(--primary-color); }
        .wf-main { flex: 1; display: flex; flex-direction: column; }
        .wf-header { height: 60px; background: #fff; border-bottom: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center; padding: 0 25px; }
        .wf-header-box { height: 16px; background: #e2e8f0; border-radius: 4px; }
        .wf-content { flex: 1; padding: 25px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; grid-template-rows: auto 1fr; }
        .wf-card { background: #fff; border-radius: 8px; border: 1px solid #e2e8f0; }
    </style>
}

<div class="row">
    <div class="col-12">
        <div class="layout-demo">
            <h2 class="fw-bold text-dark">Collapsed Menu Layout</h2>
            <p class="text-muted w-75 mx-auto mb-4">This layout automatically minimizes the sidebar, maximizing the screen's horizontal real estate for data-heavy applications while keeping navigation quickly accessible via icons.</p>
            
            <div class="wf-container">
                <div class="wf-nav">
                    <div class="wf-menu-item" style="border-radius: 50%;"></div>
                    <div class="wf-menu-item active"></div>
                    <div class="wf-menu-item"></div>
                    <div class="wf-menu-item"></div>
                    <div class="wf-menu-item mt-auto mb-3"></div>
                </div>
                <div class="wf-main">
                    <div class="wf-header">
                        <div class="wf-header-box" style="width: 30px;"></div>
                        <div class="wf-header-box" style="width: 150px;"></div>
                    </div>
                    <div class="wf-content">
                        <div class="wf-card" style="grid-column: span 3; height: 100px;"></div>
                        <div class="wf-card"></div>
                        <div class="wf-card"></div>
                        <div class="wf-card"></div>
                    </div>
                </div>
            </div>

            <div class="alert alert-primary bg-primary bg-opacity-10 text-primary border-0 text-start mt-4 d-inline-block text-center mx-auto" style="max-width: 700px;">
                <i class="fa-solid fa-code me-2"></i> <strong>Live Demo:</strong> Notice how the sidebar on the left has been automatically collapsed upon entering this page using JavaScript.
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var wrapper = document.querySelector('.sidebar-wrapper');
            if (wrapper && !wrapper.classList.contains('collapsed')) {
                wrapper.classList.add('collapsed');
            }
        });
    </script>
}
