@{
    ViewData["Title"] = "Content Nav + Sidebar";
}

@section Styles {
    <style>
        .layout-demo { padding: 3rem 2rem; background: #fff; border-radius: var(--radius-lg); border: 1px dashed #cbd5e1; text-align: center; }
        .wf-container { max-width: 700px; margin: 2rem auto; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); background: #f8fafc; overflow: hidden; display: flex; height: 350px; border: 1px solid #e2e8f0; }
        .wf-nav { width: 180px; background: var(--sidebar-bg); display: flex; flex-direction: column; padding: 20px 15px; gap: 12px; border-right: 1px solid rgba(255,255,255,0.05); }
        .wf-menu-item { height: 25px; border-radius: 6px; background: rgba(255,255,255,0.05); }
        .wf-menu-item.active { background: var(--primary-color); }
        .wf-menu-item.circle { width: 40px; height: 40px; border-radius: 50%; margin-bottom: 10px; align-self: center; }
        .wf-main { flex: 1; display: flex; flex-direction: column; }
        .wf-header { height: 60px; background: #fff; border-bottom: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center; padding: 0 25px; }
        .wf-header-box { height: 16px; background: #e2e8f0; border-radius: 4px; }
        .wf-content { flex: 1; padding: 25px; display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
        .wf-card { background: #fff; border-radius: 8px; border: 1px solid #e2e8f0; }
    </style>
}

<div class="row">
    <div class="col-12">
        <div class="layout-demo">
            <h2 class="fw-bold text-dark">Content Nav + Sidebar (Standard)</h2>
            <p class="text-muted w-75 mx-auto mb-4">The default layout of Kuda App. Features a persistent collapsible sidebar on the left and a contextual top navigation bar for user profile, notifications, and search.</p>
            
            <div class="wf-container">
                <div class="wf-nav">
                    <div class="wf-menu-item circle mt-2"></div>
                    <div class="wf-menu-item active mt-4"></div>
                    <div class="wf-menu-item" style="width: 80%;"></div>
                    <div class="wf-menu-item" style="width: 90%;"></div>
                    <div class="wf-menu-item mt-auto" style="width: 60%;"></div>
                </div>
                <div class="wf-main">
                    <div class="wf-header">
                        <div class="wf-header-box" style="width: 30px;"></div>
                        <div class="wf-header-box" style="width: 150px;"></div>
                    </div>
                    <div class="wf-content">
                        <div class="wf-card" style="grid-column: span 2; height: 80px;"></div>
                        <div class="wf-card"></div>
                        <div class="wf-card"></div>
                    </div>
                </div>
            </div>

            <div class="alert alert-success bg-success bg-opacity-10 text-success border-0 text-start mt-4 d-inline-block text-center mx-auto" style="max-width: 700px;">
                <i class="fa-solid fa-check-circle me-2"></i> <strong>Current Layout:</strong> You are currently viewing the admin template using this exact layout engine.
            </div>
        </div>
    </div>
</div>
