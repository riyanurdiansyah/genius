@{
    ViewData["Title"] = "Blank";
}

@section Styles {
    <style>
        /* Force Layout Change for this demo */
        .sidebar-wrapper, .top-header { display: none !important; }
        .main-content { margin-left: 0 !important; padding-top: 0 !important; min-height: 100vh; display: flex; align-items: center; justify-content: center; background: #f8fafc; }
        
        /* Demo Styles */
        .layout-demo { padding: 3rem 2rem; background: #fff; border-radius: var(--radius-lg); border: 1px dashed #cbd5e1; text-align: center; box-shadow: 0 10px 40px rgba(0,0,0,0.05); max-width: 700px; width: 100%; border: none; }
        .wf-container { width: 100%; margin: 2rem auto; border-radius: 12px; background: #f1f5f9; overflow: hidden; display: flex; align-items: center; justify-content: center; height: 350px; border: 1px solid #e2e8f0; }
        .wf-card { background: #fff; border-radius: 8px; border: 1px solid #e2e8f0; width: 300px; height: 200px; box-shadow: 0 5px 15px rgba(0,0,0,0.05); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 15px;}
        .wf-box { background: #e2e8f0; border-radius: 4px; height: 16px; width: 80%; }
        .wf-btn { background: var(--primary-color); border-radius: 4px; height: 35px; width: 80%; margin-top: 10px;}
    </style>
}

<div class="layout-demo">
    <i class="fa-regular fa-square fa-4x text-muted mb-4 opacity-50"></i>
    <h2 class="fw-bold text-dark">Blank Canvas Layout</h2>
    <p class="text-muted w-75 mx-auto mb-4">Stripping away both the sidebar and the top navbar gives you a completely blank canvas. Perfect for Authentication pages (Login/Register), 404 Errors, and Under Construction screens.</p>
    
    <div class="wf-container">
        <div class="wf-card">
            <div class="wf-box" style="width: 40px; height: 40px; border-radius: 50%; margin-bottom: 10px;"></div>
            <div class="wf-box" style="width: 60%;"></div>
            <div class="wf-box"></div>
            <div class="wf-btn"></div>
        </div>
    </div>

    <div class="d-flex justify-content-center gap-3 mt-4">
        <a href="/Layouts/ContentNavSidebar" class="btn btn-outline-primary"><i class="fa-solid fa-arrow-left me-2"></i> Back to Normal Layout</a>
    </div>
</div>
