@{
    ViewData["Title"] = "Fluid";
}

@section Styles {
    <style>
        .layout-demo { padding: 3rem 2rem; background: #fff; border-radius: var(--radius-lg); border: 1px dashed #cbd5e1; text-align: center; }
        .wf-container { width: 100%; max-width: 900px; margin: 2rem auto; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); background: #f8fafc; overflow: hidden; display: flex; height: 350px; border: 1px solid #e2e8f0; }
        .wf-nav { width: 180px; background: var(--sidebar-bg); display: flex; flex-direction: column; padding: 20px 15px; gap: 12px; border-right: 1px solid rgba(255,255,255,0.05); }
        .wf-menu-item { height: 25px; border-radius: 6px; background: rgba(255,255,255,0.05); }
        .wf-menu-item.active { background: var(--primary-color); }
        .wf-main { flex: 1; display: flex; flex-direction: column; width: 100%;}
        .wf-header { height: 60px; background: #fff; border-bottom: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center; padding: 0 25px; width: 100%;}
        .wf-header-box { height: 16px; background: #e2e8f0; border-radius: 4px; }
        .wf-content { flex: 1; padding: 25px; display: grid; gap: 20px; grid-template-columns: repeat(3, 1fr); width: 100%;}
        .wf-card { background: #fff; border-radius: 8px; border: 1px solid #e2e8f0; }
    </style>
}

<div class="row pt-4">
    <div class="col-12">
        <div class="layout-demo">
            <h2 class="fw-bold text-dark">Fluid Layout</h2>
            <p class="text-muted w-75 mx-auto mb-4">The fluid layout spans 100% of the viewport width. Elements will stretch perfectly to fill monitors of any size. (This is the default configuration of the admin template).</p>
            
            <div class="wf-container">
                <div class="wf-nav">
                    <div class="wf-menu-item active mt-4"></div>
                    <div class="wf-menu-item" style="width: 80%;"></div>
                    <div class="wf-menu-item mt-auto" style="width: 60%;"></div>
                </div>
                <div class="wf-main">
                    <div class="wf-header">
                        <div class="wf-header-box" style="width: 30px;"></div>
                        <div class="wf-header-box" style="width: 150px;"></div>
                    </div>
                    <div class="wf-content">
                        <div class="wf-card" style="grid-column: span 3; height: 100px;"></div>
                        <div class="wf-card"></div>
                        <div class="wf-card"></div>
                        <div class="wf-card"></div>
                    </div>
                </div>
            </div>

            <div class="alert alert-success bg-success bg-opacity-10 text-success border-0 text-start mt-4 d-inline-block text-center mx-auto" style="max-width: 700px;">
                <i class="fa-solid fa-check-circle me-2"></i> <strong>Current View:</strong> You are currently experiencing the Fluid layout.
            </div>
        </div>
    </div>
</div>
