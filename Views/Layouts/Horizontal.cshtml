@{
    ViewData["Title"] = "Horizontal";
}

@section Styles {
    <style>
        .layout-demo { padding: 3rem 2rem; background: #fff; border-radius: var(--radius-lg); border: 1px dashed #cbd5e1; text-align: center; }
        .wf-container { max-width: 700px; margin: 2rem auto; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); background: #f8fafc; overflow: hidden; display: flex; flex-direction: column; height: 350px; border: 1px solid #e2e8f0; }
        .wf-header-top { height: 50px; background: #fff; border-bottom: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center; padding: 0 25px; }
        .wf-header-box { height: 16px; background: #e2e8f0; border-radius: 4px; }
        .wf-nav-horizontal { height: 55px; background: var(--sidebar-bg); display: flex; align-items: center; padding: 0 25px; gap: 20px; }
        .wf-hmenu-item { height: 18px; width: 60px; background: rgba(255,255,255,0.1); border-radius: 4px; }
        .wf-hmenu-item.active { background: var(--primary-color); width: 80px; }
        .wf-main { flex: 1; padding: 25px; }
        .wf-content { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; height: 100%; }
        .wf-card { background: #fff; border-radius: 8px; border: 1px solid #e2e8f0; }
    </style>
}

<div class="row">
    <div class="col-12">
        <div class="layout-demo">
            <h2 class="fw-bold text-dark">Horizontal Navigation Layout</h2>
            <p class="text-muted w-75 mx-auto mb-4">A dual-header layout where the traditional sidebar is converted into a wide, horizontal menu bar placed directly underneath the main top-header.</p>
            
            <div class="wf-container">
                <div class="wf-header-top">
                    <div style="display:flex; align-items: center; gap: 10px;">
                        <div class="wf-header-box" style="width: 25px; height: 25px; border-radius:50%; background: var(--primary-color);"></div>
                        <div class="wf-header-box" style="width: 80px;"></div>
                    </div>
                    <div style="display:flex; gap: 15px;">
                        <div class="wf-header-box" style="width: 150px;"></div>
                        <div class="wf-header-box" style="width: 32px; height: 32px; border-radius: 50%; margin-top: -8px;"></div>
                    </div>
                </div>
                <!-- The Horizontal Nav -->
                <div class="wf-nav-horizontal">
                    <div class="wf-hmenu-item active"></div>
                    <div class="wf-hmenu-item"></div>
                    <div class="wf-hmenu-item"></div>
                    <div class="wf-hmenu-item" style="width: 90px;"></div>
                    <div class="wf-hmenu-item ms-auto" style="width: 40px;"></div>
                </div>
                <div class="wf-main">
                    <div class="wf-content">
                        <div class="wf-card" style="grid-column: span 3; height: 80px;"></div>
                        <div class="wf-card"></div>
                        <div class="wf-card"></div>
                        <div class="wf-card"></div>
                    </div>
                </div>
            </div>

            <div class="alert alert-warning bg-warning bg-opacity-10 text-dark border-0 text-start mt-4 d-inline-block mx-auto text-center" style="max-width: 700px;">
                <i class="fa-solid fa-triangle-exclamation text-warning me-2"></i> <strong>Structural Change Required:</strong> Implementing the horizontal layout requires redefining the DOM structure and changing the view hierarchy in `_Layout.cshtml`.
            </div>
        </div>
    </div>
</div>
