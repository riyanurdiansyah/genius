<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Kuda</title>
    
    <!-- FontAwesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    
    <!-- Core Theme and Component Styles -->
    <link rel="stylesheet" href="~/css/theme.css" />
    
    <style>
        body {
            font-family: var(--font-family-primary);
            color: var(--text-dark);
            background: #fff;
            overflow-x: hidden;
            padding-top: 80px; /* Space for fixed navbar */
        }
        
        /* Front-End Navbar */
        .fe-navbar {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            box-shadow: 0 4px 30px rgba(0,0,0,0.03);
            border-bottom: 1px solid rgba(0,0,0,0.05);
            transition: all 0.3s;
            height: 80px;
        }
        .fe-navbar .navbar-brand {
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--color-1);
            letter-spacing: -0.5px;
        }
        .fe-navbar .nav-link {
            font-weight: 600;
            color: var(--text-gray);
            padding: 0.5rem 1.25rem;
            transition: color 0.3s;
        }
        .fe-navbar .nav-link:hover, .fe-navbar .nav-link.active {
            color: var(--primary);
        }
        .btn-navbar {
            padding: 0.5rem 1.5rem;
            border-radius: 50px;
            font-weight: 600;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body data-bs-spy="scroll" data-bs-target="#navbar-spy" data-bs-offset="100" tabindex="0">
    
    <!-- Header Navbar -->
    <nav class="navbar navbar-expand-lg fe-navbar fixed-top" id="navbar-spy">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="#">
                <i class="fas fa-layer-group text-primary me-2"></i> KUDA<span class="text-primary">.</span>
            </a>
            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#frontNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="frontNavbar">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link" href="#home">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="#about">About</a></li>
                    <li class="nav-item"><a class="nav-link" href="#services">Services</a></li>
                    <li class="nav-item"><a class="nav-link" href="#contact">Contact</a></li>
                </ul>
                <div class="d-flex align-items-center">
                    <a href="/" class="text-muted fw-bold text-decoration-none me-4 d-none d-lg-block">Back to Dashboard</a>
                    <a href="#contact" class="btn btn-primary btn-navbar shadow-sm">Get Started</a>
                </div>
            </div>
        </div>
    </nav>

    @RenderBody()

    <!-- Core Scripts -->
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
