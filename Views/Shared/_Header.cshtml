<style>
    .topbar {
        background: rgba(255, 255, 255, 0.8) !important;
        backdrop-filter: blur(15px) saturate(180%);
        -webkit-backdrop-filter: blur(15px) saturate(180%);
        border-bottom: 1px solid rgba(255, 255, 255, 0.3) !important;
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.03);
        margin: 0 -40px 40px -40px !important; /* Fixed: Added negative margins back for full-width */
        padding: 15px 40px !important;
        position: sticky;
        top: 0;
        z-index: 1050;
        transition: all 0.3s ease;
    }
    
    [data-theme="dark"] .topbar {
        background: rgba(15, 23, 42, 0.8) !important;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05) !important;
    }

    .search-container {
        max-width: 450px !important;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .search-bar {
        background: rgba(241, 245, 249, 0.6) !important;
        border: 1px solid transparent;
        transition: all 0.3s ease;
        padding: 8px 20px !important;
    }

    [data-theme="dark"] .search-bar {
        background: rgba(30, 41, 59, 0.6) !important;
    }

    .search-container:focus-within .search-bar {
        background: #fff !important;
        border-color: var(--primary);
        box-shadow: 0 10px 25px -5px rgba(59, 130, 246, 0.1);
        transform: translateY(-1px);
    }
    
    [data-theme="dark"] .search-container:focus-within .search-bar {
        background: #1e293b !important;
    }

    .user-actions {
        gap: 12px !important;
    }

    .icon-btn {
        width: 42px !important;
        height: 42px !important;
        border: 1px solid rgba(0,0,0,0.05) !important;
        background: #fff;
        color: #64748b !important;
        transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1) !important;
        box-shadow: 0 2px 5px rgba(0,0,0,0.02);
    }

    [data-theme="dark"] .icon-btn {
        background: #1e293b;
        border-color: rgba(255,255,255,0.05) !important;
        color: #94a3b8 !important;
    }

    .icon-btn:hover {
        transform: translateY(-3px) scale(1.05);
        background: #fff;
        color: var(--primary) !important;
        border-color: var(--primary) !important;
        box-shadow: 0 10px 15px -3px rgba(59, 130, 246, 0.1);
    }

    .profile {
        background: rgba(241, 245, 249, 0.6);
        padding: 4px 4px 4px 16px !important;
        border-radius: 50px;
        border: 1px solid rgba(0,0,0,0.03);
        margin-left: 8px !important;
        transition: all 0.3s ease;
    }

    [data-theme="dark"] .profile {
        background: rgba(30, 41, 59, 0.6);
        border-color: rgba(255,255,255,0.05);
    }

    .profile:hover {
        background: #fff;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        transform: translateX(-2px);
    }

    .profile-img-wrap {
        position: relative;
    }
    
    .profile-status {
        position: absolute;
        bottom: 2px;
        right: 2px;
        width: 10px;
        height: 10px;
        background: #10b981;
        border: 2px solid #fff;
        border-radius: 50%;
    }

    /* Notification Dropdown Styles */
    .notification-dropdown {
        width: 360px !important;
        padding: 0 !important;
        border: none !important;
        border-radius: 20px !important;
        overflow: hidden;
        box-shadow: 0 15px 50px rgba(0,0,0,0.1) !important;
        margin-top: 15px !important;
    }

    .noti-header {
        padding: 20px;
        background: #fff;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    [data-theme="dark"] .noti-header { background: #1e293b; border-color: rgba(255,255,255,0.05); }

    .noti-title { font-weight: 800; font-size: 15px; margin: 0; }
    .noti-badge { background: rgba(59, 157, 130, 0.1); color: var(--primary); font-size: 11px; padding: 4px 10px; border-radius: 50px; font-weight: 700; }

    .noti-list {
        max-height: 400px;
        overflow-y: auto;
    }

    .noti-item {
        padding: 16px 20px;
        display: flex;
        gap: 15px;
        transition: all 0.2s;
        border-bottom: 1px solid #f8fafc;
        text-decoration: none !important;
        color: inherit !important;
    }
    
    [data-theme="dark"] .noti-item { border-color: rgba(255,255,255,0.03); }

    .noti-item:hover {
        background: #f8fafc;
        transform: scale(1.01);
    }
    
    [data-theme="dark"] .noti-item:hover { background: rgba(255,255,255,0.02); }

    .noti-item.unread {
        background: rgba(59, 157, 130, 0.02);
    }

    .noti-icon {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 18px;
    }

    .noti-content { flex: 1; }
    .noti-text { font-size: 13px; line-height: 1.4; margin-bottom: 4px; color: #1e293b; }
    [data-theme="dark"] .noti-text { color: #e2e8f0; }
    .noti-time { font-size: 11px; color: #94a3b8; }

    .noti-footer {
        padding: 14px;
        text-align: center;
        background: #f8fafc;
    }
    [data-theme="dark"] .noti-footer { background: #1a2233; }
    .noti-view-all { font-size: 12px; font-weight: 700; color: var(--primary); text-decoration: none; }

    /* Profile Dropdown Styles */
    .profile-dropdown {
        width: 260px !important;
        padding: 8px !important;
        border: none !important;
        border-radius: 20px !important;
        box-shadow: 0 15px 50px rgba(0,0,0,0.1) !important;
        margin-top: 15px !important;
    }

    .profile-dropdown-header {
        padding: 16px;
        border-bottom: 1px solid #f1f5f9;
        margin-bottom: 8px;
    }
    
    [data-theme="dark"] .profile-dropdown-header { border-color: rgba(255,255,255,0.05); }

    .profile-dropdown-item {
        padding: 10px 16px;
        display: flex;
        align-items: center;
        gap: 12px;
        border-radius: 12px;
        color: #475569 !important;
        font-size: 13px;
        font-weight: 600;
        transition: all 0.2s;
        text-decoration: none !important;
    }

    [data-theme="dark"] .profile-dropdown-item { color: #94a3b8 !important; }

    .profile-dropdown-item:hover {
        background: #f8fafc;
        color: var(--primary) !important;
        transform: translateX(4px);
    }
    
    [data-theme="dark"] .profile-dropdown-item:hover { background: rgba(255,255,255,0.03); }

    .profile-dropdown-item i {
        font-size: 16px;
        width: 20px;
        text-align: center;
        opacity: 0.7;
    }

    .profile-dropdown-item.logout {
        color: #ef4444 !important;
        margin-top: 8px;
        border-top: 1px solid #f1f5f9;
        border-radius: 0 0 12px 12px;
    }
    
    [data-theme="dark"] .profile-dropdown-item.logout { border-top-color: rgba(255,255,255,0.05); }
    
    .profile-dropdown-item.logout:hover {
        background: #fef2f2;
    }
    [data-theme="dark"] .profile-dropdown-item.logout:hover { background: rgba(239, 68, 68, 0.05); }
</style>

