<!-- Views/Shared/_Header.cshtml -->
<div class="topbar">
    <div class="search-bar">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" placeholder="Search or type command">
    </div>
    <div class="user-actions">
        <!-- Re-use the toggle identifier for the sidebar action -->
        <div class="icon-btn" id="toggleSidebar" title="Toggle Sidebar"><i class="fa-solid fa-bars"></i></div>
        <div class="icon-btn"><i class="fa-solid fa-gear"></i></div>
        <div class="icon-btn"><i class="fa-regular fa-bell"></i></div>
        <div class="profile">
            <span>Admin</span>
            <img src="https://ui-avatars.com/api/?name=Admin+User&background=3b9d82&color=fff" alt="Profile">
        </div>
    </div>
</div>
