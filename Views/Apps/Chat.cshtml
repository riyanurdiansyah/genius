@{ ViewData["Title"] = "Chat Panel"; }

<style>
    /* Chat Layout Variables */
    .app-chat-container {
        height: calc(100vh - 150px);
        min-height: 500px;
        background: var(--bg-card);
        border-radius: 20px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        display: flex;
        overflow: hidden;
        border: 1px solid var(--border-color);
        position: relative;
    }
    
    /* 1. Chat Sidebar (Contacts) */
    .chat-sidebar {
        width: 350px;
        border-right: 1px solid var(--border-color);
        display: flex;
        flex-direction: column;
        background: #f8fafc;
        transition: transform 0.3s ease;
    }
    .chat-sidebar-header {
        padding: 1.5rem;
        background: var(--bg-card);
        border-bottom: 1px solid var(--border-color);
    }
    .chat-list {
        flex: 1;
        overflow-y: auto;
        padding: 0.5rem;
    }
    .chat-item {
        display: flex;
        align-items: center;
        padding: 12px 16px;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.2s;
        margin-bottom: 4px;
        position: relative;
    }
    .chat-item:hover {
        background: rgba(0, 0, 0, 0.03);
    }
    .chat-item.active {
        background: var(--primary);
        color: white;
        box-shadow: 0 4px 15px rgba(59, 130, 246, 0.2);
    }
    .chat-item.active .text-muted, .chat-item.active .small-time {
        color: rgba(255, 255, 255, 0.8) !important;
    }
    .chat-item.active .text-dark {
        color: white !important;
    }
    .avatar-box {
        position: relative;
        margin-right: 14px;
    }
    .status-dot {
        position: absolute;
        bottom: 2px; right: 2px;
        width: 12px; height: 12px;
        border-radius: 50%;
        border: 2px solid #fff;
    }
    .small-time { font-size: 0.75rem; color: #94a3b8; }
    
    /* 2. Main Chat Room */
    .chat-room {
        flex: 1;
        display: flex;
        flex-direction: column;
        background: var(--bg-card);
    }
    .chat-room-header {
        padding: 1.25rem 2rem;
        border-bottom: 1px solid var(--border-color);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .chat-history {
        flex: 1;
        padding: 2rem;
        overflow-y: auto;
        background: #f1f5f9;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }
    
    /* 3. Message Bubbles */
    .msg-wrap {
        display: flex;
        max-width: 75%;
        position: relative;
    }
    .msg-wrap.received { align-self: flex-start; }
    .msg-wrap.sent { align-self: flex-end; flex-direction: row-reverse; }
    
    .msg-bubble {
        padding: 12px 18px;
        border-radius: 18px;
        font-size: 0.95rem;
        line-height: 1.5;
        position: relative;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }
    .msg-wrap.received .msg-bubble {
        background: white;
        color: var(--text-dark);
        border-bottom-left-radius: 4px;
        border: 1px solid var(--border-color);
    }
    .msg-wrap.sent .msg-bubble {
        background: linear-gradient(135deg, var(--primary), #2563eb);
        color: white;
        border-bottom-right-radius: 4px;
    }
    
    .msg-time {
        font-size: 0.7rem;
        color: #94a3b8;
        margin-top: 5px;
        display: block;
    }
    .msg-wrap.sent .msg-time { text-align: right; }
    
    /* 4. Chat Input Box */
    .chat-input-area {
        padding: 1.5rem 2rem;
        background: var(--bg-card);
        border-top: 1px solid var(--border-color);
    }
    .chat-input-wrapper {
        display: flex;
        align-items: center;
        background: #f8fafc;
        border-radius: 50px;
        padding: 8px 16px;
        border: 1px solid #e2e8f0;
        transition: border-color 0.2s;
    }
    .chat-input-wrapper:focus-within { border-color: var(--primary); background: #fff;}
    .chat-input {
        flex: 1; border: none; background: transparent; padding: 10px; outline: none; box-shadow: none;
    }
    .btn-circle {
        width: 40px; height: 40px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        transition: all 0.2s;
    }
    
    /* Context & Dark Mode */
    [data-theme="dark"] .chat-sidebar { background: #0f172a; border-color: #334155; }
    [data-theme="dark"] .chat-sidebar-header { border-color: #334155; }
    [data-theme="dark"] .chat-room-header, [data-theme="dark"] .chat-input-area { border-color: #334155; }
    [data-theme="dark"] .chat-item:hover { background: rgba(255,255,255,0.03); }
    [data-theme="dark"] .chat-history { background: #0b1120; }
    [data-theme="dark"] .msg-wrap.received .msg-bubble { background: #1e293b; border-color: #334155; color: #f8fafc; }
    [data-theme="dark"] .chat-input-wrapper { background: #0f172a; border-color: #334155; }
    [data-theme="dark"] .chat-input-wrapper:focus-within { background: #1e293b; }
    [data-theme="dark"] .status-dot { border-color: #1e293b; }
    [data-theme="dark"] .text-dark { color: #f8fafc !important; }
    [data-theme="dark"] .text-muted { color: #94a3b8 !important; }
    
    /* Responsive logic */
    @@media (max-width: 768px) {
        .chat-sidebar { position: absolute; z-index: 100; height: 100%; transform: translateX(-100%); }
        .chat-sidebar.show { transform: translateX(0); }
        .mobile-toggle { display: block !important; }
    }
    .mobile-toggle { display: none; }
</style>

<div class="row mb-4">
    <div class="col-12">
        <h4 class="fw-bold mb-1">Corporate Communicator</h4>
        <p class="text-muted">Real-time collaboration panel with rich text and attachment support.</p>
    </div>
</div>

<div class="app-chat-container">
    
    <!-- 1. Contacts Sidebar -->
    <div class="chat-sidebar" id="chatSidebar">
        <div class="chat-sidebar-header d-flex flex-column gap-3">
            <div class="d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-3">
                    <img src="https://ui-avatars.com/api/?name=Admin+User&background=3b9d82&color=fff" class="rounded-circle" width="45" height="45" alt="Me">
                    <div>
                        <h6 class="fw-bold mb-0 text-dark">My Messages</h6>
                        <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-2"><span class="pulse-dot d-inline-block me-1" style="width:6px; height:6px; background:#198754; border-radius:50%; vertical-align:middle;"></span>Online</span>
                    </div>
                </div>
                <button class="btn btn-light btn-circle border-0 text-muted"><i class="fas fa-edit"></i></button>
            </div>
            
            <div class="input-group">
                <span class="input-group-text bg-transparent border-end-0 text-muted ps-3"><i class="fas fa-search"></i></span>
                <input type="text" class="form-control border-start-0 ps-0" placeholder="Search chats..." style="background:transparent; box-shadow:none;">
            </div>
        </div>
        
        <div class="chat-list">
            <!-- Active Item -->
            <div class="chat-item active">
                <div class="avatar-box">
                    <img src="https://ui-avatars.com/api/?name=Sarah+Miller&background=0D8ABC&color=fff" class="rounded-circle" width="48" height="48" alt="Avatar">
                    <span class="status-dot bg-success"></span>
                </div>
                <div class="flex-grow-1 overflow-hidden">
                    <div class="d-flex justify-content-between mb-1">
                        <h6 class="fw-bold mb-0 text-dark text-truncate">UX Design Team 🚀</h6>
                        <span class="small-time">10:45 AM</span>
                    </div>
                    <p class="mb-0 text-muted small text-truncate">Sarah: Here is the latest Figma file.</p>
                </div>
                <span class="badge bg-white text-primary rounded-circle p-1 ms-2" style="font-size:0.65rem;">3</span>
            </div>
            
            <!-- Standard Items -->
            <div class="chat-item">
                <div class="avatar-box">
                    <img src="https://ui-avatars.com/api/?name=David+R&background=FF8A65&color=fff" class="rounded-circle" width="48" height="48" alt="Avatar">
                    <span class="status-dot bg-secondary"></span>
                </div>
                <div class="flex-grow-1 overflow-hidden">
                    <div class="d-flex justify-content-between mb-1">
                        <h6 class="fw-bold mb-0 text-dark text-truncate">David Robertson</h6>
                        <span class="small-time">Yesterday</span>
                    </div>
                    <p class="mb-0 text-muted small text-truncate">Can we schedule a call for tomorrow?</p>
                </div>
            </div>
            
            <div class="chat-item">
                <div class="avatar-box">
                    <div class="rounded-circle bg-info bg-opacity-10 text-info d-flex align-items-center justify-content-center fw-bold fs-5" style="width:48px; height:48px;">
                        #
                    </div>
                </div>
                <div class="flex-grow-1 overflow-hidden">
                    <div class="d-flex justify-content-between mb-1">
                        <h6 class="fw-bold mb-0 text-dark text-truncate">Marketing Campaign</h6>
                        <span class="small-time">Mon</span>
                    </div>
                    <p class="mb-0 text-muted small text-truncate">Amanda is typing...</p>
                </div>
            </div>
            
            <div class="chat-item">
                <div class="avatar-box">
                    <img src="https://ui-avatars.com/api/?name=Jessica+T&background=8E24AA&color=fff" class="rounded-circle" width="48" height="48" alt="Avatar">
                    <span class="status-dot bg-warning"></span>
                </div>
                <div class="flex-grow-1 overflow-hidden">
                    <div class="d-flex justify-content-between mb-1">
                        <h6 class="fw-bold mb-0 text-dark text-truncate">Jessica Taylor</h6>
                        <span class="small-time">Oct 12</span>
                    </div>
                    <p class="mb-0 text-muted small text-truncate"><i class="fas fa-file-pdf me-1"></i> QuarterlyReport.pdf</p>
                </div>
            </div>
        </div>
    </div>
    
    <!-- 2. Chat Room Main Window -->
    <div class="chat-room">
        <!-- Room Header -->
        <div class="chat-room-header">
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-light btn-sm mobile-toggle border-0" onclick="document.getElementById('chatSidebar').classList.toggle('show')">
                    <i class="fas fa-chevron-left"></i>
                </button>
                <div class="avatar-box mb-0 me-0">
                    <img src="https://ui-avatars.com/api/?name=Sarah+Miller&background=0D8ABC&color=fff" class="rounded-circle shadow-sm" width="50" height="50" alt="Avatar">
                    <span class="status-dot bg-success" style="width:14px; height:14px;"></span>
                </div>
                <div>
                    <h5 class="fw-bold mb-0 text-dark">UX Design Team 🚀</h5>
                    <span class="text-success small fw-bold">Sarah, John, You</span>
                </div>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-light btn-circle border-0 text-muted shadow-sm hover-primary"><i class="fas fa-phone"></i></button>
                <button class="btn btn-light btn-circle border-0 text-muted shadow-sm hover-primary"><i class="fas fa-video"></i></button>
                <button class="btn btn-light btn-circle border-0 text-muted shadow-sm hover-primary"><i class="fas fa-info-circle"></i></button>
            </div>
        </div>
        
        <!-- Chat Area -->
        <div class="chat-history">
            
            <!-- System / Date bubble -->
            <div class="text-center my-2">
                <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill px-3 py-1">Today</span>
            </div>
            
            <!-- Received Message 1 -->
            <div class="msg-wrap received">
                <img src="https://ui-avatars.com/api/?name=John+Doe&background=4CAF50&color=fff" class="rounded-circle mt-auto me-2" width="30" height="30" alt="Avatar">
                <div>
                    <span class="text-muted small fw-bold ms-1">John Doe</span>
                    <div class="msg-bubble">
                        Hey team, just wanted to check if the new wireframes are ready for the presentation today?
                    </div>
                    <span class="msg-time ms-1">10:30 AM</span>
                </div>
            </div>
            
            <!-- Sent Message -->
            <div class="msg-wrap sent">
                <div>
                    <div class="msg-bubble">
                        Yes! Almost done. I am compiling the final screens into a Figma prototype right now. Should be ready in 15 mins. 🔥
                    </div>
                    <span class="msg-time me-1">10:35 AM <i class="fas fa-check-double text-primary ms-1"></i></span>
                </div>
            </div>
            
            <!-- Received Message 2 (File) -->
            <div class="msg-wrap received">
                <img src="https://ui-avatars.com/api/?name=Sarah+Miller&background=0D8ABC&color=fff" class="rounded-circle mt-auto me-2" width="30" height="30" alt="Avatar">
                <div>
                    <span class="text-muted small fw-bold ms-1">Sarah Miller</span>
                    <div class="msg-bubble">
                        Awesome! While waiting, here is the updated brand guideline document as requested by the client.
                        
                        <div class="card mt-3 border bg-light bg-opacity-50">
                            <div class="card-body p-2 d-flex align-items-center gap-3">
                                <div class="bg-danger bg-opacity-10 text-danger rounded p-2 text-center" style="width:45px; height:45px;">
                                    <i class="fas fa-file-pdf fs-4 mt-1"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="fw-bold" style="font-size:0.9rem;">Brand_Guidelines_v3.pdf</div>
                                    <div class="text-muted" style="font-size:0.75rem;">1.2 MB</div>
                                </div>
                                <button class="btn btn-sm btn-light border-0"><i class="fas fa-download"></i></button>
                            </div>
                        </div>
                    </div>
                    <span class="msg-time ms-1">10:45 AM</span>
                </div>
            </div>
            
        </div>
        
        <!-- Chat Input Area -->
        <div class="chat-input-area">
            <div class="chat-input-wrapper shadow-sm">
                <button class="btn btn-link text-muted p-0 px-2 fs-5" title="Emoji"><i class="far fa-smile"></i></button>
                <button class="btn btn-link text-muted p-0 px-2 fs-5" title="Attach"><i class="fas fa-paperclip"></i></button>
                
                <input type="text" class="chat-input mx-2" placeholder="Type your message here...">
                
                <button class="btn btn-primary btn-circle shadow" title="Send">
                    <i class="fas fa-paper-plane" style="margin-right:-3px;"></i>
                </button>
            </div>
        </div>
        
    </div>
</div>

<script>
    // Simple script to auto-scroll chat to bottom
    document.addEventListener("DOMContentLoaded", function() {
        const chatHistory = document.querySelector('.chat-history');
        if(chatHistory) {
            chatHistory.scrollTop = chatHistory.scrollHeight;
        }
    });
</script>
