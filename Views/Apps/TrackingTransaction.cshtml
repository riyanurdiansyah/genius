@{ ViewData["Title"] = "Transaction & Parcel Tracking"; }

<style>
    /* Global Tracking Aesthetics */
    .tracking-search-box {
        background: url('https://images.unsplash.com/photo-1586528116311-ad8ce7dcabf0?auto=format&fit=crop&q=80&w=1200&h=300') center/cover no-repeat;
        border-radius: 20px;
        padding: 4rem 2rem;
        position: relative;
        overflow: hidden;
    }
    .tracking-search-box::before {
        content: ''; position: absolute; top:0; left:0; right:0; bottom:0;
        background: linear-gradient(135deg, rgba(15,23,42,0.95) 0%, rgba(30,58,138,0.85) 100%);
    }
    .search-wrapper {
        position: relative; z-index: 2; max-width: 600px; margin: 0 auto;
    }
    
    /* 1. Horizontal Stepper */
    .stepper-horizontal {
        display: flex;
        justify-content: space-between;
        position: relative;
        margin: 3rem 0;
        padding: 0 2rem;
    }
    .stepper-horizontal::before {
        content: ''; position: absolute; top: 20px; left: 10%; right: 10%;
        height: 3px; background: #e2e8f0; z-index: 1;
    }
    .step-item {
        position: relative; z-index: 2; text-align: center; width: 25%;
    }
    .step-icon {
        width: 44px; height: 44px;
        border-radius: 50%;
        background: #fff;
        border: 3px solid #e2e8f0;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 12px;
        color: #94a3b8;
        font-size: 1.2rem;
        transition: all 0.3s ease;
    }
    .step-item.completed .step-icon {
        background: var(--success);
        border-color: var(--success);
        color: white;
        box-shadow: 0 0 0 5px rgba(16, 185, 129, 0.2);
    }
    .step-item.active .step-icon {
        background: var(--primary);
        border-color: var(--primary);
        color: white;
        box-shadow: 0 0 0 5px rgba(59, 130, 246, 0.2);
    }
    .step-title { font-weight: 600; color: var(--text-dark); margin-bottom: 4px; }
    .step-date { font-size: 0.75rem; color: #64748b; }
    
    /* Progress line override */
    .stepper-horizontal .progress-line {
        position: absolute; top: 20px; left: 10%; width: 50%;
        height: 3px; background: var(--success); z-index: 1;
    }

    /* 2. Vertical Detail Timeline */
    .timeline-vertical {
        border-left: 2px dashed #cbd5e1;
        padding-left: 30px;
        margin-left: 20px;
        position: relative;
    }
    .timeline-item {
        position: relative;
        margin-bottom: 2rem;
    }
    .timeline-item::before {
        content: ''; position: absolute; left: -39px; top: 0;
        width: 16px; height: 16px; border-radius: 50%;
        background: #fff; border: 3px solid #cbd5e1;
    }
    .timeline-item.done::before {
        background: var(--primary); border-color: #fff;
        box-shadow: 0 0 0 3px rgba(59,130,246,0.3);
    }
    .timeline-time {
        font-size: 0.8rem; font-weight: 600; color: #64748b; margin-bottom: 5px;
        display: block;
    }
    .timeline-content {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 1rem;
        display: inline-block;
        min-width: 300px;
    }
    
    /* 3. Parcel Modern Card */
    .parcel-card {
        background: linear-gradient(145deg, #ffffff, #f8fafc);
        border-radius: 24px;
        border: 1px solid #e2e8f0;
        overflow: hidden;
    }
    .parcel-header {
        background: #0f172a; color: white;
        padding: 1.5rem;
    }
    .qrcode-box {
        background: #fff; border-radius: 8px; padding: 10px; width: 80px; height: 80px;
    }

    [data-theme="dark"] .step-title { color: #f8fafc; }
    [data-theme="dark"] .timeline-content { background: #1e293b; border-color: rgba(255,255,255,0.05); }
    [data-theme="dark"] .stepper-horizontal::before { background: #334155; }
    [data-theme="dark"] .step-icon { background: #1e293b; border-color: #334155; }
    [data-theme="dark"] .parcel-card { background: #0f172a; border-color: rgba(255,255,255,0.05); }
</style>

<div class="row g-4 mb-5">
    <div class="col-12">
        <h4 class="fw-bold mb-1">Transaction & Parcel Tracking</h4>
        <p class="text-muted">Modern consumer-facing tracking interfaces, timelines, and proof of delivery.</p>
    </div>

    <!-- Tracking Header Input -->
    <div class="col-12">
        <div class="tracking-search-box shadow-lg mb-2">
            <div class="search-wrapper text-center text-white">
                <i class="fas fa-box-open fa-3x mb-3 text-primary" style="opacity: 0.8;"></i>
                <h3 class="fw-bold mb-2">Track Your Package</h3>
                <p class="mb-4" style="color: #cbd5e1;">Enter your Airway Bill (AWB) or Transaction ID below</p>
                
                <div class="input-group input-group-lg bg-white p-2 rounded-pill shadow">
                    <span class="input-group-text bg-transparent border-0 text-muted ps-4"><i class="fas fa-search"></i></span>
                    <input type="text" class="form-control border-0 bg-transparent fs-6" placeholder="e.g. TRK-992144810-ID" value="TRK-992144810-ID" style="box-shadow: none;">
                    <button class="btn btn-primary rounded-pill px-4 fw-bold">Track Now</button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 d-flex justify-content-between align-items-center mt-3 mb-1">
        <div>
            <h5 class="fw-bold mb-0">Order: #TRK-992144810-ID</h5>
            <span class="text-muted small">Estimated Delivery: <strong>Tomorrow, 14:00</strong></span>
        </div>
        <button class="btn btn-outline-dark rounded-pill px-3 btn-sm"><i class="fas fa-print me-1"></i> Print Receipt</button>
    </div>

    <!-- Variation 1: Horizontal Stepper -->
    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body py-5">
                <div class="stepper-horizontal">
                    <div class="progress-line"></div>
                    
                    <div class="step-item completed">
                        <div class="step-icon"><i class="fas fa-check"></i></div>
                        <div class="step-title">Order Placed</div>
                        <div class="step-date">Oct 12, 08:30</div>
                    </div>
                    
                    <div class="step-item completed">
                        <div class="step-icon"><i class="fas fa-box"></i></div>
                        <div class="step-title">Picked Up</div>
                        <div class="step-date">Oct 12, 14:15</div>
                    </div>
                    
                    <div class="step-item active">
                        <div class="step-icon"><i class="fas fa-truck-fast"></i></div>
                        <div class="step-title">In Transit</div>
                        <div class="step-date">Oct 13, 09:20</div>
                    </div>
                    
                    <div class="step-item">
                        <div class="step-icon"><i class="fas fa-home"></i></div>
                        <div class="step-title">Delivered</div>
                        <div class="step-date text-muted">Awaiting</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-1">
        <!-- Variation 2: Detailed Vertical Timeline -->
        <div class="col-md-7">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white border-0 pt-4 pb-2">
                    <h6 class="fw-bold mb-0"><i class="fas fa-history text-primary me-2"></i>Detailed History</h6>
                </div>
                <div class="card-body">
                    <div class="timeline-vertical mt-3">
                        
                        <div class="timeline-item done">
                            <span class="timeline-time">Today, 09:20 AM</span>
                            <div class="timeline-content">
                                <h6 class="fw-bold text-dark mb-1">Arrived at Sorting Facility</h6>
                                <p class="text-muted small mb-0">Package scanned at Gateway Hub (Jakarta Selatan). Preparing for local dispatch.</p>
                            </div>
                        </div>
                        
                        <div class="timeline-item done">
                            <span class="timeline-time">Yesterday, 18:45 PM</span>
                            <div class="timeline-content">
                                <h6 class="fw-bold text-dark mb-1">Departed Origin Facility</h6>
                                <p class="text-muted small mb-0">Handed over to inter-city logistics carrier. Line haul en-route to Jakarta.</p>
                                <div class="mt-2 bg-white rounded border p-2 d-inline-flex align-items-center">
                                    <i class="fas fa-plane-departure text-info me-2"></i> <span class="small fw-bold">Flight GA-411</span>
                                </div>
                            </div>
                        </div>
                        
                        <div class="timeline-item done">
                            <span class="timeline-time">Yesterday, 14:15 PM</span>
                            <div class="timeline-content">
                                <h6 class="fw-bold text-dark mb-1">Package Picked Up</h6>
                                <p class="text-muted small mb-0">Driver "Budi Santoso" successfully collected the package from sender.</p>
                            </div>
                        </div>
                        
                        <div class="timeline-item done">
                            <span class="timeline-time">Yesterday, 08:30 AM</span>
                            <div class="timeline-content">
                                <h6 class="fw-bold text-dark mb-1">Electronic Info Received</h6>
                                <p class="text-muted small mb-0">Sender created an AWB label. We are awaiting physical handover.</p>
                            </div>
                        </div>
                        
                    </div>
                </div>
            </div>
        </div>

        <!-- Variation 3: Parcel Specs & QR Card -->
        <div class="col-md-5">
            <div class="parcel-card shadow-sm h-100">
                <div class="parcel-header d-flex justify-content-between align-items-start">
                    <div>
                        <span class="badge bg-primary bg-opacity-25 text-info rounded-pill px-3 py-2 mb-3 border border-primary">Express Delivery</span>
                        <h4 class="fw-bold mb-1">Apple MacBook Pro 16"</h4>
                        <p class="text-white text-opacity-75 small mb-0">Electronics / Fragile</p>
                    </div>
                    <div class="qrcode-box shadow-sm">
                        <!-- Generic fake QR code SVG -->
                        <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                            <path fill="#0f172a" d="M0 0h100v100H0z" fill-opacity="0.05"/>
                            <path fill="#0f172a" d="M10 10h30v30H10zm5 5h20v20H15zm-5 45h30v30H10zm5 5h20v20H15zM55 10h30v30H55zm5 5h20v20H60zM45 45h40v15H45zM10 90V65h15v10h10v15H10zM75 60h15v15H75z" />
                        </svg>
                    </div>
                </div>
                <div class="p-4 bg-white">
                    <div class="row g-3 mb-4 text-center">
                        <div class="col-6 border-end">
                            <div class="text-muted small">Weight</div>
                            <h6 class="fw-bold text-dark mt-1 mb-0">2.4 kg</h6>
                        </div>
                        <div class="col-6">
                            <div class="text-muted small">Dimensions</div>
                            <h6 class="fw-bold text-dark mt-1 mb-0">35x25x6 cm</h6>
                        </div>
                    </div>
                    
                    <hr class="border-secondary opacity-10">
                    
                    <div class="mt-3">
                        <div class="d-flex align-items-start mb-3">
                            <div class="bg-light rounded-circle p-2 text-danger me-3"><i class="fas fa-map-marker-alt"></i></div>
                            <div>
                                <small class="text-muted d-block">From (Sender)</small>
                                <p class="fw-bold text-dark mb-0 small">iBox Official Store</p>
                                <p class="text-muted small mb-0">Surabaya Pusat, Jatim</p>
                            </div>
                        </div>
                        <div class="d-flex align-items-start">
                            <div class="bg-light rounded-circle p-2 text-success me-3"><i class="fas fa-location-arrow"></i></div>
                            <div>
                                <small class="text-muted d-block">To (Recipient)</small>
                                <p class="fw-bold text-dark mb-0 small">Kuncoro Jati</p>
                                <p class="text-muted small mb-0">Sudirman Central, Jakarta 12190</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
