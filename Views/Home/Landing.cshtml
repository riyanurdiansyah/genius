@{
    Layout = null; // No navbar/sidebar for the landing page
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kuda Admin - Welcome</title>
    <!-- Use the same fonts if available -->
    <link rel="stylesheet" href="/css/theme.css" />
    <style>
        body, html {
            margin: 0; 
            padding: 0; 
            width: 100%; 
            height: 100%;
            /* Dark techy background matching the image aesthetic */
            background-color: #060b14; 
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            font-family: var(--font-primary, sans-serif);
        }
        
        .splash-container {
            text-align: center;
        }

        .splash-logo {
            width: 700px;
            max-width: 95vw;
            opacity: 0;
            transform: scale(0.9);
            /* Play animation for 6 seconds then stay on last frame */
            animation: emerge 6s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
        }

        /* 
           The animation sequence:
           0% : Invisible and slightly zoomed out
           20% : Fades in quickly, slight glow
           70% : Held visible, bright glow representing the "loading/activation" phase
           100%: Quick fade-out & swoop up simulating entering the system
        */
        @@keyframes emerge {
            0% {
                opacity: 0;
                transform: scale(0.8) translateY(20px);
                filter: blur(10px) brightness(0.5);
            }
            25% {
                opacity: 1;
                transform: scale(1) translateY(0);
                filter: blur(0px) drop-shadow(0 0 25px rgba(0, 255, 255, 0.4)) brightness(1.1);
            }
            80% {
                opacity: 1;
                transform: scale(1) translateY(0);
                filter: blur(0px) drop-shadow(0 0 35px rgba(0, 255, 255, 0.6)) brightness(1.2);
            }
            100% {
                opacity: 0;
                transform: scale(1.1) translateY(-20px);
                filter: blur(8px) brightness(1.5);
            }
        }
    </style>
</head>
<body>
    <div class="splash-container">
        <!-- 
           The user specified the image is placed at wwwroot/image/kuda.png 
           Note: the Genius template standard path might be image/ or images/, 
           but we'll use /image/kuda.png as requested.
        -->
        <img src="/image/kuda.png" alt="Kuda System Architecture" class="splash-logo" onerror="this.src='/images/kuda.png'" />
    </div>

    <script>
        // Redirect to login page after the animation finishes (6 seconds)
        // Set slightly earlier than CSS animation end for a smooth transition feeling
        setTimeout(() => {
            window.location.replace('/Login');
        }, 5900);
    </script>
</body>
</html>
