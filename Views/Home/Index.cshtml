@{
    ViewData["Title"] = "Dashboard";
}

<div class="row mb-4">
    <!-- Stat Cards -->
    <div class="col-md-3 mb-3">
        <div class="card h-100 mb-0">
            <div class="card-body stat-card">
                <div class="stat-icon bg-primary">
                    <i class="fas fa-users text-white"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1">Total Users</h6>
                    <h3 class="mb-0">1,245</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card h-100 mb-0">
            <div class="card-body stat-card">
                <div class="stat-icon bg-secondary">
                    <i class="fas fa-shopping-cart text-white"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1">New Orders</h6>
                    <h3 class="mb-0">382</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card h-100 mb-0">
            <div class="card-body stat-card">
                <div class="stat-icon bg-success">
                    <i class="fas fa-dollar-sign text-white"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1">Total Revenue</h6>
                    <h3 class="mb-0">$45K</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card h-100 mb-0">
            <div class="card-body stat-card">
                <div class="stat-icon bg-warning">
                    <i class="fas fa-chart-line"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1">Growth</h6>
                    <h3 class="mb-0">+24%</h3>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Charts or other elements -->
    <div class="col-lg-8 mb-4">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Revenue Overview</span>
                <button class="btn btn-sm btn-outline-primary"><i class="fas fa-download"></i> Export</button>
            </div>
            <div class="card-body d-flex justify-content-center align-items-center" style="min-height: 300px; background-color: #f8f9fa;">
                <p class="text-muted"><i class="fas fa-chart-bar fs-1 mb-2 d-block text-center"></i> Chart Placeholder</p>
                <!-- Include Chart.js or similar library to render actual charts -->
            </div>
        </div>
    </div>
    
    <!-- Recent Activity -->
    <div class="col-lg-4 mb-4">
        <div class="card h-100">
            <div class="card-header">
                System Health
            </div>
            <div class="card-body">
                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-secondary">CPU Usage</span>
                        <span class="fw-bold">45%</span>
                    </div>
                    <div class="progress" style="height: 8px; background: #e9ecef; border-radius: 4px;">
                        <div class="progress-bar bg-primary" role="progressbar" style="width: 45%; height: 100%; border-radius: 4px;" aria-valuenow="45" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                </div>
                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-secondary">Memory</span>
                        <span class="fw-bold">75%</span>
                    </div>
                    <div class="progress" style="height: 8px; background: #e9ecef; border-radius: 4px;">
                        <div class="progress-bar bg-warning" role="progressbar" style="width: 75%; height: 100%; border-radius: 4px;" aria-valuenow="75" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                </div>
                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-secondary">Disk Space</span>
                        <span class="fw-bold">20%</span>
                    </div>
                    <div class="progress" style="height: 8px; background: #e9ecef; border-radius: 4px;">
                        <div class="progress-bar bg-success" role="progressbar" style="width: 20%; height: 100%; border-radius: 4px;" aria-valuenow="20" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">Recent Orders</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Customer</th>
                                <th>Date</th>
                                <th>Status</th>
                                <th>Amount</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>#ORD-001</td>
                                <td>John Doe</td>
                                <td>Oct 24, 2023</td>
                                <td><span class="badge bg-success">Completed</span></td>
                                <td>$120.50</td>
                                <td><button class="btn btn-sm btn-outline-primary"><i class="fas fa-eye"></i></button></td>
                            </tr>
                            <tr>
                                <td>#ORD-002</td>
                                <td>Jane Smith</td>
                                <td>Oct 23, 2023</td>
                                <td><span class="badge bg-warning text-dark">Pending</span></td>
                                <td>$45.00</td>
                                <td><button class="btn btn-sm btn-outline-primary"><i class="fas fa-eye"></i></button></td>
                            </tr>
                            <tr>
                                <td>#ORD-003</td>
                                <td>Mike Johnson</td>
                                <td>Oct 22, 2023</td>
                                <td><span class="badge bg-danger">Cancelled</span></td>
                                <td>$210.00</td>
                                <td><button class="btn btn-sm btn-outline-primary"><i class="fas fa-eye"></i></button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
