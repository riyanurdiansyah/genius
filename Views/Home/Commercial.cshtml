@{
    ViewData["Title"] = "Commercial Dashboard";
}

<style>
    .comm-card {
        border-radius: 12px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
        border: none;
        background: #fff;
    }
    .comm-kpi-val {
        font-size: 2rem;
        font-weight: 800;
        letter-spacing: -1px;
        margin-bottom: 5px;
    }
    .comm-title {
        color: #64748b;
        text-transform: uppercase;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.5px;
    }
    .trend-up { color: var(--success); }
    .trend-down { color: var(--danger); }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold">Commercial & Finance Hub</h4>
        <p class="text-muted"><small>Sales, Accounting, and HR Metrics</small></p>
    </div>
    <div class="d-flex gap-2">
        <select class="form-select form-select-sm" style="width: auto;">
            <option>Q3 2026</option>
            <option>Q2 2026</option>
            <option>Q1 2026</option>
            <option>FY 2025</option>
        </select>
        <button class="btn btn-sm btn-dark"><i class="fas fa-download"></i> Download Report</button>
    </div>
</div>

<!-- High-Level Financials -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card comm-card h-100 p-3">
            <div class="comm-title">Total Gross Revenue</div>
            <div class="comm-kpi-val">$2.45M</div>
            <div class="d-flex justify-content-between align-items-center">
                <span class="badge bg-success-light text-success"><i class="fas fa-arrow-up"></i> 12%</span>
                <span class="text-muted small">vs last quarter</span>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card comm-card h-100 p-3">
            <div class="comm-title">Net Profit Margin</div>
            <div class="comm-kpi-val">18.2%</div>
            <div class="d-flex justify-content-between align-items-center">
                <span class="badge bg-success-light text-success"><i class="fas fa-arrow-up"></i> 2.1%</span>
                <span class="text-muted small">vs last quarter</span>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card comm-card h-100 p-3">
            <div class="comm-title">Operating Cash Flow</div>
            <div class="comm-kpi-val">$840K</div>
            <div class="d-flex justify-content-between align-items-center">
                <span class="badge bg-danger-light text-danger"><i class="fas fa-arrow-down"></i> 1.5%</span>
                <span class="text-muted small">vs last quarter</span>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card comm-card h-100 p-3" style="background-color: var(--primary); color: white;">
            <div class="comm-title text-white-50">Total Employee Count</div>
            <div class="comm-kpi-val text-white">412</div>
            <div class="d-flex justify-content-between align-items-center">
                <span class="bg-white text-primary px-2 rounded small fw-bold">+14 Hires</span>
                <span class="text-white-50 small">HR Tracker</span>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <!-- Revenue vs Expenses Trend -->
    <div class="col-lg-8">
        <div class="card comm-card h-100">
            <div class="card-header bg-transparent border-bottom-0 pt-4 pb-0">
                <h6 class="fw-bold mb-0">Financial Performance (Revenue vs Expenses)</h6>
            </div>
            <div class="card-body">
                <div id="financialChart" style="min-height: 300px;"></div>
            </div>
        </div>
    </div>

    <!-- Sales by Category (Donut) -->
    <div class="col-lg-4">
        <div class="card comm-card h-100">
            <div class="card-header bg-transparent border-bottom-0 pt-4 pb-0">
                <h6 class="fw-bold mb-0">Sales by Division</h6>
            </div>
            <div class="card-body d-flex flex-column justify-content-center">
                <div id="salesDonut" style="min-height: 250px;"></div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Regional Sales Table -->
    <div class="col-md-7">
        <div class="card comm-card">
            <div class="card-header bg-transparent d-flex justify-content-between align-items-center pt-4">
                <h6 class="fw-bold mb-0">Regional Sales Pipeline</h6>
                <a href="#" class="text-primary small text-decoration-none">View Full Report</a>
            </div>
            <div class="card-body p-0 mt-2">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Region</th>
                                <th>Lead Manager</th>
                                <th>Generated</th>
                                <th>Target</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>North America</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width:30px;height:30px; font-size:12px;">SM</div>
                                        <span>Sarah Miller</span>
                                    </div>
                                </td>
                                <td>$1.2M</td>
                                <td><div class="progress" style="height:5px;"><div class="progress-bar bg-success" style="width: 100%;"></div></div></td>
                                <td><span class="text-success fw-bold">Reached</span></td>
                            </tr>
                            <tr>
                                <td>Europe</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-info text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width:30px;height:30px; font-size:12px;">DK</div>
                                        <span>David Koch</span>
                                    </div>
                                </td>
                                <td>$850K</td>
                                <td><div class="progress" style="height:5px;"><div class="progress-bar bg-warning" style="width: 85%;"></div></div></td>
                                <td><span class="text-warning fw-bold">On Track</span></td>
                            </tr>
                            <tr>
                                <td>Asia-Pacific</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width:30px;height:30px; font-size:12px;">AL</div>
                                        <span>Anna Lee</span>
                                    </div>
                                </td>
                                <td>$400K</td>
                                <td><div class="progress" style="height:5px;"><div class="progress-bar bg-danger" style="width: 40%;"></div></div></td>
                                <td><span class="text-danger fw-bold">Lagging</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- HR Payroll / Expenses snippet -->
    <div class="col-md-5">
        <div class="card comm-card">
            <div class="card-header bg-transparent border-bottom-0 pt-4">
                <h6 class="fw-bold mb-0">HR & Admin Cost Distribution</h6>
            </div>
            <div class="card-body">
                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted text-sm">Salaries & Wages</span>
                        <span class="fw-bold">$420,000</span>
                    </div>
                    <div class="progress" style="height: 8px;">
                        <div class="progress-bar bg-primary" style="width: 65%;"></div>
                    </div>
                </div>
                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted text-sm">Benefits & Insurance</span>
                        <span class="fw-bold">$125,000</span>
                    </div>
                    <div class="progress" style="height: 8px;">
                        <div class="progress-bar bg-info" style="width: 25%;"></div>
                    </div>
                </div>
                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted text-sm">Training & Recruitment</span>
                        <span class="fw-bold">$45,000</span>
                    </div>
                    <div class="progress" style="height: 8px;">
                        <div class="progress-bar bg-warning" style="width: 10%;"></div>
                    </div>
                </div>

                <div class="alert alert-secondary mt-4 border-0 mb-0 d-flex align-items-center py-2">
                    <i class="fas fa-lightbulb text-warning me-3 fa-lg"></i>
                    <small>Recruitment costs are down 15% this quarter due to higher retention.</small>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        // Finance Spline Chart
        var finOptions = {
            series: [{
                name: 'Revenue',
                data: [310, 420, 280, 510, 490, 620, 690, 810, 750]
            }, {
                name: 'Expenses',
                data: [210, 300, 250, 380, 400, 450, 480, 500, 520]
            }],
            chart: {
                height: 300,
                type: 'line',
                toolbar: { show: false }
            },
            colors: ['#235347', '#f43f5e'],
            dataLabels: { enabled: false },
            stroke: {
                curve: 'smooth',
                width: 3
            },
            xaxis: {
                categories: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep'],
            },
            legend: {
                position: 'top',
                horizontalAlign: 'right'
            },
            markers: {
                size: 4
            }
        };

        var finChart = new ApexCharts(document.querySelector("#financialChart"), finOptions);
        finChart.render();

        // Sales Division Donut Chart
        var salesOptions = {
            series: [44, 55, 13, 33],
            labels: ['B2B Enterprise', 'Retail Direct', 'E-Commerce', 'Wholesale'],
            chart: {
                type: 'donut',
                height: 280
            },
            colors: ['#235347', '#3b82f6', '#10b981', '#f59e0b'],
            plotOptions: {
                pie: {
                    donut: {
                        size: '70%',
                        labels: {
                            show: true,
                            total: {
                                show: true,
                                showAlways: true,
                                label: 'Total',
                                fontSize: '20px',
                                color: '#000',
                                formatter: function (w) {
                                    return "$2.45M"
                                }
                            }
                        }
                    }
                }
            },
            dataLabels: { enabled: false },
            legend: {
                position: 'bottom'
            }
        };

        var salesChart = new ApexCharts(document.querySelector("#salesDonut"), salesOptions);
        salesChart.render();
    });
</script>
