    <!-- Scatter Chart -->
    <div class="col-lg-6 mb-4" id="demo-scatter-chart">
        <div class="custom-chart-container">
            <div class="chart-header-flex">
                <div class="chart-header-title">
                    <div class="chart-icon"><i class="fa-solid fa-braille"></i></div>
                    Scatter Chart
                </div>
                <button class="btn btn-sm btn-outline-primary copy-btn"><i class="fa-regular fa-copy"></i> Copy HTML</button>
            </div>
            <div class="chart-canvas-wrapper">
                <canvas id="scatterChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Mixed Chart -->
    <div class="col-lg-6 mb-4" id="demo-mixed-chart">
        <div class="custom-chart-container">
            <div class="chart-header-flex">
                <div class="chart-header-title">
                    <div class="chart-icon"><i class="fa-solid fa-chart-column"></i></div>
                    Mixed Chart (Bar & Line)
                </div>
                <button class="btn btn-sm btn-outline-primary copy-btn"><i class="fa-regular fa-copy"></i> Copy HTML</button>
            </div>
            <div class="chart-canvas-wrapper">
