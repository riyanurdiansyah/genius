@{
    ViewData["Title"] = "Chart";
}

@section Styles {
    <style>
        .custom-chart-container {
            padding: 30px;
            background: #fff;
            border-radius: 25px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.01);
            border: 1px solid rgba(0,0,0,0.03);
            margin-bottom: 30px;
            height: 100%;
            display: flex;
            flex-direction: column;
        }

        .chart-header-flex {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
        }

        .chart-header-title {
            font-size: 20px;
            font-weight: 600;
            color: var(--text-dark);
            display: flex;
            align-items: center;
            gap: 15px;
        }
        
        .chart-icon {
            background: var(--green-light);
            color: var(--green-accent);
            width: 45px;
            height: 45px;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 18px;
        }

        .chart-canvas-wrapper {
            position: relative;
            height: 320px;
            width: 100%;
            flex-grow: 1;
        }
    </style>
}

<div class="row">
    <!-- Line Chart -->
    <div class="col-lg-6 mb-4" id="demo-line-chart">
        <div class="custom-chart-container">
            <div class="chart-header-flex">
                <div class="chart-header-title">
                    <div class="chart-icon"><i class="fa-solid fa-chart-line"></i></div>
                    Line Chart
                </div>
                <button class="btn btn-sm btn-outline-primary copy-btn"><i class="fa-regular fa-copy"></i> Copy HTML</button>
            </div>
            <div class="chart-canvas-wrapper">
                <canvas id="lineChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Bar Chart -->
    <div class="col-lg-6 mb-4" id="demo-bar-chart">
        <div class="custom-chart-container">
            <div class="chart-header-flex">
