@{
    ViewData["Title"] = "Apex Charts";
}

@section Styles {
    <style>
        .custom-chart-container {
            padding: 30px;
            background: #fff;
            border-radius: 25px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.01);
            border: 1px solid rgba(0,0,0,0.03);
            margin-bottom: 30px;
            height: 100%;
            display: flex;
            flex-direction: column;
        }

        .chart-header-flex {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
        }

        .chart-header-title {
            font-size: 20px;
            font-weight: 600;
            color: var(--text-dark);
            display: flex;
            align-items: center;
            gap: 15px;
        }
        
        .chart-icon {
            background: var(--green-light);
            color: var(--green-accent);
            width: 45px;
            height: 45px;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 18px;
        }

        .chart-canvas-wrapper {
            position: relative;
            height: 350px;
            width: 100%;
            flex-grow: 1;
        }
        
        /* Custom Apex legend style to match organic theme */
        .apexcharts-legend-text {
            font-family: var(--font-family-primary) !important;
            color: var(--text-gray) !important;
        }
        .apexcharts-tooltip {
            border-radius: 12px !important;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1) !important;
        }
    </style>
}

<div class="row">
    <!-- 1. Smooth Spline Area Chart -->
    <div class="col-lg-6 mb-4">
        <div class="custom-chart-container">
            <div class="chart-header-flex">
                <div class="chart-header-title">
                    <div class="chart-icon"><i class="fa-solid fa-water"></i></div>
                    Spline Area Chart
                </div>
                <button class="btn btn-sm btn-outline-primary copy-btn"><i class="fa-regular fa-copy"></i> Copy HTML</button>
            </div>
            <div class="chart-canvas-wrapper" id="chart-spline"></div>
        </div>
    </div>

    <!-- 2. Column with Data Labels Chart -->
    <div class="col-lg-6 mb-4">
        <div class="custom-chart-container">
            <div class="chart-header-flex">
                <div class="chart-header-title">
                    <div class="chart-icon"><i class="fa-solid fa-chart-simple"></i></div>
                    Column Data Labels
                </div>
                <button class="btn btn-sm btn-outline-primary copy-btn"><i class="fa-regular fa-copy"></i> Copy HTML</button>
            </div>
            <div class="chart-canvas-wrapper" id="chart-column"></div>
        </div>
    </div>

    <!-- 3. Mixed Chart (Line + Column + Area) -->
    <div class="col-lg-12 mb-4">
        <div class="custom-chart-container">
            <div class="chart-header-flex">
                <div class="chart-header-title">
                    <div class="chart-icon"><i class="fa-solid fa-chart-mixed"></i></div>
                    Mixed Multiple Y-Axis
                </div>
                <button class="btn btn-sm btn-outline-primary copy-btn"><i class="fa-regular fa-copy"></i> Copy HTML</button>
            </div>
            <div class="chart-canvas-wrapper" id="chart-mixed"></div>
        </div>
    </div>

    <!-- 4. RadialBar / Gauge Chart -->
    <div class="col-lg-4 mb-4">
        <div class="custom-chart-container">
            <div class="chart-header-flex">
                <div class="chart-header-title">
                    <div class="chart-icon"><i class="fa-solid fa-gauge-high"></i></div>
                    Radial Bar
                </div>
                <button class="btn btn-sm btn-outline-primary copy-btn"><i class="fa-regular fa-copy"></i> Copy HTML</button>
            </div>
            <div class="chart-canvas-wrapper" id="chart-radial"></div>
        </div>
    </div>

    <!-- 5. Heatmap Chart -->
    <div class="col-lg-8 mb-4">
        <div class="custom-chart-container">
            <div class="chart-header-flex">
                <div class="chart-header-title">
                    <div class="chart-icon"><i class="fa-solid fa-border-all"></i></div>
                    Heatmap Chart
                </div>
                <button class="btn btn-sm btn-outline-primary copy-btn"><i class="fa-regular fa-copy"></i> Copy HTML</button>
            </div>
            <div class="chart-canvas-wrapper" id="chart-heatmap"></div>
        </div>
    </div>

    <!-- 6. Candlestick Chart (Finance) -->
    <div class="col-lg-6 mb-4">
        <div class="custom-chart-container">
            <div class="chart-header-flex">
                <div class="chart-header-title">
                    <div class="chart-icon"><i class="fa-solid fa-candlestick-chart"></i></div>
                    Candlestick (Stocks)
                </div>
                <button class="btn btn-sm btn-outline-primary copy-btn"><i class="fa-regular fa-copy"></i> Copy HTML</button>
            </div>
            <div class="chart-canvas-wrapper" id="chart-candlestick"></div>
        </div>
    </div>

    <!-- 7. Timeline Chart -->
    <div class="col-lg-6 mb-4">
        <div class="custom-chart-container">
            <div class="chart-header-flex">
                <div class="chart-header-title">
                    <div class="chart-icon"><i class="fa-solid fa-timeline"></i></div>
                    Timeline Range Bar
                </div>
                <button class="btn btn-sm btn-outline-primary copy-btn"><i class="fa-regular fa-copy"></i> Copy HTML</button>
            </div>
            <div class="chart-canvas-wrapper" id="chart-timeline"></div>
        </div>
    </div>
    
    <!-- 8. Treemap Chart -->
    <div class="col-lg-6 mb-4">
        <div class="custom-chart-container">
            <div class="chart-header-flex">
                <div class="chart-header-title">
                    <div class="chart-icon"><i class="fa-solid fa-table-cells-large"></i></div>
                    Treemap Chart
                </div>
                <button class="btn btn-sm btn-outline-primary copy-btn"><i class="fa-regular fa-copy"></i> Copy HTML</button>
            </div>
            <div class="chart-canvas-wrapper" id="chart-treemap"></div>
        </div>
    </div>

    <!-- 9. Radar Graphic -->
    <div class="col-lg-6 mb-4">
        <div class="custom-chart-container">
            <div class="chart-header-flex">
                <div class="chart-header-title">
                    <div class="chart-icon"><i class="fa-solid fa-satellite-dish"></i></div>
                    Radar Variant
                </div>
                <button class="btn btn-sm btn-outline-primary copy-btn"><i class="fa-regular fa-copy"></i> Copy HTML</button>
            </div>
            <div class="chart-canvas-wrapper" id="chart-radar-apex"></div>
        </div>
    </div>

    <!-- 10. Pie Chart -->
    <div class="col-lg-6 mb-4">
        <div class="custom-chart-container">
            <div class="chart-header-flex">
                <div class="chart-header-title">
                    <div class="chart-icon"><i class="fa-solid fa-chart-pie"></i></div>
                    Pie Chart
                </div>
                <button class="btn btn-sm btn-outline-primary copy-btn"><i class="fa-regular fa-copy"></i> Copy HTML</button>
            </div>
            <div class="chart-canvas-wrapper" id="chart-pie"></div>
        </div>
    </div>

    <!-- 11. Donut Chart -->
    <div class="col-lg-6 mb-4">
        <div class="custom-chart-container">
            <div class="chart-header-flex">
                <div class="chart-header-title">
                    <div class="chart-icon"><i class="fa-solid fa-circle-notch"></i></div>
                    Donut Chart
                </div>
                <button class="btn btn-sm btn-outline-primary copy-btn"><i class="fa-regular fa-copy"></i> Copy HTML</button>
            </div>
            <div class="chart-canvas-wrapper" id="chart-donut"></div>
        </div>
    </div>

    <!-- 12. Bubble Chart -->
    <div class="col-lg-6 mb-4">
        <div class="custom-chart-container">
            <div class="chart-header-flex">
                <div class="chart-header-title">
                    <div class="chart-icon"><i class="fa-solid fa-circle-dot"></i></div>
                    Bubble Chart
                </div>
                <button class="btn btn-sm btn-outline-primary copy-btn"><i class="fa-regular fa-copy"></i> Copy HTML</button>
            </div>
            <div class="chart-canvas-wrapper" id="chart-bubble"></div>
        </div>
    </div>

    <!-- 13. Scatter Chart -->
    <div class="col-lg-6 mb-4">
        <div class="custom-chart-container">
            <div class="chart-header-flex">
                <div class="chart-header-title">
                    <div class="chart-icon"><i class="fa-solid fa-braille"></i></div>
                    Scatter Chart
                </div>
                <button class="btn btn-sm btn-outline-primary copy-btn"><i class="fa-regular fa-copy"></i> Copy HTML</button>
            </div>
            <div class="chart-canvas-wrapper" id="chart-scatter"></div>
        </div>
    </div>

    <!-- 14. Distributed Columns -->
    <div class="col-lg-12 mb-4">
        <div class="custom-chart-container">
            <div class="chart-header-flex">
                <div class="chart-header-title">
                    <div class="chart-icon"><i class="fa-solid fa-chart-bar"></i></div>
                    Distributed Columns
                </div>
                <button class="btn btn-sm btn-outline-primary copy-btn"><i class="fa-regular fa-copy"></i> Copy HTML</button>
            </div>
            <div class="chart-canvas-wrapper" id="chart-distributed"></div>
        </div>
    </div>

</div>



@section Scripts {
    <!-- Include ApexCharts -->
    <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
    
    <script>
        $(document).ready(function() {
            // STEP 1: CACHE RAW HTML FOR COPY BUTTONS
            $('.custom-chart-container').each(function() {
                var btn = $(this).find('.copy-btn');
                if (btn.length) {
                    var containerClone = $(this).clone();
                    // Clean injected SVG by ApexCharts
                    var chartId = containerClone.find('.chart-canvas-wrapper').attr('id');
                    containerClone.find('.chart-canvas-wrapper').empty(); 
                    var rawHtml = containerClone.prop('outerHTML');
                    btn.data('raw-html', rawHtml);
                }
            });

            $('.copy-btn').on('click', function(e) {
                e.preventDefault();
                var rawHtml = $(this).data('raw-html');
                
                // Use the Global Copy HTML Modal from _Layout.cshtml
                document.getElementById('globalCopyHtmlTextarea').value = rawHtml;
                openModal('globalCopyHtmlModal');
            });

            // Theme Colors
            const colorPrimary = '#3b9d82';
            const colorSecondary = '#f5c342';
            const colorDark = '#0B2B26';
            const colorMuted = '#9ca3af';

            // 1. Spline Area Chart
            var splineOptions = {
                series: [{ name: 'Income', data: [31, 40, 28, 51, 42, 109, 100] }, { name: 'Expenses', data: [11, 32, 45, 32, 34, 52, 41] }],
                chart: { height: 350, type: 'area', toolbar: { show: false }, fontFamily: 'var(--font-family-primary)' },
                colors: [colorPrimary, colorSecondary],
                dataLabels: { enabled: false },
                stroke: { curve: 'smooth', width: 2 },
                xaxis: { categories: ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul"] },
                grid: { borderColor: '#f3f4f6', strokeDashArray: 4 }
            };
            new ApexCharts(document.querySelector("#chart-spline"), splineOptions).render();

            // 2. Column Data Labels
            var columnOptions = {
                series: [{ name: 'Net Profit', data: [44, 55, 57, 56, 61, 58, 63] }],
                chart: { type: 'bar', height: 350, toolbar: { show: false }, fontFamily: 'var(--font-family-primary)' },
                plotOptions: { bar: { borderRadius: 6, dataLabels: { position: 'top' } } },
                dataLabels: { enabled: true, formatter: function (val) { return val + "%"; }, offsetY: -20, style: { fontSize: '12px', colors: [colorDark] } },
                colors: [colorPrimary],
                xaxis: { categories: ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul"] },
                grid: { borderColor: '#f3f4f6' }
            };
            new ApexCharts(document.querySelector("#chart-column"), columnOptions).render();

            // 3. Mixed Chart
            var mixedOptions = {
                series: [{ name: 'Income', type: 'column', data: [1.4, 2, 2.5, 1.5, 2.5, 2.8, 3.8] }, { name: 'Cashflow', type: 'column', data: [1.1, 3, 3.1, 4, 4.1, 4.9, 6.5] }, { name: 'Revenue', type: 'line', data: [20, 29, 37, 36, 44, 45, 50] }],
                chart: { height: 350, type: 'line', toolbar: { show: false }, fontFamily: 'var(--font-family-primary)' },
                colors: [colorPrimary, colorSecondary, colorDark],
                stroke: { width: [0, 0, 4] },
                title: { text: 'Traffic Sources', align: 'left', style: { color: colorMuted } },
                xaxis: { categories: [2009, 2010, 2011, 2012, 2013, 2014, 2015] },
                yaxis: [{ title: { text: 'Income' } }, { title: { text: 'Cashflow' } }, { opposite: true, title: { text: 'Revenue' } }]
            };
            new ApexCharts(document.querySelector("#chart-mixed"), mixedOptions).render();

            // 4. RadialBar Chart
            var radialOptions = {
                series: [76, 67, 61],
                chart: { height: 350, type: 'radialBar', fontFamily: 'var(--font-family-primary)' },
                plotOptions: {
                    radialBar: {
                        dataLabels: { name: { fontSize: '22px', }, value: { fontSize: '16px', }, total: { show: true, label: 'Total', formatter: function () { return 204 } } }
                    }
                },
                labels: ['Apples', 'Oranges', 'Bananas'],
                colors: [colorPrimary, colorSecondary, colorDark]
            };
            new ApexCharts(document.querySelector("#chart-radial"), radialOptions).render();

            // 5. Heatmap
            function generateData(count, yrange) {
                var i = 0, series = [];
                while (i < count) { series.push({ x: 'W' + (i+1).toString(), y: Math.floor(Math.random() * (yrange.max - yrange.min + 1)) + yrange.min }); i++; }
                return series;
            }
            var heatmapOptions = {
                series: [
                    { name: 'Metric1', data: generateData(9, { min: 0, max: 90 }) },
                    { name: 'Metric2', data: generateData(9, { min: 0, max: 90 }) },
                    { name: 'Metric3', data: generateData(9, { min: 0, max: 90 }) }
                ],
                chart: { height: 350, type: 'heatmap', toolbar: { show: false }, fontFamily: 'var(--font-family-primary)' },
                colors: [colorPrimary]
            };
            new ApexCharts(document.querySelector("#chart-heatmap"), heatmapOptions).render();

            // 6. Candlestick
            var candlestickOptions = {
                series: [{
                    data: [
                        { x: new Date(1538778600000), y: [6629.81, 6650.5, 6623.04, 6633.33] },
                        { x: new Date(1538780400000), y: [6632.01, 6643.59, 6620, 6630.11] },
                        { x: new Date(1538782200000), y: [6630.71, 6648.95, 6623.34, 6635.65] },
                        { x: new Date(1538784000000), y: [6635.65, 6651, 6629.67, 6638.24] },
                        { x: new Date(1538785800000), y: [6638.24, 6640, 6620, 6624.47] }
                    ]
                }],
                chart: { type: 'candlestick', height: 350, toolbar: { show: false }, fontFamily: 'var(--font-family-primary)' },
                plotOptions: { candlestick: { colors: { upward: colorPrimary, downward: colorSecondary } } },
                xaxis: { type: 'datetime' }
            };
            new ApexCharts(document.querySelector("#chart-candlestick"), candlestickOptions).render();

            // 7. Timeline (Range Bar)
            var timelineOptions = {
                series: [{
                    data: [
                        { x: 'Code', y: [new Date('2019-02-27').getTime(), new Date('2019-03-04').getTime()] },
                        { x: 'Test', y: [new Date('2019-03-04').getTime(), new Date('2019-03-08').getTime()] },
                        { x: 'Validation', y: [new Date('2019-03-08').getTime(), new Date('2019-03-12').getTime()] },
                        { x: 'Deployment', y: [new Date('2019-03-12').getTime(), new Date('2019-03-18').getTime()] }
                    ]
                }],
                chart: { height: 350, type: 'rangeBar', toolbar: { show: false }, fontFamily: 'var(--font-family-primary)' },
                plotOptions: { bar: { horizontal: true, borderRadius: 4 } },
                colors: [colorPrimary],
                xaxis: { type: 'datetime' }
            };
            new ApexCharts(document.querySelector("#chart-timeline"), timelineOptions).render();

            // 8. Treemap
            var treemapOptions = {
                series: [{
                    data: [{ x: 'New Delhi', y: 218 }, { x: 'Kolkata', y: 149 }, { x: 'Mumbai', y: 184 }, { x: 'Ahmedabad', y: 55 }, { x: 'Bangaluru', y: 84 }, { x: 'Pune', y: 31 }, { x: 'Chennai', y: 70 }, { x: 'Jaipur', y: 30 }, { x: 'Surat', y: 44 }]
                }],
                chart: { type: 'treemap', height: 350, toolbar: { show: false }, fontFamily: 'var(--font-family-primary)' },
                colors: [colorPrimary, colorSecondary, colorDark]
            };
            new ApexCharts(document.querySelector("#chart-treemap"), treemapOptions).render();

            // 9. Radar Graphic
            var radarOptions = {
                series: [{ name: 'Series 1', data: [80, 50, 30, 40, 100, 20] }, { name: 'Series 2', data: [20, 30, 40, 80, 20, 80] }],
                chart: { height: 350, type: 'radar', dropShadow: { enabled: true, blur: 1, left: 1, top: 1 }, fontFamily: 'var(--font-family-primary)' },
                stroke: { width: 2 },
                fill: { opacity: 0.1 },
                markers: { size: 0 },
                xaxis: { categories: ['2011', '2012', '2013', '2014', '2015', '2016'] },
                colors: [colorPrimary, colorSecondary]
            };
            new ApexCharts(document.querySelector("#chart-radar-apex"), radarOptions).render();

            // 10. Pie Chart
            var pieOptions = {
                series: [44, 55, 13, 43],
                chart: { width: 380, type: 'pie', fontFamily: 'var(--font-family-primary)' },
                labels: ['Team A', 'Team B', 'Team C', 'Team D'],
                colors: [colorPrimary, colorSecondary, colorDark, '#0dcaf0'],
                responsive: [{ breakpoint: 480, options: { chart: { width: 200 }, legend: { position: 'bottom' } } }]
            };
            new ApexCharts(document.querySelector("#chart-pie"), pieOptions).render();

            // 11. Donut Chart
            var donutOptions = {
                series: [44, 55, 41, 17, 15],
                chart: { type: 'donut', height: 350, fontFamily: 'var(--font-family-primary)' },
                colors: [colorPrimary, colorSecondary, colorDark, '#0dcaf0', '#dc3545'],
                plotOptions: { donut: { size: '65%' } },
                labels: ['Electronics', 'Clothing', 'Grocery', 'Sports', 'Other'],
            };
            new ApexCharts(document.querySelector("#chart-donut"), donutOptions).render();

            // 12. Bubble Chart
            function generateBubbleData(baseval, count, yrange) {
                var i = 0, series = [];
                while (i < count) {
                    var x = Math.floor(Math.random() * (750 - 1 + 1)) + 1;
                    var y = Math.floor(Math.random() * (yrange.max - yrange.min + 1)) + yrange.min;
                    var z = Math.floor(Math.random() * (75 - 15 + 1)) + 15;
                    series.push([x, y, z]);
                    baseval += 86400000;
                    i++;
                }
                return series;
            }
            var bubbleOptions = {
                series: [{ name: 'Bubble1', data: generateBubbleData(new Date('11 Feb 2017 GMT').getTime(), 20, { min: 10, max: 60 }) }, { name: 'Bubble2', data: generateBubbleData(new Date('11 Feb 2017 GMT').getTime(), 20, { min: 10, max: 60 }) }],
                chart: { height: 350, type: 'bubble', toolbar: { show: false }, fontFamily: 'var(--font-family-primary)' },
                dataLabels: { enabled: false },
                fill: { opacity: 0.8 },
                colors: [colorPrimary, colorSecondary],
                xaxis: { tickAmount: 12, type: 'category' }
            };
            new ApexCharts(document.querySelector("#chart-bubble"), bubbleOptions).render();

            // 13. Scatter Chart
            var scatterOptions = {
                series: [{ name: "Sample A", data: [[16.4, 5.4], [21.7, 2], [25.4, 3], [19, 2], [10.9, 1], [13.6, 3.2], [10.9, 7.4], [10.9, 0], [10.9, 8.2], [16.4, 0], [16.4, 1.8], [13.6, 0.3], [13.6, 0], [29.9, 0], [27.1, 2.3], [16.4, 0], [13.6, 3.7], [10.9, 5.2], [16.4, 6.5], [10.9, 0], [24.5, 7.1], [10.9, 0], [8.1, 4.7], [19, 0], [21.7, 1.8], [27.1, 0], [24.5, 0], [27.1, 0], [29.9, 1.5], [27.1, 0.8], [22.1, 2]] }, { name: "Sample B", data: [[36.4, 13.4], [1.7, 11], [5.4, 8], [9, 17], [1.9, 4], [3.6, 12.2], [1.9, 14.4], [1.9, 9], [1.9, 13.2], [1.4, 7], [6.4, 8.8], [3.6, 4.3], [1.6, 10], [9.9, 2], [7.1, 15], [1.4, 0], [3.6, 13.7], [1.9, 15.2], [6.4, 16.5], [0.9, 10], [4.5, 17.1], [10.9, 10], [0.1, 14.7], [9, 10], [12.7, 11.8], [2.1, 10], [2.5, 10], [27.1, 10], [2.9, 11.5], [7.1, 10.8], [2.1, 12]] }],
                chart: { height: 350, type: 'scatter', zoom: { enabled: true, type: 'xy' }, toolbar: { show: false }, fontFamily: 'var(--font-family-primary)' },
                colors: [colorPrimary, colorSecondary],
                xaxis: { tickAmount: 10, labels: { formatter: function(val) { return parseFloat(val).toFixed(1) } } },
                yaxis: { tickAmount: 7 }
            };
            new ApexCharts(document.querySelector("#chart-scatter"), scatterOptions).render();

            // 14. Distributed Columns
            var distColumnOptions = {
                series: [{ data: [21, 22, 10, 28, 16, 21, 13, 30] }],
                chart: { height: 350, type: 'bar', toolbar: { show: false }, events: { click: function(chart, w, e) {} }, fontFamily: 'var(--font-family-primary)' },
                colors: [colorPrimary, colorSecondary, colorDark, '#0dcaf0', '#dc3545', '#ffc107', '#6c757d', '#343a40'],
                plotOptions: { bar: { columnWidth: '45%', distributed: true, borderRadius: 6 } },
                dataLabels: { enabled: false },
                legend: { show: false },
                xaxis: { categories: [['John', 'Doe'], ['Joe', 'Smith'], ['Jake', 'Williams'], 'Amber', ['Peter', 'Brown'], ['Mary', 'Evans'], ['David', 'Wilson'], ['Lily', 'Roberts']], labels: { style: { colors: [colorPrimary, colorSecondary, colorDark, '#0dcaf0', '#dc3545', '#ffc107', '#6c757d', '#343a40'], fontSize: '12px' } } }
            };
            new ApexCharts(document.querySelector("#chart-distributed"), distColumnOptions).render();

        });
    </script>
}
