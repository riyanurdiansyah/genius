@{
    ViewData["Title"] = "Editors";
}

@section Styles {
    <style>
        .editor-card { margin-bottom: 25px; }

        /* Rich Text Editor Mockup */
        .editor-wrapper {
            border: 1px solid #cbd5e1;
            border-radius: var(--radius-md);
            overflow: hidden;
            background: #fff;
        }
        .editor-toolbar {
            display: flex;
            flex-wrap: wrap;
            gap: 2px;
            padding: 8px;
            background: #f8fafc;
            border-bottom: 1px solid #cbd5e1;
            align-items: center;
        }
        .editor-btn {
            background: transparent;
            border: none;
            width: 32px;
            height: 32px;
            border-radius: 4px;
            color: var(--text-dark);
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: background 0.2s;
        }
        .editor-btn:hover { background: #e2e8f0; }
        .editor-btn.active { background: #cbd5e1; color: var(--primary-color); }
        .editor-separator {
            width: 1px;
            height: 20px;
            background: #cbd5e1;
            margin: 0 8px;
        }
        .editor-content {
            padding: 20px;
            min-height: 250px;
            outline: none;
            color: var(--text-dark);
        }

        /* Syntax Highlighter / Code block mockup */
        .code-mockup {
            background: #1e293b;
            color: #f8fafc;
            padding: 15px;
            border-radius: var(--radius-md);
            font-family: monospace;
            line-height: 1.6;
        }
        .code-comment { color: #64748b; }
        .code-keyword { color: #c678dd; }
        .code-string { color: #98c379; }
        .code-func { color: #61afef; }
    </style>
}

<div class="row">
    <!-- 1. Rich Text Editor WYSIWYG -->
    <div class="col-lg-12 mb-4">
        <div class="card editor-card">
            <div class="card-header d-flex justify-content-between align-items-center bg-white border-bottom">
                <h6 class="m-0 font-weight-bold">Classic WYSIWYG Editor Mockup</h6>
                <button class="btn btn-sm btn-outline-primary copy-btn" data-target="wysiwyg-ui"><i class="fa-regular fa-copy"></i> Copy HTML</button>
            </div>
            <div class="card-body" id="wysiwyg-ui">
                <label class="form-label">Article Body</label>
                <div class="editor-wrapper">
                    <div class="editor-toolbar">
                        <!-- Headings -->
                        <select class="form-select form-select-sm" style="width: 130px; margin-right: 8px;">
                            <option>Paragraph</option>
                            <option>Heading 1</option>
                            <option>Heading 2</option>
                            <option>Heading 3</option>
                        </select>
                        <div class="editor-separator"></div>
                        <!-- Formatting -->
                        <button class="editor-btn active" title="Bold"><i class="fa-solid fa-bold"></i></button>
                        <button class="editor-btn" title="Italic"><i class="fa-solid fa-italic"></i></button>
                        <button class="editor-btn" title="Underline"><i class="fa-solid fa-underline"></i></button>
                        <button class="editor-btn" title="Strikethrough"><i class="fa-solid fa-strikethrough"></i></button>
                        <div class="editor-separator"></div>
                        <!-- Lists & Alignment -->
                        <button class="editor-btn" title="Unordered List"><i class="fa-solid fa-list-ul"></i></button>
                        <button class="editor-btn" title="Ordered List"><i class="fa-solid fa-list-ol"></i></button>
                        <div class="editor-separator"></div>
                        <button class="editor-btn active" title="Align Left"><i class="fa-solid fa-align-left"></i></button>
                        <button class="editor-btn" title="Align Center"><i class="fa-solid fa-align-center"></i></button>
                        <button class="editor-btn" title="Align Right"><i class="fa-solid fa-align-right"></i></button>
                        <button class="editor-btn" title="Justify"><i class="fa-solid fa-align-justify"></i></button>
                        <div class="editor-separator"></div>
                        <!-- Links & Insert -->
                        <button class="editor-btn" title="Link"><i class="fa-solid fa-link"></i></button>
                        <button class="editor-btn" title="Image"><i class="fa-regular fa-image"></i></button>
                        <button class="editor-btn" title="Code"><i class="fa-solid fa-code"></i></button>
                    </div>
                    <div class="editor-content" contenteditable="true">
                        <h4>Welcome to the WYSIWYG Editor</h4>
                        <p>This is a <strong>simulated rich text editor</strong> interface. You can click inside this area and start typing just like a real textarea. In a real environment, you would use libraries like <em>Tinymce, Quill.js, or CKEditor</em>.</p>
                        <ul>
                            <li>Fully customizable toolbar</li>
                            <li>Responsive design</li>
                            <li>Clean HTML output</li>
                        </ul>
                        <p>Start writing your amazing content here...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 2. Code / Markdown Editor -->
    <div class="col-lg-12 mb-4">
        <div class="card editor-card">
            <div class="card-header d-flex justify-content-between align-items-center bg-white border-bottom">
                <h6 class="m-0 font-weight-bold">Markdown & Code Editor Appearance</h6>
                <button class="btn btn-sm btn-outline-primary copy-btn" data-target="code-ui"><i class="fa-regular fa-copy"></i> Copy HTML</button>
            </div>
            <div class="card-body" id="code-ui">
                <div class="d-flex justify-content-between mb-2">
                    <label class="form-label m-0">README.md</label>
                    <span class="badge bg-secondary">Markdown</span>
                </div>
                <!-- Mockup of a Markdown Editor with split view idea -->
                <div class="row g-0 border rounded overflow-hidden" style="border-color: #cbd5e1 !important;">
                    <div class="col-md-6 border-end" style="border-color: #cbd5e1 !important;">
                        <div class="bg-light p-2 border-bottom d-flex gap-2" style="border-color: #cbd5e1 !important;">
                            <button class="editor-btn"><i class="fa-solid fa-heading"></i></button>
                            <button class="editor-btn"><i class="fa-solid fa-bold"></i></button>
                            <button class="editor-btn"><i class="fa-solid fa-list-ul"></i></button>
                            <button class="editor-btn"><i class="fa-regular fa-image"></i></button>
                        </div>
                        <textarea class="form-control border-0 rounded-0" style="min-height: 250px; resize: none; background: #fff;" placeholder="Type markdown here..."># Project Title

A brief description of what this project does and who it's for.

## Installation 

```bash
npm install my-project
```

## Features
- Fast and reliable
- Secure
- Responsive</textarea>
                    </div>
                    <div class="col-md-6 bg-white p-4">
                        <h1 class="fw-bold fs-3">Project Title</h1>
                        <p>A brief description of what this project does and who it's for.</p>
                        <h2 class="fw-bold fs-4 mt-4 border-bottom pb-2">Installation</h2>
                        <div class="code-mockup mt-2 py-2 px-3">
                            <span class="code-func">npm</span> install my-project
                        </div>
                        <h2 class="fw-bold fs-4 mt-4 border-bottom pb-2">Features</h2>
                        <ul>
                            <li>Fast and reliable</li>
                            <li>Secure</li>
                            <li>Responsive</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            
            // Editor toolbar button toggle effect
            document.querySelectorAll('.editor-btn').forEach(btn => {
                btn.addEventListener('click', function(e) {
                    if(this.tagName !== 'SELECT') {
                        e.preventDefault();
                        this.classList.toggle('active');
                    }
                });
            });
        });
    </script>
}
