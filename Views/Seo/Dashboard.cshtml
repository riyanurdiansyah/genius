@{ ViewData["Title"] = "SEO Analytics"; }

@section Styles {
    <style>
        .seo-card {
            border: none;
            border-radius: var(--radius-md);
            box-shadow: 0 4px 15px rgba(0,0,0,0.03);
            background: #fff;
            height: 100%;
            transition: transform 0.3s;
        }
        .seo-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.05);
        }
        .seo-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
        }
        .seo-score {
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--color-1);
        }
        .text-success-alt { color: #10b981; }
        .text-danger-alt { color: #ef4444; }
        .bg-success-subtle { background: #d1fae5; color: #065f46; }
        .bg-warning-subtle { background: #fef3c7; color: #92400e; }
        .bg-primary-subtle { background: #e0e7ff; color: #3730a3; }
        .bg-info-subtle { background: #e0f2fe; color: #0369a1; }
        
        .progress-slim {
            height: 6px;
            border-radius: 3px;
            background: #f1f5f9;
        }
    </style>
}

<!-- Summary Widgets -->
<div class="row g-4 mb-4">
    <div class="col-md-3 col-sm-6">
        <div class="card seo-card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="text-muted fw-bold mb-0 text-uppercase" style="letter-spacing: 0.5px;">Organic Traffic</h6>
                    <div class="seo-icon bg-success-subtle"><i class="fas fa-users"></i></div>
                </div>
                <div class="seo-score">124.5K</div>
                <p class="mb-0 text-sm mt-2">
                    <span class="text-success-alt fw-bold"><i class="fas fa-arrow-up me-1"></i> 14.2%</span>
                    <span class="text-muted">vs last month</span>
                </p>
            </div>
        </div>
    </div>
    
    <div class="col-md-3 col-sm-6">
        <div class="card seo-card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="text-muted fw-bold mb-0 text-uppercase" style="letter-spacing: 0.5px;">Avg. Position</h6>
                    <div class="seo-icon bg-primary-subtle"><i class="fas fa-sort-amount-up"></i></div>
                </div>
                <div class="seo-score">11.4</div>
                <p class="mb-0 text-sm mt-2">
                    <span class="text-success-alt fw-bold"><i class="fas fa-arrow-up me-1"></i> 2.1</span>
                    <span class="text-muted">positions up</span>
                </p>
            </div>
        </div>
    </div>
    
    <div class="col-md-3 col-sm-6">
        <div class="card seo-card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="text-muted fw-bold mb-0 text-uppercase" style="letter-spacing: 0.5px;">Domain Rating</h6>
                    <div class="seo-icon bg-warning-subtle"><i class="fas fa-crown"></i></div>
                </div>
                <div class="seo-score">68<span class="fs-4 text-muted">/100</span></div>
                <p class="mb-0 text-sm mt-2">
                    <span class="text-muted fw-bold"><i class="fas fa-minus me-1"></i> 0.0%</span>
                    <span class="text-muted">No change</span>
                </p>
            </div>
        </div>
    </div>
    
    <div class="col-md-3 col-sm-6">
        <div class="card seo-card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="text-muted fw-bold mb-0 text-uppercase" style="letter-spacing: 0.5px;">Total Backlinks</h6>
                    <div class="seo-icon bg-info-subtle"><i class="fas fa-link"></i></div>
                </div>
                <div class="seo-score">45.2K</div>
                <p class="mb-0 text-sm mt-2">
                    <span class="text-danger-alt fw-bold"><i class="fas fa-arrow-down me-1"></i> 112</span>
                    <span class="text-muted">lost links</span>
                </p>
            </div>
        </div>
    </div>
</div>

<!-- Charts Section -->
<div class="row g-4 mb-4">
    <div class="col-lg-8">
        <div class="card seo-card">
            <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                <h5 class="fw-bold mb-0">Organic Traffic Overview</h5>
                <select class="form-select form-select-sm w-auto shadow-none border-0 bg-light fw-bold text-muted">
                    <option>Last 30 Days</option>
                    <option>Last 3 Months</option>
                    <option>This Year</option>
                </select>
            </div>
            <div class="card-body px-4">
                <div id="trafficChart" style="height: 320px;"></div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card seo-card">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <h5 class="fw-bold mb-0">Top Performing Keywords</h5>
            </div>
            <div class="card-body px-4">
                <div class="d-flex justify-content-between mb-2 mt-2">
                    <span class="fw-bold">"dashboard template"</span>
                    <span class="text-success-alt fw-bold"><i class="fas fa-caret-up"></i> #1</span>
                </div>
                <div class="progress progress-slim mb-4">
                    <div class="progress-bar bg-primary" style="width: 95%"></div>
                </div>

                <div class="d-flex justify-content-between mb-2">
                    <span class="fw-bold">"admin panel ui"</span>
                    <span class="text-success-alt fw-bold"><i class="fas fa-caret-up"></i> #3</span>
                </div>
                <div class="progress progress-slim mb-4">
                    <div class="progress-bar bg-info" style="width: 82%"></div>
                </div>

                <div class="d-flex justify-content-between mb-2">
                    <span class="fw-bold">"bootstrap 5 admin"</span>
                    <span class="text-muted fw-bold"><i class="fas fa-minus"></i> #5</span>
                </div>
                <div class="progress progress-slim mb-4">
                    <div class="progress-bar bg-warning" style="width: 65%"></div>
                </div>

                <div class="d-flex justify-content-between mb-2">
                    <span class="fw-bold">"react dashboard ui"</span>
                    <span class="text-danger-alt fw-bold"><i class="fas fa-caret-down"></i> #12</span>
                </div>
                <div class="progress progress-slim mb-4">
                    <div class="progress-bar bg-danger" style="width: 45%"></div>
                </div>
                
                <div class="d-flex justify-content-between mb-2">
                    <span class="fw-bold">"web analytics tool"</span>
                    <span class="text-success-alt fw-bold"><i class="fas fa-caret-up"></i> #18</span>
                </div>
                <div class="progress progress-slim mb-3">
                    <div class="progress-bar bg-success" style="width: 25%"></div>
                </div>
                
                <button class="btn btn-light w-100 fw-bold mt-2 text-primary">View All Keywords</button>
            </div>
        </div>
    </div>
</div>

<!-- Pages Health Table -->
<div class="card seo-card">
    <div class="card-header bg-white border-0 pt-4 px-4 pb-0 d-flex justify-content-between align-items-center">
        <h5 class="fw-bold mb-0">Pages SEO Health Check</h5>
        <button class="btn btn-primary btn-sm rounded-pill px-3 shadow-sm fw-bold"><i class="fas fa-sync-alt me-2"></i>Run Audit</button>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="border-0 rounded-start">Page URL</th>
                        <th class="border-0">Title Length</th>
                        <th class="border-0">Word Count</th>
                        <th class="border-0">Load Time</th>
                        <th class="border-0">Issues</th>
                        <th class="border-0 rounded-end">On-Page Score</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>
                            <a href="#" class="fw-bold text-dark text-decoration-none d-block">/</a>
                            <small class="text-muted">Home Page</small>
                        </td>
                        <td><span class="badge bg-success-subtle text-success border border-success border-opacity-25 shadow-none pb-1">Good (58 chars)</span></td>
                        <td>1,245</td>
                        <td><span class="fw-bold text-success-alt">0.8s</span></td>
                        <td><span class="badge bg-light text-dark shadow-none pb-1"><i class="fas fa-check text-success me-1"></i>0</span></td>
                        <td>
                            <div class="d-flex align-items-center">
                                <span class="me-2 fw-bold text-success">98</span>
                                <div class="progress progress-slim flex-grow-1">
                                    <div class="progress-bar bg-success" style="width: 98%"></div>
                                </div>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <a href="#" class="fw-bold text-dark text-decoration-none d-block">/products</a>
                            <small class="text-muted">Product Catalog</small>
                        </td>
                        <td><span class="badge bg-warning-subtle text-warning border border-warning border-opacity-25 shadow-none pb-1">Short (22 chars)</span></td>
                        <td>8,950</td>
                        <td><span class="fw-bold text-warning">2.4s</span></td>
                        <td><span class="badge bg-light text-warning shadow-none pb-1" style="color:#d97706!important"><i class="fas fa-exclamation-triangle me-1"></i>3</span></td>
                        <td>
                            <div class="d-flex align-items-center">
                                <span class="me-2 fw-bold text-warning">76</span>
                                <div class="progress progress-slim flex-grow-1">
                                    <div class="progress-bar bg-warning" style="width: 76%"></div>
                                </div>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <a href="#" class="fw-bold text-dark text-decoration-none d-block">/blog/top-ui-trends-2026</a>
                            <small class="text-muted">Blog Post</small>
                        </td>
                        <td><span class="badge bg-success-subtle text-success border border-success border-opacity-25 shadow-none pb-1">Good (45 chars)</span></td>
                        <td>2,100</td>
                        <td><span class="fw-bold text-success-alt">1.2s</span></td>
                        <td><span class="badge bg-light text-dark shadow-none pb-1"><i class="fas fa-check text-success me-1"></i>0</span></td>
                        <td>
                            <div class="d-flex align-items-center">
                                <span class="me-2 fw-bold text-success">92</span>
                                <div class="progress progress-slim flex-grow-1">
                                    <div class="progress-bar bg-success" style="width: 92%"></div>
                                </div>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <a href="#" class="fw-bold text-dark text-decoration-none d-block">/about-us</a>
                            <small class="text-muted">Company Info</small>
                        </td>
                        <td><span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 shadow-none pb-1">Too Long (75 chars)</span></td>
                        <td>450</td>
                        <td><span class="fw-bold text-danger-alt">4.1s</span></td>
                        <td><span class="badge bg-light text-danger shadow-none pb-1"><i class="fas fa-times-circle me-1"></i>8</span></td>
                        <td>
                            <div class="d-flex align-items-center">
                                <span class="me-2 fw-bold text-danger">45</span>
                                <div class="progress progress-slim flex-grow-1">
                                    <div class="progress-bar bg-danger" style="width: 45%"></div>
                                </div>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            var options = {
                series: [{
                    name: 'Organic Traffic',
                    data: [31000, 40000, 28000, 51000, 42000, 109000, 100000, 124500]
                }, {
                    name: 'Paid Traffic',
                    data: [11000, 32000, 45000, 32000, 34000, 52000, 41000, 58000]
                }],
                chart: {
                    height: 320,
                    type: 'area',
                    toolbar: { show: false },
                    fontFamily: 'inherit'
                },
                colors: ['#3b9d82', '#0dcaf0'],
                dataLabels: { enabled: false },
                stroke: {
                    curve: 'smooth',
                    width: 3
                },
                fill: {
                    type: 'gradient',
                    gradient: {
                        shadeIntensity: 1,
                        opacityFrom: 0.4,
                        opacityTo: 0.05,
                        stops: [0, 90, 100]
                    }
                },
                xaxis: {
                    categories: ['Aug', 'Sep', 'Oct', 'Nov', 'Dec', 'Jan', 'Feb', 'Mar'],
                    axisBorder: { show: false },
                    axisTicks: { show: false }
                },
                yaxis: {
                    labels: {
                        formatter: function(val) { return (val / 1000).toFixed(0) + "k"; }
                    }
                },
                grid: {
                    borderColor: '#f1f5f9',
                    strokeDashArray: 4,
                },
                legend: {
                    position: 'top',
                    horizontalAlign: 'right'
                }
            };

            var chart = new ApexCharts(document.querySelector("#trafficChart"), options);
            chart.render();
        });
    </script>
}
