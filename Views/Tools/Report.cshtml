@{
    ViewData["Title"] = "Report Generator";
}

<link rel="stylesheet" href="/css/report.css" />

<!-- DataTables CSS for QA Format -->
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">

<div class="report-page">
    <div class="report-toolbar">
        <div class="report-toolbar-left">
            <i class="fas fa-file-pdf" style="font-size:22px;color:#3b9d82;"></i>
            <h5>Report Generator</h5>
        </div>
        <div class="design-pills">
            <div class="design-pill active" onclick="switchDesign('qa',this)">General</div>
        </div>
        <div>
            <button class="btn btn-outline-secondary me-1" onclick="printReport()"><i class="fas fa-print me-1"></i> Print</button>
            <button class="btn btn-primary" onclick="downloadPDF()"><i class="fas fa-download me-1"></i> Download PDF</button>
        </div>
    </div>

    <div class="report-preview-area">
        <!-- The paper wrapper -->
        <div id="reportPaperWrapper">
            <!-- Content will be injected here -->
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

<script>
    let currentDesign = 'qa';

    function switchDesign(d, el) {
        currentDesign = d;
        document.querySelectorAll('.design-pill').forEach(p => p.classList.remove('active'));
        el.classList.add('active');
        renderReport();
    }

    const reportData = {
        company: "PT Kuda Technology",
        companySub: "INNOVATIVE SOLUTIONS",
        addressLine1: "Jl. Sudirman No. 123, Jakarta 10220",
        addressLine2: "Tel: (021) 5555-1234 | Fax: (021) 5555-1235",
        website: "www.kudatech.co.id",
        title: "Laporan Penjualan Bulanan",
        subtitle: "Periode: 1 Maret 2026 — 31 Maret 2026",
        refNo: "RPT-2026-003"
    };

    function getQaBodyHtml() {
        return `
            <div style="font-size: 11px; margin-bottom: 20px;">
                <p><strong>Nama Panelis:</strong> ______________________ &nbsp;&nbsp;&nbsp;&nbsp; <strong>Tanggal:</strong> ______________________</p>
                <p><strong>Tujuan Uji:</strong> Terdapatnya tiga sampel produk. Dua sampel adalah sama dan satu sampel adalah berbeda. Silakan uji sampel secara berurutan dan lingkarilah kode sampel yang rasanya/profilnya berbeda.</p>
            </div>
            
            <table id="qaDataTable" class="display table cell-border" style="width:100%; font-size: 11px;">
                <thead>
                    <tr>
                        <th style="width: 50px;">No.</th>
                        <th>Kode Sampel A</th>
                        <th>Kode Sampel B</th>
                        <th>Kode Sampel C</th>
                        <th>Komentar Panelis / Deskripsi Perbedaan</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td>1</td><td>412</td><td>689</td><td>412</td><td></td></tr>
                    <tr><td>2</td><td>331</td><td>331</td><td>890</td><td></td></tr>
                    <tr><td>3</td><td>745</td><td>123</td><td>123</td><td></td></tr>
                    <tr><td>4</td><td>999</td><td>554</td><td>999</td><td></td></tr>
                    <tr><td>5</td><td>222</td><td>222</td><td>444</td><td></td></tr>
                    <tr><td>6</td><td>876</td><td>876</td><td>391</td><td></td></tr>
                    <tr><td>7</td><td>404</td><td>200</td><td>404</td><td></td></tr>
                    <tr><td>8</td><td>711</td><td>822</td><td>822</td><td></td></tr>
                    <tr><td>9</td><td>303</td><td>303</td><td>101</td><td></td></tr>
                    <tr><td>10</td><td>900</td><td>450</td><td>450</td><td></td></tr>
                </tbody>
            </table>

            <div class="rpt-note" style="margin-top:20px;">* Harap kembalikan formulir kepada QC Dept setelah diisi.</div>
            
            <div class="rpt-signatures-row" style="margin-top: 40px;">
                <div class="rpt-sig-col"><div class="rpt-sig-line"></div><div class="rpt-sig-name">QC Inspector</div></div>
                <div class="rpt-sig-col"><div class="rpt-sig-line"></div><div class="rpt-sig-name">QA Manager</div></div>
            </div>`;
    }

    function renderReport() {
        const wrapper = document.getElementById('reportPaperWrapper');
        
        // Single default format ("General" / qa format)
        let html = `
            <div class="report-paper design-qa" id="actualPaperContent">
                <div class="qa-document-box">
                    <table class="rpt-qa-header">
                        <tr>
                            <td class="qa-logo-cell">
                                <img src="/image/kn.jpg" alt="Kalbe Nutritionals" />
                            </td>
                            <td class="qa-title-cell" rowspan="3">
                                UJI SEGITIGA<br/>(TRIANGLE TEST)
                            </td>
                        </tr>
                        <tr>
                            <td class="qa-meta-cell">Doc No &nbsp;: SHP-FRM-QACC-01</td>
                        </tr>
                        <tr>
                            <td class="qa-meta-cell">Revision : 02</td>
                        </tr>
                    </table>
                    <div class="qa-header-divider"></div>
                    <div class="rpt-body qa-body-content">${getQaBodyHtml()}</div>
                </div>
            </div>`;

        wrapper.innerHTML = html;

        // Initialize DataTable since only General/QA mode remains
        if ($.fn.DataTable.isDataTable('#qaDataTable')) {
            $('#qaDataTable').DataTable().destroy();
        }
        $('#qaDataTable').DataTable({
            paging: false,
            searching: false,
            info: false,
            ordering: false,
            lengthChange: false
        });
    }

    function printReport() {
        window.print();
    }

    function downloadPDF() {
        const el = document.getElementById('actualPaperContent');
        const opt = {
            margin: 0,
            image: { type: 'jpeg', quality: 0.98 },
            html2canvas: { scale: 2, useCORS: true, logging: false, scrollY: 0 },
            jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
        };
        const safeName = 'Laporan_Penjualan_Maret_2026.pdf';
        html2pdf().set(opt).from(el).save(safeName);
    }

    document.addEventListener('DOMContentLoaded', renderReport);
</script>
