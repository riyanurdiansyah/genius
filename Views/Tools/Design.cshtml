        'list-group': `<ul class="list-group mb-3"><li class="list-group-item d-flex justify-content-between align-items-center" contenteditable="true">List Item One<span class="badge bg-primary rounded-pill">14</span></li><li class="list-group-item d-flex justify-content-between align-items-center" contenteditable="true">List Item Two<span class="badge bg-success rounded-pill">9</span></li><li class="list-group-item d-flex justify-content-between align-items-center" contenteditable="true">List Item Three<span class="badge bg-warning text-dark rounded-pill">3</span></li><li class="list-group-item d-flex justify-content-between align-items-center" contenteditable="true">List Item Four<span class="badge bg-secondary rounded-pill">0</span></li></ul>`,
        'tooltip-demo': `<div class="d-flex flex-wrap gap-2 mb-3 align-items-center"><button class="btn btn-secondary" title="This is a tooltip">Hover Tooltip</button><button class="btn btn-info text-white" data-bs-toggle="popover" title="Popover Title" data-bs-content="This is popover content. More detail here.">Click Popover</button><small class="text-muted">Tooltips & popovers appear on hover/click</small></div>`,

        /* ─ Charts ─ */
        'chart-bar': `<div class="card border-0 shadow-sm mb-3"><div class="card-header bg-white fw-semibold" contenteditable="true">Bar Chart — Monthly Sales</div><div class="card-body"><div id="chartBar_{{UID}}" style="min-height:280px;"></div></div></div><script>if(typeof ApexCharts!=='undefined'){new ApexCharts(document.querySelector('#chartBar_{{UID}}'),{chart:{type:'bar',height:260,toolbar:{show:false}},colors:['#6366f1'],series:[{name:'Sales',data:[44,55,57,56,61,58,63,70,65,80,75,90]}],xaxis:{categories:['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec']},plotOptions:{bar:{borderRadius:4}},dataLabels:{enabled:false}}).render();}<\/script>`.replace(/{{UID}}/g, 'b'+Date.now()),
        'chart-line': `<div class="card border-0 shadow-sm mb-3"><div class="card-header bg-white fw-semibold" contenteditable="true">Line Chart — Revenue Trend</div><div class="card-body"><div id="chartLine_{{UID}}" style="min-height:280px;"></div></div></div><script>if(typeof ApexCharts!=='undefined'){new ApexCharts(document.querySelector('#chartLine_{{UID}}'),{chart:{type:'area',height:260,toolbar:{show:false}},colors:['#10b981'],fill:{type:'gradient',gradient:{shadeIntensity:1,opacityFrom:0.4,opacityTo:0,stops:[0,90,100]}},series:[{name:'Revenue',data:[31,40,28,51,42,109,100,80,91,120,105,135]}],xaxis:{categories:['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec']},dataLabels:{enabled:false},stroke:{curve:'smooth'}}).render();}<\/script>`.replace(/{{UID}}/g, 'l'+Date.now()),
        'chart-pie': `<div class="card border-0 shadow-sm mb-3"><div class="card-header bg-white fw-semibold" contenteditable="true">Pie / Donut Chart — Distribution</div><div class="card-body"><div id="chartPie_{{UID}}" style="min-height:280px;"></div></div></div><script>if(typeof ApexCharts!=='undefined'){new ApexCharts(document.querySelector('#chartPie_{{UID}}'),{chart:{type:'donut',height:260},colors:['#6366f1','#10b981','#f59e0b','#ef4444'],series:[44,55,41,17],labels:['Product A','Product B','Product C','Product D'],legend:{position:'bottom'}}).render();}<\/script>`.replace(/{{UID}}/g, 'p'+Date.now()),
        'chart-gantt': `<div class="card border-0 shadow-sm mb-3"><div class="card-header bg-white fw-semibold" contenteditable="true">Gantt Chart — Project Timeline</div><div class="card-body"><div id="chartGantt_{{UID}}" style="min-height:280px;"></div></div></div><script>if(typeof ApexCharts!=='undefined'){new ApexCharts(document.querySelector('#chartGantt_{{UID}}'),{chart:{type:'rangeBar',height:260,toolbar:{show:false}},plotOptions:{bar:{horizontal:true,borderRadius:4}},colors:['#6366f1','#10b981','#f59e0b'],series:[{name:'Planning',data:[{x:'Research',y:[new Date('2025-01-01').getTime(),new Date('2025-01-20').getTime()]},{x:'Design',y:[new Date('2025-01-15').getTime(),new Date('2025-02-10').getTime()]}]},{name:'Development',data:[{x:'Frontend',y:[new Date('2025-02-01').getTime(),new Date('2025-03-01').getTime()]},{x:'Backend',y:[new Date('2025-02-10').getTime(),new Date('2025-03-15').getTime()]}]}],xaxis:{type:'datetime'},dataLabels:{enabled:false}}).render();}<\/script>`.replace(/{{UID}}/g, 'g'+Date.now()),

        /* ─ Data Tables ─ */
        'table': `<div class="table-responsive"><table class="table table-hover"><thead><tr><th contenteditable="true">ID</th><th contenteditable="true">Name</th><th contenteditable="true">Status</th><th contenteditable="true">Action</th></tr></thead><tbody><tr><td contenteditable="true">1</td><td contenteditable="true">John Doe</td><td contenteditable="true"><span class="badge bg-success">Active</span></td><td contenteditable="true"><button class="btn btn-sm btn-outline-primary">Edit</button></td></tr><tr><td contenteditable="true">2</td><td contenteditable="true">Jane Smith</td><td contenteditable="true"><span class="badge bg-warning">Pending</span></td><td contenteditable="true"><button class="btn btn-sm btn-outline-primary">Edit</button></td></tr></tbody></table></div>`,
        'table-striped': `<div class="table-responsive"><table class="table table-striped table-bordered align-middle"><thead class="table-dark"><tr><th contenteditable="true">#</th><th contenteditable="true">Name</th><th contenteditable="true">Role</th><th contenteditable="true">Department</th><th contenteditable="true">Status</th></tr></thead><tbody><tr><td>1</td><td contenteditable="true">Alice Johnson</td><td contenteditable="true">Manager</td><td contenteditable="true">Marketing</td><td><span class="badge bg-success">Active</span></td></tr><tr><td>2</td><td contenteditable="true">Bob Williams</td><td contenteditable="true">Developer</td><td contenteditable="true">Engineering</td><td><span class="badge bg-primary">Active</span></td></tr><tr><td>3</td><td contenteditable="true">Carol Smith</td><td contenteditable="true">Designer</td><td contenteditable="true">Creative</td><td><span class="badge bg-warning text-dark">On Leave</span></td></tr></tbody></table></div>`,
        'table-datatable': function() {
            const uid = 'dt' + Date.now();
            const u = uid;
            return `
<div class="card border-0 shadow-sm" id="DTW_${u}">
  <div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-2" style="padding:10px 14px;">
    <span class="fw-semibold" contenteditable="true">Interactive Data Table</span>
    <div class="d-flex gap-2 align-items-center flex-wrap">
      <input type="text" id="DTS_${u}" class="form-control form-control-sm" placeholder="Search..." style="width:150px;" oninput="DT_${u}.search(this.value)">
      <select id="DTF_${u}" class="form-select form-select-sm" style="width:auto;" onchange="DT_${u}.filter(this.value)"></select>
      <button class="btn btn-outline-secondary btn-sm" onclick="DT_${u}.openColMgr()"><i class="fas fa-table-columns me-1"></i>Columns</button>
      <button class="btn btn-primary btn-sm" onclick="DT_${u}.openAdd()"><i class="fas fa-plus me-1"></i>Add</button>
    </div>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive"><table class="table table-hover align-middle mb-0"><thead class="table-light" id="DTH_${u}"></thead><tbody id="DTB_${u}"></tbody></table></div>
    <div id="DTE_${u}" class="text-center text-muted py-4" style="display:none;"><i class="fas fa-inbox fa-2x mb-2 d-block"></i>No data found</div>
  </div>
  <div class="card-footer bg-white d-flex justify-content-between align-items-center" style="padding:8px 14px;">
    <small class="text-muted" id="DTI_${u}"></small>
    <nav><ul class="pagination pagination-sm mb-0" id="DTP_${u}"></ul></nav>
  </div>
  <!-- ADD/EDIT MODAL -->
  <div id="DTM_${u}" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.5);align-items:center;justify-content:center;">
    <div style="background:#fff;border-radius:12px;width:500px;max-width:95vw;max-height:88vh;overflow-y:auto;box-shadow:0 24px 64px rgba(0,0,0,.3);">
      <div style="padding:14px 18px;border-bottom:1px solid #e5e7eb;display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;background:#fff;">
        <h6 class="mb-0 fw-bold" id="DMTITLE_${u}">Add Data</h6>
        <button onclick="DT_${u}.closeModal()" style="background:none;border:none;font-size:20px;color:#9ca3af;cursor:pointer;line-height:1;">&times;</button>
      </div>
      <div style="padding:18px;" id="DMFORM_${u}"></div>
      <div id="DMERR_${u}" class="text-danger small px-4 pb-2" style="display:none;"><i class="fas fa-exclamation-circle me-1"></i>Please fill required fields.</div>
      <div style="padding:12px 18px;border-top:1px solid #e5e7eb;display:flex;justify-content:flex-end;gap:8px;position:sticky;bottom:0;background:#fff;">
        <button onclick="DT_${u}.closeModal()" class="btn btn-light border btn-sm">Cancel</button>
        <button onclick="DT_${u}.saveData()" class="btn btn-primary btn-sm px-4"><i class="fas fa-save me-1"></i>Save</button>
      </div>
    </div>
  </div>
  <!-- VIEW MODAL -->
  <div id="DTV_${u}" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.5);align-items:center;justify-content:center;">
    <div style="background:#fff;border-radius:12px;width:400px;max-width:95vw;box-shadow:0 24px 64px rgba(0,0,0,.3);overflow:hidden;">
      <div id="DVHDR_${u}" style="background:linear-gradient(135deg,#6366f1,#8b5cf6);padding:20px;color:#fff;">
        <div style="width:48px;height:48px;border-radius:50%;background:rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:700;margin-bottom:8px;" id="DVAVT_${u}"></div>
        <div class="fw-bold" id="DVNAME_${u}"></div><small style="opacity:.75;" id="DVSUB_${u}"></small>
      </div>
      <div style="padding:18px;" id="DVBODY_${u}"></div>
      <div style="padding:12px 18px;border-top:1px solid #e5e7eb;text-align:right;"><button onclick="DT_${u}.closeView()" class="btn btn-light border btn-sm px-4">Close</button></div>
    </div>
  </div>
  <!-- DELETE MODAL -->
  <div id="DTDEL_${u}" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.5);align-items:center;justify-content:center;">
    <div style="background:#fff;border-radius:12px;width:340px;max-width:95vw;text-align:center;padding:28px;box-shadow:0 24px 64px rgba(0,0,0,.3);">
      <div style="width:56px;height:56px;border-radius:50%;background:#fee2e2;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;"><i class="fas fa-trash-alt text-danger" style="font-size:20px;"></i></div>
      <h6 class="fw-bold mb-1">Delete record?</h6>
      <p class="text-muted small mb-4" id="DTDELNAME_${u}"></p>
      <div class="d-flex gap-2 justify-content-center">
        <button onclick="DT_${u}.closeDelete()" class="btn btn-light border btn-sm px-3">Cancel</button>
        <button onclick="DT_${u}.confirmDelete()" class="btn btn-danger btn-sm px-3"><i class="fas fa-trash me-1"></i>Delete</button>
      </div>
    </div>
  </div>
  <!-- COLUMN MANAGER MODAL -->
  <div id="DTCM_${u}" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.5);align-items:center;justify-content:center;">
    <div style="background:#fff;border-radius:12px;width:660px;max-width:97vw;max-height:85vh;overflow-y:auto;box-shadow:0 24px 64px rgba(0,0,0,.3);">
      <div style="padding:14px 18px;border-bottom:1px solid #e5e7eb;display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;background:#fff;z-index:1;">
        <div><h6 class="mb-0 fw-bold"><i class="fas fa-table-columns text-primary me-2"></i>Manage Columns</h6><small class="text-muted">Edit columns — Add/Edit form fields update automatically.</small></div>
        <button onclick="DT_${u}.closeColMgr()" style="background:none;border:none;font-size:20px;color:#9ca3af;cursor:pointer;">&times;</button>
      </div>
      <div style="padding:16px 18px;">
        <div style="display:grid;grid-template-columns:1fr 140px 1fr 32px;gap:8px;margin-bottom:6px;font-size:11px;font-weight:600;color:#9ca3af;text-transform:uppercase;letter-spacing:.5px;">
          <div>Column Name</div><div>Type</div><div>Options (comma-separated)</div><div></div>
        </div>
        <div id="DTCMLIST_${u}"></div>
        <button onclick="DT_${u}._addCol()" class="btn btn-outline-primary btn-sm mt-2 w-100"><i class="fas fa-plus me-1"></i>Add Column</button>
      </div>
      <div style="padding:12px 18px;border-top:1px solid #e5e7eb;display:flex;justify-content:flex-end;gap:8px;position:sticky;bottom:0;background:#fff;">
        <button onclick="DT_${u}.closeColMgr()" class="btn btn-light border btn-sm">Cancel</button>
        <button onclick="DT_${u}.saveColMgr()" class="btn btn-primary btn-sm px-4"><i class="fas fa-check me-1"></i>Apply</button>
      </div>
    </div>
  </div>
</div>
<script>
(function(){
const ID='${u}';const PS=5;
let cols=[{key:'c1',label:'Name',type:'text',req:true},{key:'c2',label:'Email',type:'email',req:false},{key:'c3',label:'Role',type:'select',opts:['Admin','User','Editor','Manager','Viewer'],req:false},{key:'c4',label:'Status',type:'status',opts:['Active','Pending','Inactive'],req:false}];
let draft=[];
let rows=[{id:1,c1:'John Doe',c2:'john@@example.com',c3:'Admin',c4:'Active'},{id:2,c1:'Jane Smith',c2:'jane@@example.com',c3:'User',c4:'Pending'},{id:3,c1:'Bob Marley',c2:'bob@@example.com',c3:'Editor',c4:'Inactive'},{id:4,c1:'Alice Johnson',c2:'alice@@example.com',c3:'Manager',c4:'Active'},{id:5,c1:'Charlie Brown',c2:'charlie@@example.com',c3:'Viewer',c4:'Active'},{id:6,c1:'Diana Prince',c2:'diana@@example.com',c3:'User',c4:'Pending'}];
let nid=7,eid=null,did=null,pg=1,sq='',fv='',ck=cols.length;
const g=id=>document.getElementById(id);
const esc=s=>String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
const sCol=()=>cols.find(c=>c.type==='status');
const sBadge=s=>{const m={Active:'bg-success',Pending:'bg-warning text-dark',Inactive:'bg-secondary'};return '<span class="badge '+(m[s]||'bg-secondary')+'">'+esc(s)+'</span>';};
const showM=id=>{g(id).style.display='flex';};
const hideM=id=>{g(id).style.display='none';};
function filt(){return rows.filter(r=>{const q=sq.toLowerCase();const mq=!q||cols.some(c=>(r[c.key]||'').toString().toLowerCase().includes(q));const sc=sCol();const ms=!fv||!sc||r[sc.key]===fv;return mq&&ms;});}
function rAll(){rHead();rBody();rFilterSel();}
function rHead(){const th=g('DTH_'+ID);if(!th)return;th.innerHTML='<tr><th style="width:40px;font-size:12px;">No</th>'+cols.map(c=>'<th style="font-size:12px;">'+esc(c.label)+'</th>').join('')+'<th style="width:110px;font-size:12px;">Action</th></tr>';}
function rBody(){
  const data=filt();const tot=data.length;const totP=Math.max(1,Math.ceil(tot/PS));
  if(pg>totP)pg=totP;const paged=data.slice((pg-1)*PS,pg*PS);
  const tb=g('DTB_'+ID),em=g('DTE_'+ID);if(!tb)return;
  tb.innerHTML='';
  if(!paged.length){em.style.display='';g('DTI_'+ID).textContent='No entries';}
  else{
    em.style.display='none';
    paged.forEach((r,i)=>{
      const tr=document.createElement('tr');
      let h='<td style="font-size:12px;">'+(((pg-1)*PS)+i+1)+'</td>';
      cols.forEach((c,ci)=>{
        const v=r[c.key]||'';
        if(c.type==='status')h+='<td>'+sBadge(v)+'</td>';
        else if(c.type==='select')h+='<td><span class="badge bg-light text-dark border" style="font-size:12px;">'+esc(v)+'</span></td>';
        else if(ci===0)h+='<td><div class="d-flex align-items-center gap-2"><div style="width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,#6366f1,#8b5cf6);display:flex;align-items:center;justify-content:center;color:#fff;font-size:11px;font-weight:700;flex-shrink:0;">'+(v.charAt(0)||'?').toUpperCase()+'</div><span style="font-size:13px;font-weight:600;">'+esc(v)+'</span></div></td>';
        else h+='<td><span class="text-muted" style="font-size:12px;">'+esc(v)+'</span></td>';
      });
      h+='<td><div class="d-flex gap-1"><button class="btn btn-sm btn-outline-primary" style="padding:2px 6px;" onclick="DT_'+ID+'.openView('+r.id+')"><i class="fas fa-eye" style="font-size:11px;"></i></button><button class="btn btn-sm btn-outline-warning" style="padding:2px 6px;" onclick="DT_'+ID+'.openEdit('+r.id+')"><i class="fas fa-edit" style="font-size:11px;"></i></button><button class="btn btn-sm btn-outline-danger" style="padding:2px 6px;" onclick="DT_'+ID+'.openDelete('+r.id+')"><i class="fas fa-trash" style="font-size:11px;"></i></button></div></td>';
      tr.innerHTML=h;tb.appendChild(tr);
    });
    const from=(pg-1)*PS+1,to=Math.min(pg*PS,tot);
    g('DTI_'+ID).textContent='Showing '+from+'\u2013'+to+' of '+tot+' entries';
  }
  const ul=g('DTP_'+ID);ul.innerHTML='';
  const mk=(lbl,p,dis,act)=>{const li=document.createElement('li');li.className='page-item'+(dis?' disabled':'')+(act?' active':'');const a=document.createElement('a');a.className='page-link';a.textContent=lbl;a.href='#';if(!dis&&!act)a.onclick=e=>{e.preventDefault();pg=p;rBody();};li.appendChild(a);return li;};
  ul.appendChild(mk('Prev',pg-1,pg===1,false));
  for(let p=1;p<=totP;p++)ul.appendChild(mk(p,p,false,p===pg));
  ul.appendChild(mk('Next',pg+1,pg===totP,false));
}
function rFilterSel(){const sel=g('DTF_'+ID);if(!sel)return;const sc=sCol();if(!sc){sel.style.display='none';return;}sel.style.display='';const cv=fv;sel.innerHTML='<option value="">All '+esc(sc.label)+'</option>'+(sc.opts||[]).map(o=>'<option value="'+esc(o)+'"'+(o===cv?' selected':'')+'>'+esc(o)+'</option>').join('');}
function buildForm(r){
  return '<div class="row g-3">'+cols.map(c=>{
    const v=r?(r[c.key]||''):'';
    const req=c.req?'<span class="text-danger">*</span>':'';
    let inp='';
    if(c.type==='status'||c.type==='select'){const opts=(c.opts||[]).map(o=>'<option'+(o===v?' selected':'')+'>'+esc(o)+'</option>').join('');inp='<select id="mf_'+c.key+'_'+ID+'" class="form-select form-select-sm">'+opts+'</select>';}
    else if(c.type==='date')inp='<input type="date" id="mf_'+c.key+'_'+ID+'" class="form-control form-control-sm" value="'+esc(v)+'">';
    else if(c.type==='number')inp='<input type="number" id="mf_'+c.key+'_'+ID+'" class="form-control form-control-sm" value="'+esc(v)+'">';
    else if(c.type==='email')inp='<div class="input-group input-group-sm"><span class="input-group-text"><i class="fas fa-envelope text-muted" style="font-size:11px;"></i></span><input type="email" id="mf_'+c.key+'_'+ID+'" class="form-control" value="'+esc(v)+'" placeholder="user@@example.com"></div>';
    else inp='<input type="text" id="mf_'+c.key+'_'+ID+'" class="form-control form-control-sm" value="'+esc(v)+'" placeholder="Enter '+esc(c.label)+'">';
    const cls=cols.length>2?'col-md-6 col-12':'col-12';
    return '<div class="'+cls+'"><label class="form-label mb-1" style="font-size:12px;font-weight:600;">'+esc(c.label)+' '+req+'</label>'+inp+'</div>';
  }).join('')+'</div>';}
function buildColMgr(){
  const list=g('DTCMLIST_'+ID);if(!list)return;
  list.innerHTML='';
  draft.forEach(c=>{
    const hasOpts=c.type==='select'||c.type==='status';
    const row=document.createElement('div');
    row.style.cssText='display:grid;grid-template-columns:1fr 140px 1fr 32px;gap:8px;margin-bottom:8px;align-items:center;';
    row.innerHTML=
      '<input type="text" class="form-control form-control-sm" value="'+esc(c.label)+'" placeholder="Name" oninput="DT_'+ID+'._cLbl(&quot;'+c.key+'&quot;,this.value)">'+
      '<select class="form-select form-select-sm" onchange="DT_'+ID+'._cType(&quot;'+c.key+'&quot;,this.value)">'+
      ['text','email','number','date','select','status'].map(t=>'<option value="'+t+'"'+(c.type===t?' selected':'')+'>'+{text:'Text',email:'Email',number:'Number',date:'Date',select:'Select',status:'Status Badge'}[t]+'</option>').join('')+
      '</select>'+
      '<input type="text" class="form-control form-control-sm" value="'+(c.opts||[]).join(',')+'" placeholder="e.g. Yes,No"'+(hasOpts?'':' disabled style="opacity:.4"')+' oninput="DT_'+ID+'._cOpts(&quot;'+c.key+'&quot;,this.value)">'+
      '<button class="btn btn-sm btn-outline-danger" style="padding:2px 6px;" onclick="DT_'+ID+'._delCol(&quot;'+c.key+'&quot;)"'+(draft.length<=1?' disabled':'')+' title="Remove"><i class="fas fa-times" style="font-size:11px;"></i></button>';
    list.appendChild(row);
  });
}
window['DT_'+ID]={
