@{
    ViewData["Title"] = "UI Designer";
}

<link rel="stylesheet" href="/css/ui-builder.css" />

<div class="builder-container">
    <!-- Sidebar / Components Palette -->
    <div class="builder-sidebar">
        <div class="builder-sidebar-header pb-0 border-bottom-0">
            <h5 class="mb-2">UI Builder</h5>
            <ul class="nav nav-tabs" style="font-size: 13px; border-bottom: none;">
                <li class="nav-item">
                    <button class="nav-link active px-3 py-2" data-bs-toggle="tab" data-bs-target="#components-tab" type="button">Components</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link px-3 py-2" data-bs-toggle="tab" data-bs-target="#pages-tab" type="button">Pages</button>
                </li>
            </ul>
        </div>
        <div class="tab-content builder-components" id="sidebarProtoTabs">
            <!-- COMPONENTS TAB -->
            <div class="tab-pane fade show active p-3" id="components-tab">
                <div class="component-group-title">Layouts</div>
                <div class="component-item" draggable="true" ondragstart="drag(event)" data-type="row"><i class="fa-solid fa-table-columns"></i> 2-Column Row</div>
                <div class="component-item" draggable="true" ondragstart="drag(event)" data-type="card"><i class="fa-solid fa-rectangle-list"></i> Card</div>
                <div class="component-group-title mt-4">Typography</div>
                <div class="component-item" draggable="true" ondragstart="drag(event)" data-type="header"><i class="fa-solid fa-heading"></i> Heading Title</div>
                <div class="component-item" draggable="true" ondragstart="drag(event)" data-type="paragraph"><i class="fa-solid fa-align-left"></i> Text Paragraph</div>
                <div class="component-group-title mt-4">Forms & Inputs</div>
                <div class="component-item" draggable="true" ondragstart="drag(event)" data-type="input-text"><i class="fa-solid fa-i-cursor"></i> Text Input</div>
                <div class="component-item" draggable="true" ondragstart="drag(event)" data-type="select"><i class="fa-regular fa-square-caret-down"></i> Select Dropdown</div>
                <div class="component-item" draggable="true" ondragstart="drag(event)" data-type="checkbox"><i class="fa-regular fa-square-check"></i> Checkbox</div>
                <div class="component-item" draggable="true" ondragstart="drag(event)" data-type="button"><i class="fa-solid fa-hand-pointer"></i> Button</div>
                <div class="component-group-title mt-4">Data</div>
                <div class="component-item" draggable="true" ondragstart="drag(event)" data-type="table"><i class="fa-solid fa-table"></i> Data Table</div>
            </div>
            <!-- PAGES TAB -->
            <div class="tab-pane fade p-3 h-100" id="pages-tab">
                <button class="btn btn-primary w-100 mb-3 btn-sm" onclick="addNewPage()"><i class="fas fa-plus me-1"></i> Add Prototype Page</button>
                <div id="pagesList"></div>
            </div>
        </div>

        <!-- ERD Sidebar (hidden by default) -->
        <div id="erdSidebarContent" style="display:none;flex:1;flex-direction:column;overflow:hidden;">
            <div style="padding:16px;border-bottom:1px solid var(--border-color);">
                <button class="btn btn-primary w-100 btn-sm mb-2" onclick="ERD.addEntity()"><i class="fas fa-plus me-1"></i> Add Entity</button>
            </div>
            <div style="flex:1;overflow-y:auto;padding:16px;">
                <div class="component-group-title">Entities</div>
                <div id="erdEntityList"></div>
                <div class="component-group-title mt-4">Relationships</div>
                <div id="erdRelList"></div>
            </div>
        </div>
    </div>

    <!-- Main Canvas Area -->
    <div class="builder-canvas-wrapper">
        <!-- Unified Toolbar -->
        <div class="builder-toolbar">
            <div class="workspace-tabs">
                <button class="ws-tab active" onclick="switchWorkspace('prototype',this)"><i class="fas fa-paint-brush"></i> Prototype</button>
                <button class="ws-tab" onclick="switchWorkspace('fsd',this)"><i class="fas fa-file-alt"></i> FSD</button>
                <button class="ws-tab" onclick="switchWorkspace('erd',this)"><i class="fas fa-project-diagram"></i> ERD</button>
            </div>
            <div class="toolbar-right" id="toolbarActions">
                <button class="btn btn-sm btn-outline-danger me-2" onclick="clearCanvas()"><i class="fa-solid fa-trash"></i> Clear</button>
                <button class="btn btn-sm btn-outline-primary" onclick="previewHTML()"><i class="fa-solid fa-code"></i> Get HTML</button>
            </div>
        </div>

        <!-- PROTOTYPE PANEL -->
        <div class="workspace-panel active" id="panel-prototype">
            <div class="builder-canvas">
                <div class="canvas-paper drop-zone" id="mainCanvas" ondrop="drop(event)" ondragover="allowDrop(event)" ondragenter="dragEnter(event)" ondragleave="dragLeave(event)"></div>
            </div>
        </div>

        <!-- FSD PANEL -->
        <div class="workspace-panel" id="panel-fsd">
            <div class="fsd-panel" id="fsdContent"></div>
        </div>

        <!-- ERD PANEL -->
        <div class="workspace-panel" id="panel-erd">
            <div class="erd-canvas-area" id="erdCanvas">
                <svg id="erdSvg"></svg>
            </div>
        </div>
    </div>
</div>

<!-- Modal for HTML Source -->
<div class="modal fade" id="htmlPreviewModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Export</h5>
                <button type="button" class="btn-close" onclick="closeModal()"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-2"><small>Copy this code into your IDE.</small></p>
                <div id="exportCode"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal()">Close</button>
                <button type="button" class="btn btn-primary" onclick="copySource()">Copy to Clipboard</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal for Linking Buttons -->
<div class="modal fade" id="linkModal" tabindex="-1" style="z-index: 1060;">
    <div class="modal-dialog modal-sm modal-dialog-centered" style="pointer-events: auto;">
        <div class="modal-content">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fs-6">Link Button to Page</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="linkModalBody"></div>
            <div class="modal-footer border-top-0 pt-0">
                <button type="button" class="btn btn-sm btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-sm btn-primary px-3" onclick="saveLink()">Save</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal for Adding Page -->
<div class="modal fade" id="addPageModal" tabindex="-1" style="z-index: 1060;">
    <div class="modal-dialog modal-sm modal-dialog-centered" style="pointer-events: auto;">
        <div class="modal-content">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fs-6">Add New Page</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <label class="form-label">Page Name</label>
                <input type="text" class="form-control" id="newPageNameInput" placeholder="Enter page name" value="New Page">
            </div>
            <div class="modal-footer border-top-0 pt-0">
                <button type="button" class="btn btn-sm btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-sm btn-primary px-3" onclick="confirmAddPage()">Add Page</button>
            </div>
        </div>
    </div>
</div>

<script src="/js/ui-builder-fsd.js"></script>
<script src="/js/ui-builder-erd.js"></script>
<!-- html2pdf for FSD Export -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

<script>
    /* ── Workspace Switching ────────────── */
    let currentWorkspace = 'prototype';

    function switchWorkspace(ws, btn) {
        if (ws === currentWorkspace) return;
        currentWorkspace = ws;

        // Save prototype canvas before leaving
        if (ws !== 'prototype') {
            const cd = pages.find(p => p.id === currentPageId);
            if (cd) cd.html = document.getElementById('mainCanvas').innerHTML;
        }

        // Tab active state
        document.querySelectorAll('.ws-tab').forEach(t => t.classList.remove('active'));
        btn.classList.add('active');

        // Panel visibility
        document.querySelectorAll('.workspace-panel').forEach(p => p.classList.remove('active'));
        document.getElementById('panel-' + ws).classList.add('active');

        // Sidebar switching
        const protoTabs = document.getElementById('sidebarProtoTabs');
        const erdSb = document.getElementById('erdSidebarContent');
        const sidebarHeader = document.querySelector('.builder-sidebar-header');

        if (ws === 'erd') {
            protoTabs.style.display = 'none';
            erdSb.style.display = 'flex';
            sidebarHeader.querySelector('h5').textContent = 'ERD Builder';
            sidebarHeader.querySelector('ul').style.display = 'none';
            ERD.init();
        } else if (ws === 'fsd') {
            protoTabs.style.display = 'none';
            erdSb.style.display = 'none';
            sidebarHeader.querySelector('h5').textContent = 'FSD Editor';
            sidebarHeader.querySelector('ul').style.display = 'none';
            FSD.init();
        } else {
            protoTabs.style.display = '';
            erdSb.style.display = 'none';
            sidebarHeader.querySelector('h5').textContent = 'UI Builder';
            sidebarHeader.querySelector('ul').style.display = '';
        }

        // Toolbar actions update
        const actions = document.getElementById('toolbarActions');
        if (ws === 'prototype') {
            actions.innerHTML = `<button class="btn btn-sm btn-outline-danger me-2" onclick="clearCanvas()"><i class="fa-solid fa-trash"></i> Clear</button>
                <button class="btn btn-sm btn-outline-primary" onclick="previewHTML()"><i class="fa-solid fa-code"></i> Get HTML</button>`;
        } else if (ws === 'fsd') {
            actions.innerHTML = `<button class="btn btn-sm btn-outline-secondary me-2" onclick="exportFSDPDF()"><i class="fas fa-file-pdf"></i> Export PDF</button>
                <button class="btn btn-sm btn-outline-primary" onclick="exportFSD()"><i class="fas fa-download"></i> Export Markdown</button>`;
        } else if (ws === 'erd') {
            actions.innerHTML = `<button class="btn btn-sm btn-outline-primary" onclick="exportERD()"><i class="fas fa-download"></i> Export SQL</button>`;
        }
    }

    function exportFSD() {
        const md = FSD.exportMarkdown();
        document.getElementById('exportCode').textContent = md;
        document.querySelector('#htmlPreviewModal .modal-title').textContent = 'Export FSD (Markdown)';
        const modal = document.getElementById('htmlPreviewModal');
        modal.style.display = 'flex'; modal.classList.add('show');
    }

    function exportFSDPDF() {
        const el = document.querySelector('.fsd-paper');
        if (!el) return;
        
        // Clone paper to replace inputs with text for printing
        const clone = el.cloneNode(true);
        
        // Replace form elements with text spans
        const origInputs = el.querySelectorAll('input, select, textarea');
        const cloneInputs = clone.querySelectorAll('input, select, textarea');
        origInputs.forEach((inp, i) => {
            const val = inp.value;
            const cInp = cloneInputs[i];
            const span = document.createElement('span');
            // Basic styling for print
            span.style.fontFamily = cInp.tagName === 'INPUT' && cInp.style.fontFamily === 'monospace' ? 'monospace' : 'inherit';
            span.style.fontWeight = cInp.style.fontWeight || 'normal';
            span.style.fontSize = cInp.style.fontSize || 'inherit';
            
            if (cInp.tagName === 'TEXTAREA') {
                span.innerHTML = val ? val.replace(/\n/g, '<br>') : '-';
                span.style.display = 'block';
                // Copy height or min-height to maintain spacing if needed
                span.style.minHeight = '20px';
                span.style.padding = '8px 0';
            } else if (cInp.tagName === 'SELECT') {
                span.innerText = cInp.options[cInp.selectedIndex]?.text || '-';
            } else {
                span.innerText = val || '-';
            }
            cInp.parentNode.replaceChild(span, cInp);
        });

        // Hide UI buttons
        clone.querySelectorAll('.toggle, .fsd-add-btn, button').forEach(b => b.remove());

        // Render directly in-place to avoid out-of-viewport blank captures
        const container = el.parentElement;
        el.style.display = 'none'; // hide original FSD temporarily
        clone.style.background = '#fff';
        clone.style.padding = '20px';
        container.appendChild(clone);

        const safeName = 'FSD_' + (FSD.data.projectName || 'Document').replace(/[^a-zA-Z0-9]/g, '_') + '.pdf';
        
        const opt = {
            margin: [10, 10, 10, 10],
            filename: safeName,
            image: { type: 'jpeg', quality: 0.98 },
            html2canvas: { scale: 2, useCORS: true, logging: false, windowWidth: clone.scrollWidth },
            jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
        };
        
        // Wait a tiny bit for DOM to apply styles, then capture
        setTimeout(() => {
            html2pdf().set(opt).from(clone).save().then(() => {
                container.removeChild(clone);
                el.style.display = ''; // restore original FSD
            });
        }, 100);
    }

    function exportERD() {
        const sql = ERD.exportSQL();
        document.getElementById('exportCode').textContent = sql;
        document.querySelector('#htmlPreviewModal .modal-title').textContent = 'Export ERD (SQL)';
        const modal = document.getElementById('htmlPreviewModal');
        modal.style.display = 'flex'; modal.classList.add('show');
    }

    /* ── Prototype Pages Logic ──────────── */
    let pages = [{ id: 'page-1', name: 'Home', html: '' }];
    let currentPageId = 'page-1';

    function renderPages() {
        const list = document.getElementById('pagesList');
        if (!list) return;
        list.innerHTML = '';
        pages.forEach((page) => {
            const isActive = page.id === currentPageId;
            const item = document.createElement('div');
            item.className = `page-item ${isActive ? 'active' : ''}`;
            item.onclick = () => switchPage(page.id);
            let html = `<span><i class="far fa-file-alt me-2"></i> <span contenteditable="${isActive}" onblur="renamePage('${page.id}', this.innerText)" onclick="event.stopPropagation()">${page.name}</span></span>`;
            if (pages.length > 1) html += `<button class="btn btn-sm text-danger p-0" onclick="event.stopPropagation(); deletePage('${page.id}')"><i class="fas fa-trash"></i></button>`;
            item.innerHTML = html;
            list.appendChild(item);
        });
    }

    function switchPage(id) {
        if (id === currentPageId) return;
        const cd = pages.find(p => p.id === currentPageId);
        if (cd) cd.html = document.getElementById('mainCanvas').innerHTML;
        currentPageId = id;
        const nd = pages.find(p => p.id === id);
        if (nd) document.getElementById('mainCanvas').innerHTML = nd.html;
        renderPages();
    }

    function addNewPage() {
        document.getElementById('newPageNameInput').value = 'New Page';
        const modal = bootstrap.Modal.getOrCreateInstance(document.getElementById('addPageModal'));
        modal.show();
        setTimeout(() => document.getElementById('newPageNameInput').select(), 300);
    }

    function confirmAddPage() {
        const name = document.getElementById('newPageNameInput').value.trim();
        if (!name) return;
        const newId = 'page-' + Date.now();
        const canvas = document.getElementById('mainCanvas');
        if (canvas) {
            const cd = pages.find(p => p.id === currentPageId);
            if (cd) cd.html = canvas.innerHTML;
            canvas.innerHTML = '';
        }
        pages.push({ id: newId, name: name, html: '' });
        currentPageId = newId;
        renderPages();
        const modal = bootstrap.Modal.getInstance(document.getElementById('addPageModal'));
        if (modal) modal.hide();
    }

    function deletePage(id) {
        if (confirm("Delete this page?")) {
            pages = pages.filter(p => p.id !== id);
            if (currentPageId === id) switchPage(pages[0].id);
            else renderPages();
        }
    }

    function renamePage(id, newName) {
        const page = pages.find(p => p.id === id);
        if (page) page.name = newName;
    }

    document.addEventListener("DOMContentLoaded", function () { renderPages(); });

    /* ── Component Templates ───────────── */
    const componentTemplates = {
        'row': `<div class="row"><div class="col-md-6"><div class="drop-zone nested-drop" ondrop="drop(event)" ondragover="allowDrop(event)" ondragenter="dragEnter(event)" ondragleave="dragLeave(event)"></div></div><div class="col-md-6"><div class="drop-zone nested-drop" ondrop="drop(event)" ondragover="allowDrop(event)" ondragenter="dragEnter(event)" ondragleave="dragLeave(event)"></div></div></div>`,
        'card': `<div class="card mb-3"><div class="card-header" contenteditable="true">Card Title Here</div><div class="card-body"><div class="drop-zone nested-drop" ondrop="drop(event)" ondragover="allowDrop(event)" ondragenter="dragEnter(event)" ondragleave="dragLeave(event)"></div></div></div>`,
        'header': `<h3 contenteditable="true">Editable Heading Title</h3>`,
        'paragraph': `<p contenteditable="true" class="text-muted">Click to edit this paragraph text.</p>`,
        'input-text': `<div class="form-group mb-3"><label class="form-label" contenteditable="true">Input Label</label><input type="text" class="form-control" placeholder="Type here..."></div>`,
        'select': `<div class="form-group mb-3"><label class="form-label" contenteditable="true">Select Option</label><select class="form-select form-control"><option>Option 1</option><option>Option 2</option><option>Option 3</option></select></div>`,
        'checkbox': `<div class="form-check mb-3"><input class="form-check-input" type="checkbox"><label class="form-check-label" contenteditable="true">Example checkbox</label></div>`,
        'button': `<button class="btn btn-primary" contenteditable="true">Submit Button</button>`,
        'table': `<div class="table-responsive"><table class="table table-hover"><thead><tr><th contenteditable="true">ID</th><th contenteditable="true">Name</th><th contenteditable="true">Status</th><th>Action</th></tr></thead><tbody><tr><td>1</td><td contenteditable="true">John Doe</td><td><span class="badge bg-success">Active</span></td><td><button class="btn btn-sm btn-outline-primary">Edit</button></td></tr><tr><td>2</td><td contenteditable="true">Jane Smith</td><td><span class="badge bg-warning">Pending</span></td><td><button class="btn btn-sm btn-outline-primary">Edit</button></td></tr></tbody></table></div>`
    };

    /* ── Drag & Drop ───────────────────── */
    function allowDrop(ev) { ev.preventDefault(); ev.stopPropagation(); }
    function dragEnter(ev) { ev.preventDefault(); ev.stopPropagation(); if (ev.target.classList.contains('drop-zone')) ev.target.classList.add('active-drag'); }
    function dragLeave(ev) { ev.preventDefault(); ev.stopPropagation(); if (ev.target.classList.contains('drop-zone')) ev.target.classList.remove('active-drag'); }
    function drag(ev) { ev.dataTransfer.setData("type", ev.target.getAttribute('data-type')); }

    function drop(ev) {
        ev.preventDefault(); ev.stopPropagation();
        document.querySelectorAll('.active-drag').forEach(el => el.classList.remove('active-drag'));
        let target = ev.target;
        if (!target.classList.contains('drop-zone')) target = target.closest('.drop-zone');
        if (!target) return;
        const type = ev.dataTransfer.getData("type");
        if (type && componentTemplates[type]) {
            const w = document.createElement('div');
            w.className = 'canvas-element';
            let extra = type === 'button' ? `<button class="action-btn link-btn" title="Link to Page" onclick="openLinkModal(this)"><i class="fa-solid fa-link"></i></button>` : '';
            w.innerHTML = `<div class="canvas-element-actions">${extra}<button class="action-btn" title="Move Up" onclick="moveEl(this,-1)"><i class="fa-solid fa-arrow-up"></i></button><button class="action-btn" title="Move Down" onclick="moveEl(this,1)"><i class="fa-solid fa-arrow-down"></i></button><button class="action-btn delete" title="Delete" onclick="deleteEl(this)"><i class="fa-solid fa-trash"></i></button></div>` + componentTemplates[type];
            target.appendChild(w);
        }
    }

    function deleteEl(btn) { btn.closest('.canvas-element').remove(); }
    function moveEl(btn, dir) {
        const el = btn.closest('.canvas-element'), p = el.parentNode;
        if (dir === -1 && el.previousElementSibling) p.insertBefore(el, el.previousElementSibling);
        else if (dir === 1 && el.nextElementSibling) p.insertBefore(el.nextElementSibling, el);
    }
    function clearCanvas() { if (confirm("Clear the entire canvas?")) { document.getElementById('mainCanvas').innerHTML = ''; const cd = pages.find(p => p.id === currentPageId); if (cd) cd.html = ''; } }

    /* ── Link Modal ────────────────────── */
    let currentLinkButton = null;
    function openLinkModal(btn) {
        currentLinkButton = btn.closest('.canvas-element').querySelector('button.btn');
        let sel = '<select id="pageLinkSelect" class="form-select"><option value="">-- No Link --</option>';
        pages.forEach(p => { const s = (currentLinkButton.getAttribute('onclick') === `switchPage('${p.id}')`) ? 'selected' : ''; sel += `<option value="${p.id}" ${s}>${p.name}</option>`; });
        sel += '</select>';
        document.getElementById('linkModalBody').innerHTML = `<div class="mb-3"><label class="form-label">Select Target Page:</label>${sel}</div>`;
        const modal = bootstrap.Modal.getOrCreateInstance(document.getElementById('linkModal'));
        modal.show();
    }
    function saveLink() {
        if (!currentLinkButton) return;
        const tid = document.getElementById('pageLinkSelect').value;
        if (tid) { currentLinkButton.setAttribute('onclick', `switchPage('${tid}')`); if (!currentLinkButton.innerHTML.includes('fa-link')) currentLinkButton.innerHTML = currentLinkButton.innerText + ' <i class="fa-solid fa-link ms-1 small" style="opacity:0.5"></i>'; }
        else currentLinkButton.removeAttribute('onclick');
        const modal = bootstrap.Modal.getInstance(document.getElementById('linkModal'));
        if (modal) modal.hide();
    }

    /* ── HTML Preview & Export ──────────── */
    function previewHTML() {
        const c = document.getElementById('mainCanvas').cloneNode(true);
        c.querySelectorAll('.canvas-element').forEach(w => { const a = w.querySelector('.canvas-element-actions'); if (a) a.remove(); w.outerHTML = w.innerHTML; });
        c.querySelectorAll('.drop-zone').forEach(dz => { dz.removeAttribute('ondrop'); dz.removeAttribute('ondragover'); dz.removeAttribute('ondragenter'); dz.removeAttribute('ondragleave'); dz.classList.remove('drop-zone', 'nested-drop'); if (dz.classList.length === 0) dz.removeAttribute('class'); if (dz.innerHTML.trim() === '') dz.outerHTML = ''; });
        c.querySelectorAll('[contenteditable]').forEach(e => e.removeAttribute('contenteditable'));
        let html = c.innerHTML.trim() || '<!-- No components added yet -->';
        document.getElementById('exportCode').textContent = formatHTML(html);
        document.querySelector('#htmlPreviewModal .modal-title').textContent = 'Export HTML';
        const modal = document.getElementById('htmlPreviewModal');
        modal.style.display = 'flex'; modal.classList.add('show');
    }
    function closeModal() { const m = document.getElementById('htmlPreviewModal'); m.style.display = 'none'; m.classList.remove('show'); }
    function copySource() { navigator.clipboard.writeText(document.getElementById('exportCode').textContent).then(() => { alert("Copied!"); closeModal(); }); }
    function formatHTML(html) { let tab = '    ', result = '', indent = ''; html.split(/>\s*</).forEach(function (el) { if (el.match(/^\/\w/)) indent = indent.substring(tab.length); result += indent + '<' + el + '>\r\n'; if (el.match(/^<?\\w[^>]*[^\/]$/) && !el.startsWith("input") && !el.startsWith("img")) indent += tab; }); return result.substring(1, result.length - 3); }
</script>
