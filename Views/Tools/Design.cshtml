        'tabs': function() {
            const uid = 'tab' + Date.now();
            return `
<div class="card border-0 shadow-sm mb-3" id="wrap_${uid}">
    <div class="card-header bg-white pb-0 border-bottom-0 d-flex justify-content-between align-items-end">
        <ul class="nav nav-tabs card-header-tabs" id="nav_${uid}" style="margin-bottom:-1px; flex-wrap:nowrap; overflow-x:auto; border-bottom:none;">
            <!-- Tabs injected here by script -->
        </ul>
        <div class="d-flex gap-1 ms-2 mb-2 pb-1" style="flex-shrink:0;">
            <button class="btn btn-sm btn-outline-primary" style="padding:2px 8px;font-size:12px;" onclick="TABS_${uid}.addTab()" title="Add Tab"><i class="fas fa-plus"></i></button>
            <button class="btn btn-sm btn-outline-danger" style="padding:2px 8px;font-size:12px;" onclick="TABS_${uid}.removeTab()" title="Remove Active Tab"><i class="fas fa-minus"></i></button>
        </div>
    </div>
    <div class="card-body p-0 border border-top-0 rounded-bottom">
        <div class="tab-content w-100" id="content_${uid}" style="position:relative; min-height:100px;">
            <!-- Panes injected here by script -->
        </div>
    </div>
</div>
<script>
(function(){
    const ID = '${uid}';
    let tabs = [
        { id: 't1', label: 'Tab One' },
        { id: 't2', label: 'Tab Two' }
    ];
    let activeId = 't1';
    let nextId = 3;

    function esc(s) {
        return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }
    
    function rNav() {
        const nav = document.getElementById('nav_' + ID);
        if(!nav) return;
        nav.innerHTML = tabs.map(t => {
            const isActive = t.id === activeId;
            return '<li class="nav-item"><button class="nav-link ' + (isActive ? 'active fw-bold' : '') + '" style="outline:none;background:'+(isActive?'#fff':'transparent')+';" onblur="TABS_'+ID+'.lbl(&quot;'+t.id+'&quot;, this.innerText)" '+(isActive?'contenteditable="true"':'onclick="TABS_'+ID+'.sw(&quot;'+t.id+'&quot;)"')+'>' + esc(t.label) + '</button></li>';
        }).join('');
    }

    function rPanes() {
        const content = document.getElementById('content_' + ID);
        if(!content) return;
        
        // Preserve unremoved panes 
        tabs.forEach(t => {
            let pane = document.getElementById('pane_' + t.id + '_' + ID);
            if (!pane) {
                pane = document.createElement('div');
                pane.id = 'pane_' + t.id + '_' + ID;
                pane.className = 'tab-pane p-4 drop-zone nested-drop w-100';
                pane.style.minHeight = '150px';
                
                // Add placeholder helper text
                const emptyState = document.createElement('div');
                emptyState.className = 'text-center text-muted w-100 comp-empty-state';
                emptyState.style.paddingTop = '10px';
                emptyState.style.pointerEvents = 'none';
                emptyState.innerHTML = '<i class="fas fa-cubes mb-2 d-block fa-lg" style="opacity:0.5;"></i>Drag &amp; Drop Components Here';
                
                pane.appendChild(emptyState);
                
                // Manually map drag drop events since it's dynamically added after initial doc parse
                pane.setAttribute('ondrop', 'drop(event)');
                pane.setAttribute('ondragover', 'allowDrop(event)');
                pane.setAttribute('ondragenter', 'dragEnter(event)');
                pane.setAttribute('ondragleave', 'dragLeave(event)');
                
                content.appendChild(pane);
            }
        });
        
        // Show active pane, hide others
        Array.from(content.children).forEach(pane => {
            if (pane.id === 'pane_' + activeId + '_' + ID) {
                pane.style.display = 'block';
                pane.classList.add('show', 'active');
            } else {
                pane.style.display = 'none';
                pane.classList.remove('show', 'active');
            }
        });
    }

    // Attach to global scope for button clicks
    window['TABS_' + ID] = {
        sw: function(id) { 
            activeId = id; 
            rNav(); rPanes(); 
        },
        addTab: function() { 
            const newId = 't' + nextId++; 
            tabs.push({ id: newId, label: 'New Tab' }); 
            activeId = newId; 
            rNav(); rPanes(); 
        },
        removeTab: function() {
            if (tabs.length <= 1) return;
            const idx = tabs.findIndex(t => t.id === activeId);
            const r = tabs[idx];
            tabs = tabs.filter(t => t.id !== activeId);
            
            const pane = document.getElementById('pane_' + r.id + '_' + ID);
            if (pane) pane.remove();

            if (idx < tabs.length) activeId = tabs[idx].id;
            else activeId = tabs[tabs.length - 1].id;
            
            rNav(); rPanes();
        },
        lbl: function(id, text) { 
            const t = tabs.find(x => x.id === id); 
            if (t) t.label = text.trim() || 'Tab'; 
        }
    };

    // Initial Render
    rNav();
    rPanes();
})();
<\/script>`;
