@{
    ViewData["Title"] = "UI Designer";
}

<style>
    .builder-container {
        display: flex;
        height: calc(100vh - 120px);
        margin: -20px -40px;
        background-color: var(--bg-body);
        font-family: inherit;
    }

    /* Palette Area */
    .builder-sidebar {
        width: 300px;
        background: #fff;
        border-right: 1px solid var(--border-color);
        display: flex;
        flex-direction: column;
        z-index: 10;
        box-shadow: 2px 0 10px rgba(0,0,0,0.02);
    }

    .builder-sidebar-header {
        padding: 20px;
        border-bottom: 1px solid var(--border-color);
        background: var(--dashboard-bg);
    }

    .builder-sidebar-header h5 {
        margin: 0;
        font-weight: 600;
        font-size: 16px;
    }

    .builder-components {
        overflow-y: auto;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .page-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 15px;
        border: 1px solid var(--border-color);
        margin-bottom: 5px;
        border-radius: 6px;
        cursor: pointer;
        background: #fff;
    }
    .page-item:hover {
        background: #f8fafc;
    }
    .page-item.active {
        border-color: var(--primary);
        background: rgba(59, 157, 130, 0.05);
        color: var(--primary);
        font-weight: 600;
    }

    .component-group-title {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 10px;
        letter-spacing: 0.5px;
    }

    .component-item {
        background: var(--bg-body);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 12px 15px;
        margin-bottom: 10px;
        cursor: grab;
        display: flex;
        align-items: center;
        transition: all 0.2s;
    }

    .component-item:active {
        cursor: grabbing;
    }

    .component-item:hover {
        border-color: var(--primary);
        color: var(--primary);
        background: var(--green-light);
    }

    .component-item i {
        margin-right: 10px;
        font-size: 16px;
    }

    /* Canvas Area */
    .builder-canvas-wrapper {
        flex: 1;
        display: flex;
        flex-direction: column;
        background-color: #f1f5f9;
        position: relative;
    }

    .builder-toolbar {
        height: 50px;
        background: #fff;
        border-bottom: 1px solid var(--border-color);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
    }

    .builder-canvas {
        flex: 1;
        padding: 40px;
        overflow-y: auto;
    }

    .canvas-paper {
        background: #fff;
        min-height: 100%;
        border-radius: 12px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
        padding: 40px;
        margin: 0 auto;
        max-width: 1000px;
    }

    /* Droppable Area */
    .drop-zone {
        min-height: 60px;
        border: 2px dashed transparent;
        border-radius: 8px;
        transition: all 0.2s;
    }

    .drop-zone.active-drag {
        border-color: var(--primary);
        background-color: rgba(35, 83, 71, 0.05); /* var(--primary) with opacity */
    }

    .drop-zone:empty::before {
        content: 'Drag & Drop components here...';
        display: block;
        text-align: center;
        color: var(--text-muted);
        padding: 20px;
        font-size: 14px;
    }

    /* Dropped Elements */
    .canvas-element {
        position: relative;
        padding: 15px;
        margin-bottom: 15px;
        border: 1px solid transparent;
        border-radius: 8px;
    }

    .canvas-element:hover {
        border-color: var(--primary);
    }

    .canvas-element-actions {
        position: absolute;
        top: -10px;
        right: 10px;
        display: none;
        background: #fff;
        border: 1px solid var(--primary);
        border-radius: 4px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        z-index: 10;
        overflow: hidden;
    }

    .canvas-element:hover .canvas-element-actions {
        display: flex;
    }

    .action-btn {
        width: 28px;
        height: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: transparent;
        border: none;
        color: var(--text-dark);
        cursor: pointer;
        font-size: 12px;
    }

    .action-btn:hover {
        background: var(--primary);
        color: #fff;
    }

    .action-btn.link-btn {
        background: #f8fafc;
        color: var(--primary);
    }

    .action-btn.link-btn:hover {
        background: var(--primary);
        color: #fff;
    }

    .action-btn.delete:hover {
        background: var(--danger);
        color: #fff;
    }

    /* Preview Modal Fix */
    #htmlPreviewModal .modal-dialog {
        max-width: 800px;
    }
    #exportCode {
        background: #1e293b;
        color: #e2e8f0;
        padding: 15px;
        border-radius: 8px;
        font-family: monospace;
        font-size: 13px;
        min-height: 300px;
        max-height: 500px;
        overflow-y: auto;
        white-space: pre-wrap;
    }
</style>

<div class="builder-container">
    <!-- Sidebar / Components Palette -->
    <div class="builder-sidebar">
        <div class="builder-sidebar-header pb-0 border-bottom-0">
            <h5 class="mb-2">UI Builder</h5>
            <ul class="nav nav-tabs" style="font-size: 13px; border-bottom: none;">
                <li class="nav-item">
                    <button class="nav-link active px-3 py-2" data-bs-toggle="tab" data-bs-target="#components-tab" type="button">Components</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link px-3 py-2" data-bs-toggle="tab" data-bs-target="#pages-tab" type="button">Pages</button>
                </li>
            </ul>
        </div>
        <div class="tab-content builder-components">
            <!-- COMPONENTS TAB -->
            <div class="tab-pane fade show active p-3" id="components-tab">
                <div class="component-group-title">Layouts</div>
                <div class="component-item" draggable="true" ondragstart="drag(event)" data-type="row">
                    <i class="fa-solid fa-table-columns"></i> 2-Column Row
                </div>
                <div class="component-item" draggable="true" ondragstart="drag(event)" data-type="card">
                    <i class="fa-solid fa-rectangle-list"></i> Card
                </div>

                <div class="component-group-title mt-4">Typography</div>
                <div class="component-item" draggable="true" ondragstart="drag(event)" data-type="header">
                    <i class="fa-solid fa-heading"></i> Heading Title
                </div>
                <div class="component-item" draggable="true" ondragstart="drag(event)" data-type="paragraph">
                    <i class="fa-solid fa-align-left"></i> Text Paragraph
                </div>

                <div class="component-group-title mt-4">Forms & Inputs</div>
                <div class="component-item" draggable="true" ondragstart="drag(event)" data-type="input-text">
                    <i class="fa-solid fa-i-cursor"></i> Text Input
                </div>
                <div class="component-item" draggable="true" ondragstart="drag(event)" data-type="select">
                    <i class="fa-regular fa-square-caret-down"></i> Select Dropdown
                </div>
                <div class="component-item" draggable="true" ondragstart="drag(event)" data-type="checkbox">
                    <i class="fa-regular fa-square-check"></i> Checkbox
                </div>
                <div class="component-item" draggable="true" ondragstart="drag(event)" data-type="button">
                    <i class="fa-solid fa-hand-pointer"></i> Button
                </div>

                <div class="component-group-title mt-4">Data</div>
                <div class="component-item" draggable="true" ondragstart="drag(event)" data-type="table">
                    <i class="fa-solid fa-table"></i> Data Table
                </div>
            </div>

            <!-- PAGES TAB -->
            <div class="tab-pane fade p-3 h-100" id="pages-tab">
                <button class="btn btn-primary w-100 mb-3 btn-sm" onclick="addNewPage()"><i class="fas fa-plus me-1"></i> Add Prototype Page</button>
                <div id="pagesList">
                    <!-- Rendered via JS -->
                </div>
            </div>
        </div>
    </div>

    <!-- Main Canvas Area -->
    <div class="builder-canvas-wrapper">
        <div class="builder-toolbar">
            <div class="toolbar-left">
                <button class="btn btn-sm btn-outline-danger" onclick="clearCanvas()">
                    <i class="fa-solid fa-trash"></i> Clear All
                </button>
            </div>
            <div class="toolbar-right">
                <button class="btn btn-sm btn-outline-primary" onclick="previewHTML()">
                    <i class="fa-solid fa-code"></i> Get HTML
                </button>
            </div>
        </div>
        <div class="builder-canvas">
            <div class="canvas-paper drop-zone" id="mainCanvas" ondrop="drop(event)" ondragover="allowDrop(event)" ondragenter="dragEnter(event)" ondragleave="dragLeave(event)">
                <!-- Dropped items will appear here -->
            </div>
        </div>
    </div>
</div>

<!-- Modal for HTML Source -->
<div class="modal fade" id="htmlPreviewModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Export HTML</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" onclick="closeModal()"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-2"><small>Copy this code into your visual studio or IDE.</small></p>
                <div id="exportCode"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal()">Close</button>
                <button type="button" class="btn btn-primary" onclick="copySource()">Copy to Clipboard</button>
            </div>
        </div>
    </div>
</div>

<script>
    // Prototype Pages Logic
    let pages = [
        { id: 'page-1', name: 'Home', html: '' }
    ];
    let currentPageId = 'page-1';

    function addPageLogics() {
        renderPages();
    }

    function renderPages() {
        const list = document.getElementById('pagesList');
        if (!list) return;
        list.innerHTML = '';
        pages.forEach((page, index) => {
            const isActive = page.id === currentPageId;
            const item = document.createElement('div');
            item.className = `page-item ${isActive ? 'active' : ''}`;
            item.onclick = () => switchPage(page.id);
            
            let html = `<span><i class="far fa-file-alt me-2"></i> <span contenteditable="${isActive}" onblur="renamePage('${page.id}', this.innerText)" onclick="event.stopPropagation()">${page.name}</span></span>`;
            if (pages.length > 1) {
                html += `
                    <button class="btn btn-sm text-danger p-0 delete-page-btn" onclick="event.stopPropagation(); deletePage('${page.id}')">
                        <i class="fas fa-trash"></i>
                    </button>
                `;
            }
            item.innerHTML = html;
            list.appendChild(item);
        });
    }

    function switchPage(id) {
        if(id === currentPageId) return;

        // Save current HTML
        const currentData = pages.find(p => p.id === currentPageId);
        if(currentData) {
            currentData.html = document.getElementById('mainCanvas').innerHTML;
        }

        // Load new HTML
        currentPageId = id;
        const newData = pages.find(p => p.id === id);
        if(newData) {
            document.getElementById('mainCanvas').innerHTML = newData.html;
        }

        renderPages();
    }

    function addNewPage() {
        const name = prompt("Enter page name:", "New Page");
        if(name) {
            const newId = 'page-' + Date.now();
            
            // Save current HTML before jumping
            const currentData = pages.find(p => p.id === currentPageId);
            if(currentData) {
                currentData.html = document.getElementById('mainCanvas').innerHTML;
            }

            pages.push({ id: newId, name: name, html: '' });
            
            currentPageId = newId;
            document.getElementById('mainCanvas').innerHTML = '';
            renderPages();
        }
    }

    function deletePage(id) {
        if(confirm("Are you sure you want to delete this page?")) {
            pages = pages.filter(p => p.id !== id);
            if(currentPageId === id) {
                switchPage(pages[0].id);
            } else {
                renderPages();
            }
        }
    }
    
    function renamePage(id, newName) {
        const page = pages.find(p => p.id === id);
        if (page) {
            page.name = newName;
        }
    }

    document.addEventListener("DOMContentLoaded", function() {
        addPageLogics();
    });

    // Templates for components
    const componentTemplates = {
        'row': `
            <div class="row">
                <div class="col-md-6"><div class="drop-zone nested-drop" ondrop="drop(event)" ondragover="allowDrop(event)" ondragenter="dragEnter(event)" ondragleave="dragLeave(event)"></div></div>
                <div class="col-md-6"><div class="drop-zone nested-drop" ondrop="drop(event)" ondragover="allowDrop(event)" ondragenter="dragEnter(event)" ondragleave="dragLeave(event)"></div></div>
            </div>
        `,
        'card': `
            <div class="card mb-3">
                <div class="card-header" contenteditable="true">Card Title Here</div>
                <div class="card-body">
                    <div class="drop-zone nested-drop" ondrop="drop(event)" ondragover="allowDrop(event)" ondragenter="dragEnter(event)" ondragleave="dragLeave(event)"></div>
                </div>
            </div>
        `,
        'header': `<h3 contenteditable="true">Editable Heading Title</h3>`,
        'paragraph': `<p contenteditable="true" class="text-muted">Click to edit this paragraph text. Lorem ipsum dolor sit amet, consectetur adipiscing elit. Aliquam nec efficitur turpis.</p>`,
        'input-text': `
            <div class="form-group mb-3">
                <label class="form-label" contenteditable="true">Input Label</label>
                <input type="text" class="form-control" placeholder="Type here...">
            </div>
        `,
        'select': `
            <div class="form-group mb-3">
                <label class="form-label" contenteditable="true">Select Option</label>
                <select class="form-select form-control">
                    <option>Option 1</option>
                    <option>Option 2</option>
                    <option>Option 3</option>
                </select>
            </div>
        `,
        'checkbox': `
            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" value="" id="flexCheckDefault">
                <label class="form-check-label" for="flexCheckDefault" contenteditable="true">
                    Example checkbox option
                </label>
            </div>
        `,
        'button': `
            <button class="btn btn-primary" contenteditable="true">Submit Button</button>
        `,
        'table': `
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th contenteditable="true">ID</th>
                            <th contenteditable="true">Name</th>
                            <th contenteditable="true">Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>1</td>
                            <td contenteditable="true">John Doe</td>
                            <td><span class="badge bg-success">Active</span></td>
                            <td><button class="btn btn-sm btn-outline-primary">Edit</button></td>
                        </tr>
                        <tr>
                            <td>2</td>
                            <td contenteditable="true">Jane Smith</td>
                            <td><span class="badge bg-warning">Pending</span></td>
                            <td><button class="btn btn-sm btn-outline-primary">Edit</button></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        `
    };

    // Drag & Drop Handlers
    function allowDrop(ev) {
        ev.preventDefault();
        ev.stopPropagation();
    }

    function dragEnter(ev) {
        ev.preventDefault();
        ev.stopPropagation();
        if(ev.target.classList.contains('drop-zone')) {
            ev.target.classList.add('active-drag');
        }
    }

    function dragLeave(ev) {
        ev.preventDefault();
        ev.stopPropagation();
        if(ev.target.classList.contains('drop-zone')) {
            ev.target.classList.remove('active-drag');
        }
    }

    function drag(ev) {
        ev.dataTransfer.setData("type", ev.target.getAttribute('data-type'));
    }

    function drop(ev) {
        ev.preventDefault();
        ev.stopPropagation();
        
        // Remove highlighting
        document.querySelectorAll('.active-drag').forEach(el => el.classList.remove('active-drag'));

        // Determine drop target (must be a drop-zone)
        let target = ev.target;
        if (!target.classList.contains('drop-zone')) {
            target = target.closest('.drop-zone');
        }

        if (!target) return;

        const type = ev.dataTransfer.getData("type");
        if (type && componentTemplates[type]) {
            // Create element wrapper
            const elWrapper = document.createElement('div');
            elWrapper.className = 'canvas-element';
            
            // Add action tools
            let extraActions = '';
            if (type === 'button') {
                extraActions = `<button class="action-btn link-btn" title="Link to Page" onclick="openLinkModal(this)"><i class="fa-solid fa-link"></i></button>`;
            }

            const actionsHTML = `
                <div class="canvas-element-actions">
                    ${extraActions}
                    <button class="action-btn" title="Move Up" onclick="moveEl(this, -1)"><i class="fa-solid fa-arrow-up"></i></button>
                    <button class="action-btn" title="Move Down" onclick="moveEl(this, 1)"><i class="fa-solid fa-arrow-down"></i></button>
                    <button class="action-btn delete" title="Delete" onclick="deleteEl(this)"><i class="fa-solid fa-trash"></i></button>
                </div>
            `;
            
            elWrapper.innerHTML = actionsHTML + componentTemplates[type];
            target.appendChild(elWrapper);
        }
    }

    // Element Actions
    function deleteEl(btn) {
        btn.closest('.canvas-element').remove();
    }

    function moveEl(btn, direction) {
        const el = btn.closest('.canvas-element');
        const parent = el.parentNode;
        
        if (direction === -1 && el.previousElementSibling) {
            parent.insertBefore(el, el.previousElementSibling);
        } else if (direction === 1 && el.nextElementSibling) {
            parent.insertBefore(el.nextElementSibling, el);
        }
    }

    function clearCanvas() {
        if(confirm("Are you sure you want to clear the entire canvas?")) {
            document.getElementById('mainCanvas').innerHTML = '';
            const currentData = pages.find(p => p.id === currentPageId);
            if(currentData) currentData.html = '';
        }
    }

        // Link Modal Logic
    let currentLinkButton = null;

    function openLinkModal(btn) {
        currentLinkButton = btn.closest('.canvas-element').querySelector('button.btn');
        
        let selectHtml = '<select id="pageLinkSelect" class="form-select">';
        selectHtml += '<option value="">-- No Link --</option>';
        pages.forEach(p => {
            const selected = (currentLinkButton.getAttribute('onclick') === `switchPage('${p.id}')`) ? 'selected' : '';
            selectHtml += `<option value="${p.id}" ${selected}>${p.name}</option>`;
        });
        selectHtml += '</select>';

        document.getElementById('linkModalBody').innerHTML = `
            <div class="mb-3">
                <label class="form-label">Select Target Page:</label>
                ${selectHtml}
            </div>
        `;

        const modalEl = document.getElementById('linkModal');
        const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
        modal.show();
    }

    function saveLink() {
        if (!currentLinkButton) return;
        
        const targetPageId = document.getElementById('pageLinkSelect').value;
        if (targetPageId) {
            currentLinkButton.setAttribute('onclick', `switchPage('${targetPageId}')`);
            // Add visual helper
            if(!currentLinkButton.innerHTML.includes('fa-link')) {
                 currentLinkButton.innerHTML = currentLinkButton.innerText + ' <i class="fa-solid fa-link ms-1 small" style="opacity:0.5"></i>';
            }
        } else {
            currentLinkButton.removeAttribute('onclick');
        }

        const modalEl = document.getElementById('linkModal');
        const modal = bootstrap.Modal.getInstance(modalEl);
        if(modal) modal.hide();
    }

    // HTML Preview & Export
    function previewHTML() {
        // Clone canvas
        const canvasHtml = document.getElementById('mainCanvas').cloneNode(true);
        
        // Clean up builder-specific classes and elements before exporting
        const wrappers = canvasHtml.querySelectorAll('.canvas-element');
        wrappers.forEach(w => {
            // Remove actions
            const actions = w.querySelector('.canvas-element-actions');
            if(actions) actions.remove();
            
            // Convert prototype links to dummy hrefs for export if needed
            const linkedBtns = w.querySelectorAll('button[onclick^="switchPage"]');
            linkedBtns.forEach(btn => {
                const targetMatch = btn.getAttribute('onclick').match(/'([^']+)'/);
                if(targetMatch && targetMatch[1]) {
                    const targetPage = pages.find(p => p.id === targetMatch[1]);
                    if(targetPage) {
                        // Change button to anchor for standard HTML export
                        const a = document.createElement('a');
                        a.className = btn.className;
                        a.href = targetPage.name.toLowerCase().replace(/\\s+/g, '-') + '.html';
                        a.innerHTML = btn.innerHTML.replace(' <i class="fa-solid fa-link ms-1 small" style="opacity:0.5"></i>', ''); // Remove helper icon
                        btn.parentNode.replaceChild(a, btn);
                    }
                }
            });

            // Just get the pure HTML inside
            w.outerHTML = w.innerHTML;
        });

        const dropZones = canvasHtml.querySelectorAll('.drop-zone');
        dropZones.forEach(dz => {
            dz.removeAttribute('ondrop');
            dz.removeAttribute('ondragover');
            dz.removeAttribute('ondragenter');
            dz.removeAttribute('ondragleave');
            dz.classList.remove('drop-zone', 'nested-drop');
            if(dz.classList.length === 0) dz.removeAttribute('class');
            
            // Remove empty divs that were just empty drop zones
            if(dz.innerHTML.trim() === '') dz.outerHTML = '';
        });

        // Remove contenteditable
        const editables = canvasHtml.querySelectorAll('[contenteditable]');
        editables.forEach(e => e.removeAttribute('contenteditable'));

        // Format HTML (rough format)
        let cleanHtml = canvasHtml.innerHTML.trim();
        if(cleanHtml === '') {
            cleanHtml = '<!-- No components added yet -->';
        }

        // Use custom formatter for display
        document.getElementById('exportCode').textContent = formatHTML(cleanHtml);
        
        // Show Modal
        const modal = document.getElementById('htmlPreviewModal');
        modal.style.display = 'flex';
        modal.classList.add('show');
    }

    function closeModal() {
        const modal = document.getElementById('htmlPreviewModal');
        modal.style.display = 'none';
        modal.classList.remove('show');
    }

    function copySource() {
        const text = document.getElementById('exportCode').textContent;
        navigator.clipboard.writeText(text).then(() => {
            alert("Code copied to clipboard!");
            closeModal();
        });
    }

    function formatHTML(html) {
        // simple pretty print logic
        let tab = '    ';
        let result = '';
        let indent= '';
        html.split(/>\s*</).forEach(function(element) {
            if (element.match( /^\/\w/ )) {
                indent = indent.substring(tab.length);
            }
            result += indent + '<' + element + '>\r\n';
            if (element.match( /^<?\w[^>]*[^\/]$/ ) && !element.startsWith("input") && !element.startsWith("img")) { 
                indent += tab;              
            }
        });
        return result.substring(1, result.length-3);
    }
</script>

<!-- Modal for Linking Buttons -->
<div class="modal fade" id="linkModal" tabindex="-1" style="z-index: 1060;">
    <div class="modal-dialog modal-sm modal-dialog-centered" style="pointer-events: auto;">
        <div class="modal-content">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fs-6">Link Button to Page</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="linkModalBody">
                <!-- dynamic select injected here -->
            </div>
            <div class="modal-footer border-top-0 pt-0">
                <button type="button" class="btn btn-sm btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-sm btn-primary px-3" onclick="saveLink()">Save</button>
            </div>
        </div>
    </div>
</div>
