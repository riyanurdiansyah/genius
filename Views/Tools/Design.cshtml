<script src="/js/ui-builder-erd.js"></script>
<script src="/js/ui-builder-flowchart.js"></script>
<!-- html2pdf for FSD Export -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<!-- ApexCharts for Chart Components in Prototype Builder -->
<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

<!-- Firebase SDK Integrasi -->
<script src="https://www.gstatic.com/firebasejs/10.9.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.9.0/firebase-firestore-compat.js"></script>

<script>
    /* ── Prototype Init Logic ────────────── */
    let pages = [];
    let currentPageId = null;

    /* ── Firebase Configuration ────────────── */
    // TODO: GANTI DENGAN KUNCI PRODUKSI FIREBASE FIRESTORE ANDA
    const firebaseConfig = {
        apiKey: "AIzaSyAkHR9hh2Y2QjpkOXr0PC4AZHdK5tBd854",
        authDomain: "kuda-300c0.firebaseapp.com",
        projectId: "kuda-300c0",
        storageBucket: "kuda-300c0.firebasestorage.app",
        messagingSenderId: "683068549402",
        appId: "1:683068549402:web:5945369acce65e999de4a3",
        measurementId: "G-RVGR1LE9LS"
    };

    if (!firebase.apps.length) {
        firebase.initializeApp(firebaseConfig);
    }
    const db = firebase.firestore();

    /* ── App Data & Project Management ────────────── */
    let AppData = { projects: [] };
    let currentProject = null;

    async function fetchProjects() {
        const grid = document.getElementById('projectGrid');
        if (grid) grid.innerHTML = `<div class="col-12 text-center text-muted" style="padding:40px;"><i class="fas fa-spinner fa-spin fs-1 mb-3"></i><br>Connecting to Firebase Firestore...</div>`;
        
        try {
            const snapshot = await db.collection("projects").get();
            AppData.projects = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
            renderProjects();
        } catch (error) {
            console.error("Firestore Error: ", error);
            if (grid) grid.innerHTML = `<div class="col-12 text-center text-danger" style="padding:40px;"><i class="fas fa-exclamation-triangle fs-1 mb-3"></i><br>Gagal Terhubung ke Firebase!<br><small class="text-muted">Pastikan Anda telah mengisi 'firebaseConfig' di file Design.cshtml dan permission Firestore telah dibuka.</small></div>`;
        }
    }

    function renderProjects() {
        const grid = document.getElementById('projectGrid');
        if (!grid) return;
        if (AppData.projects.length === 0) {
            grid.innerHTML = `<div class="col-12 text-center text-muted" style="padding:40px;"><i class="fas fa-box-open fs-1 mb-3"></i><br>No projects found in Cloud. Create one to get started!</div>`;
            return;
        }

        grid.innerHTML = AppData.projects.map(p => `
            <div class="col-md-4 col-sm-6">
                <div class="card shadow-sm border-0 h-100" style="transition:all 0.2s;" onmouseover="this.classList.add('shadow')" onmouseout="this.classList.remove('shadow')">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <h5 class="card-title fw-bold text-dark">${p.name}</h5>
                            <button class="btn btn-sm text-danger" onclick="deleteProject('${p.id}', event)"><i class="fas fa-trash"></i></button>
                        </div>
                        <p class="text-muted small mb-3">Last updated: ${p.updatedAt || 'Unknown'}</p>
                        <div class="d-flex gap-2 text-muted" style="font-size: 12px;">
                            <span><i class="fas fa-paint-brush"></i> ${p.prototypePages?.length || 1} Pages</span>
                            <span><i class="fas fa-project-diagram"></i> ${p.erdEntities?.length || 0} Entities</span>
                            <span><i class="fas fa-sitemap"></i> ${p.flowchartDiagrams?.length || 1} Flows</span>
                        </div>
                    </div>
                    <div class="card-footer bg-white border-0 pt-0">
                        <button class="btn btn-outline-primary w-100 btn-sm" onclick="loadProject('${p.id}')">Open Project <i class="fas fa-cloud-download-alt ms-1"></i></button>
                    </div>
                </div>
            </div>
        `).join('');
    }

    async function createProject() {
        const name = prompt("Enter project name:", "New Cloud Project");
        if (!name) return;
        
        const newProj = {
            id: 'proj-' + Date.now(),
            name: name,
            updatedAt: new Date().toLocaleTimeString(),
            prototypePages: [{ id: 'page-1', name: 'Home', html: '' }],
            fsdPages: [{ id: 'fsd-cover', num: 'Cover', name: 'Halaman Utama', html: typeof FSD !== 'undefined' && FSD.compTemplates ? FSD.compTemplates['cover'] : '' }],
            erdEntities: [],
            erdRelationships: [],
            flowchartDiagrams: [{ id: 'fc-page-1', num: '1.0', name: 'Main Flow', nodes: [], edges: [] }]
        };
        
        try {
            await db.collection("projects").doc(newProj.id).set(newProj);
            AppData.projects.push(newProj);
            renderProjects();
        } catch (e) {
            alert("Firebase Error: Gagal Membuat Proyek. \nPastikan Rules Firestore Anda (allow read, write: if true;)");
        }
    }

    async function deleteProject(id, ev) {
        if (ev) ev.stopPropagation();
        if (confirm("Hapus proyek Cloud ini beserta seluruh isinya secara permanen dari Firebase?")) {
            try {
                await db.collection("projects").doc(id).delete();
                AppData.projects = AppData.projects.filter(p => p.id !== id);
                renderProjects();
            } catch (e) {
                alert("Firebase Error: Gagal Menghapus Proyek.");
            }
        }
    }

    function loadProject(id) {
        const proj = AppData.projects.find(p => p.id === id);
        if (!proj) return;
        currentProject = proj;

        // Bind data state directly securely
        pages = currentProject.prototypePages || [{ id: 'page-1', name: 'Home', html: '' }];
        currentPageId = pages[0].id;
        const mainCanvas = document.getElementById('mainCanvas');
        if (mainCanvas) mainCanvas.innerHTML = pages[0].html || '';
        
        FSD.pages = currentProject.fsdPages || [{ id: 'fsd-cover', num: 'Cover', name: 'Halaman Utama', html: typeof FSD !== 'undefined' && FSD.compTemplates ? FSD.compTemplates['cover'] : '' }];
        FSD.currentPageId = FSD.pages[0].id;
        
        ERD.entities = currentProject.erdEntities || [];
        ERD.relationships = currentProject.erdRelationships || [];
        
        Flowchart.diagrams = currentProject.flowchartDiagrams || [{ id: 'fc-page-1', num: '1.0', name: 'Main Flow', nodes: [], edges: [] }];
        Flowchart.currentPageId = Flowchart.diagrams[0].id;

        document.getElementById('currentProjectTitle').textContent = proj.name;
        document.getElementById('projectDashboard').style.display = 'none';
        document.getElementById('builderMain').style.display = 'flex';

        // Refresh UI
        currentWorkspace = ''; 
        const wsTab = document.querySelector(`.ws-tab[onclick="switchWorkspace('prototype',this)"]`);
        if (wsTab) switchWorkspace('prototype', wsTab);
    }

    function shareProject() {
        if (!currentProject) return;
        const url = window.location.origin + '/Tools/Share/' + currentProject.id;
        navigator.clipboard.writeText(url).then(() => {
            alert('Share link copied to clipboard!\n' + url + '\n\nAnyone with this link can view the project.');
        }).catch(err => {
            alert('Failed to copy. Share link is: \n' + url);
        });
    }

    function closeProject() {
        saveAllData();
        currentProject = null;
        document.getElementById('builderMain').style.display = 'none';
        document.getElementById('projectDashboard').style.display = 'block';
        // Re-fetch project list incase auto-save updated metadata
        fetchProjects(); 
    }

    let isSavingToCloud = false;
    async function saveAllData() {
        if (!currentProject || isSavingToCloud) return;
        isSavingToCloud = true;

        // Capture current active state
        if (currentWorkspace === 'prototype') {
            const cd = pages.find(p => p.id === currentPageId);
            if (cd) cd.html = document.getElementById('mainCanvas').innerHTML;
        } else if (currentWorkspace === 'fsd') {
            const fd = FSD.pages.find(p => p.id === FSD.currentPageId);
            const fCnv = document.getElementById('fsdCanvas');
            if (fd && fCnv) fd.html = fCnv.innerHTML;
        }

        currentProject.prototypePages = pages;
        currentProject.fsdPages = FSD.pages;
        currentProject.erdEntities = ERD.entities;
        currentProject.erdRelationships = ERD.relationships;
        currentProject.flowchartDiagrams = Flowchart.diagrams;
        currentProject.updatedAt = new Date().toLocaleTimeString();

        // Menyimpan status dokumen terbaru langsung ke JSON Firestore
        try {
            await db.collection("projects").doc(currentProject.id).set(currentProject);
            console.log("Auto-saved to Cloud Firestore");
        } catch(e) {
            console.error("Firebase Sync Error", e);
        } finally {
            isSavingToCloud = false;
        }
    }

    // Auto save synchronize to Firebase every 15 seconds
    setInterval(() => {
        saveAllData();
    }, 15000);

    // Initial Dashboard rendering trigger fetch from Firebase
    window.addEventListener('DOMContentLoaded', () => {
        fetchProjects();
    });

    /* ── Workspace Switching ────────────── */
    let currentWorkspace = 'prototype';

    function switchWorkspace(ws, btn) {
        if (ws === currentWorkspace) return;

        // Save prototype canvas before leaving
        if (currentWorkspace === 'prototype') {
            const cd = pages.find(p => p.id === currentPageId);
            if (cd) cd.html = document.getElementById('mainCanvas').innerHTML;
        }

        currentWorkspace = ws;

        // Tab active state
        document.querySelectorAll('.ws-tab').forEach(t => t.classList.remove('active'));
        if (btn) btn.classList.add('active');

        // Panel visibility
        document.querySelectorAll('.workspace-panel').forEach(p => p.classList.remove('active'));
        document.getElementById('panel-' + ws).classList.add('active');

        // Sidebar switching
        const protoTabs = document.getElementById('sidebarProtoTabs');
        const erdSb = document.getElementById('erdSidebarContent');
        const fsdSb = document.getElementById('fsdSidebarContent');
        const flowchartSb = document.getElementById('flowchartSidebarContent');
        const sidebarHeader = document.querySelector('.builder-sidebar-header h5');
        const sidebarUl = document.querySelector('.builder-sidebar-header ul');

        // Hide all sidebar contents first
        if (protoTabs) protoTabs.style.display = 'none';
        if (erdSb) erdSb.style.display = 'none';
        if (fsdSb) fsdSb.style.display = 'none';
        if (flowchartSb) flowchartSb.style.display = 'none';

        if (ws === 'erd') {
            if (erdSb) erdSb.style.display = 'flex';
            if (sidebarHeader) sidebarHeader.textContent = 'ERD Builder';
            if (sidebarUl) sidebarUl.style.display = 'none';
            ERD.init();
        } else if (ws === 'fsd') {
            if (fsdSb) fsdSb.style.display = 'flex';
            if (sidebarHeader) sidebarHeader.textContent = 'FSD Builder';
            if (sidebarUl) sidebarUl.style.display = 'none';
            FSD.init();
        } else if (ws === 'flowchart') {
            if (flowchartSb) flowchartSb.style.display = 'flex';
            if (sidebarHeader) sidebarHeader.textContent = 'Flowchart Builder';
            if (sidebarUl) sidebarUl.style.display = 'none';
            Flowchart.init();
        } else {
            if (protoTabs) protoTabs.style.display = 'flex';
            if (sidebarHeader) sidebarHeader.textContent = 'UI Builder';
            if (sidebarUl) sidebarUl.style.display = 'flex';
            renderPages(); 
            switchPage(currentPageId);
        }

        // Toolbar actions update
        const actions = document.getElementById('toolbarActions');
        if (ws === 'prototype') {
            actions.innerHTML = `<button class="btn btn-sm btn-outline-danger me-2" onclick="clearCanvas()"><i class="fa-solid fa-trash"></i> Clear</button>
                <button class="btn btn-sm btn-outline-primary" onclick="previewHTML()"><i class="fa-solid fa-code"></i> Get HTML</button>`;
        } else if (ws === 'fsd') {
            actions.innerHTML = `<button class="btn btn-sm btn-outline-danger me-2" onclick="FSD.deletePage(FSD.currentPageId)"><i class="fa-solid fa-trash"></i> Delete Page</button>
                <button class="btn btn-sm btn-outline-primary" onclick="exportFSDPDF()"><i class="fas fa-file-pdf"></i> Export PDF</button>`;
        } else if (ws === 'erd') {
            actions.innerHTML = `<button class="btn btn-sm btn-outline-primary" onclick="exportERD()"><i class="fas fa-download"></i> Export SQL</button>`;
        } else if (ws === 'flowchart') {
            actions.innerHTML = `<button class="btn btn-sm btn-outline-danger me-2" onclick="Flowchart.deletePage(Flowchart.currentPageId)"><i class="fa-solid fa-trash"></i> Delete Diagram</button>
                                 <button class="btn btn-sm btn-outline-warning me-2" onclick="FSD.compactDiagram()"><i class="fa-solid fa-compress-arrows-alt"></i> Fix Layout (A4)</button>
                                 <button class="btn btn-sm btn-outline-primary me-2" onclick="Flowchart.clearCanvas()"><i class="fa-solid fa-eraser"></i> Clear Canvas</button>
                                 <button class="btn btn-sm btn-outline-primary" onclick="exportFlowchartPDF()"><i class="fas fa-file-pdf"></i> Export PDF</button>`;
        }
    }

    // Markdown export removed since FSD is now visual node based

    function exportFSDPDF() {
        if (!FSD || !FSD.pages || FSD.pages.length === 0) return;
        
        const el = document.getElementById('fsdCanvas');
        
        // Segarkan layar terakhir ke array memori
        const fc = FSD.pages.find(p => p.id === FSD.currentPageId);
        if (fc && el) fc.html = el.innerHTML;
        
        const tempContainer = document.createElement('div');
        tempContainer.className = 'fsd-paper';
        
        let counter = 0;
        FSD.pages.forEach((page) => {
            const pageDiv = document.createElement('div');
            // Supaya tampilan tetap nyaman dan rapi antar halaman, tanpa bayangan dll
            pageDiv.innerHTML = page.html || '<div style="color:#ccc;text-align:center;">[Blank Page]</div>';
            
            // Inject Class bawaan html2pdf.js agar PDF dipotong sempurna setiap pergantian dokumen yang berbeda
            if (counter < FSD.pages.length - 1) {
                const breakDiv = document.createElement('div');
                breakDiv.className = 'html2pdf__page-break';
                pageDiv.appendChild(breakDiv);
            }
            tempContainer.appendChild(pageDiv);
            counter++;
        });

        // Set clone referensi ke DOM tempContainer gabungan semua halaman FSD
        const clone = tempContainer;
        
        // 1. Tangkap input tepat setelah clone sebelum ada elemen yang dibuang
        const origInputs = el.querySelectorAll('input, select, textarea');
        const cloneInputs = clone.querySelectorAll('input, select, textarea');
        
        // 2. Remove interactive prototype UI & placeholders safely
        clone.querySelectorAll('.fsd-prototype-control, .fsd-prototype-placeholder').forEach(el => el.remove());
        
        // 3. Transform input jadi teks dengan presisi
        origInputs.forEach((inp, i) => {
            const cloneNodeCandidate = cloneInputs[i];
            if (!cloneNodeCandidate || !cloneNodeCandidate.parentNode) return; // skip if already removed
            
            const cInp = cloneNodeCandidate;
            const val = inp.value;
            const span = document.createElement('span');
            span.style.fontFamily = cInp.tagName === 'INPUT' && cInp.style.fontFamily === 'monospace' ? 'monospace' : 'inherit';
            span.style.fontWeight = cInp.style.fontWeight || 'normal';
            span.style.fontSize = cInp.style.fontSize || 'inherit';
            
            if (cInp.tagName === 'TEXTAREA') {
                span.innerHTML = val ? val.replace(/\n/g, '<br>') : '-';
                span.style.display = 'block';
                span.style.minHeight = '20px';
                span.style.padding = '8px 0';
                span.style.whiteSpace = 'pre-wrap';
            } else if (cInp.tagName === 'SELECT') {
                span.innerText = cInp.options[cInp.selectedIndex]?.text || '-';
            } else {
                span.innerText = val || '-';
            }
            cInp.parentNode.replaceChild(span, cInp);
        });

        clone.querySelectorAll('.toggle, .fsd-add-btn, button, select').forEach(b => b.remove());

        // Hapus paksa ikon delete & kolom `.fsd-hide-pdf` (Telah dibantu penandaan Class asli di ui-builder)
        clone.querySelectorAll('.fa-trash, .fas.fa-trash, .text-danger, button').forEach(el => el.remove());
        clone.querySelectorAll('.fsd-hide-pdf').forEach(el => el.remove());

        // Hapus kolom spesifik dengan nama persis 'Act' (Fallback jika komponen ditarik SEBELUM pembaruan kelas)
        Array.from(clone.querySelectorAll('th')).forEach(th => {
            const txt = (th.textContent || '').trim();
            if (txt === 'Act' || txt === 'Action') {
                const tbl = th.closest('table');
                if (!tbl) return;
                
                const colIdx = th.cellIndex;
                if (colIdx !== undefined && colIdx > -1) {
                    tbl.querySelectorAll('tr').forEach(row => {
                        const cellToRemove = row.children[colIdx];
                        if (cellToRemove) cellToRemove.remove();
                    });
                }
            }
        });

        // Hapus contenteditable untuk menghindari bug 'Garis Putus-Putus' halus dari spellcheck/editable boundary WebKit
        clone.querySelectorAll('[contenteditable]').forEach(el => {
            el.removeAttribute('contenteditable');
            el.style.outline = 'none';
        });

        // Hapus styling berlebih yang memicu bug rendering html2canvas (Garis Putus-Putus dari Bootstrap Table Bordered)
        clone.querySelectorAll('table.table-bordered').forEach(t => {
            t.classList.remove('table-bordered');
        });

        // Pastikan drop zone tidak merender dashed line
        clone.querySelectorAll('.fsd-drop-zone, .canvas-element').forEach(el => {
            el.style.border = 'none';
            el.style.boxShadow = 'none';
        });

        // --- PENYESUAIAN A4 TEPAT ---
        // Lebar A4 proporsional sekitar 800px. Jika lebar melebihi ini, akan terpotong
        clone.style.width = '800px'; 
        clone.style.maxWidth = '100%';
        clone.style.margin = '0 auto';  
        clone.style.padding = '20px';
        clone.style.background = '#fff';
        clone.style.boxShadow = 'none';
        
        // Paksa Font ke KalbeGeometric menggunakan Injeksi Style Block yang aman untuk html2canvas
        const fontOverrides = document.createElement('style');
        const baseUrl = window.location.origin;
        fontOverrides.innerHTML = `
            @@font-face {
                font-family: 'KalbeGeometric';
                src: url('${baseUrl}/font/geometric/KalbeGeometric-Regular.woff2') format('woff2');
                font-weight: 400; font-style: normal;
            }
            @@font-face {
                font-family: 'KalbeGeometric';
                src: url('${baseUrl}/font/geometric/KalbeGeometric-Bold.woff2') format('woff2');
                font-weight: 700; font-style: normal;
            }
            @@font-face {
                font-family: 'KalbeGeometric';
                src: url('${baseUrl}/font/geometric/KalbeGeometric-Medium.woff2') format('woff2');
                font-weight: 500; font-style: normal;
            }
            /* Mengamankan elemen dasar FSD */
            .fsd-paper, .fsd-comp, .fsd-comp *, table, th, td, h1, h2, h3, h4, h5, h6, p, span, div {
                font-family: 'KalbeGeometric', sans-serif !important;
            }
            /* Kecuali untuk ikon FontAwesome yang wajib mempertahankan font aslinya */
            i, .fa, .fas, .fa-solid, .fa-regular, .fab, .fal {
                font-family: "Font Awesome 6 Free", "FontAwesome" !important;
            }
        `;
        clone.appendChild(fontOverrides);

        // Secara agresif menginjeksi inline font-family ke seluruh elemen Prototype
        // Karena HTML2Canvas sering buta pada CSS Selector universal atau bersarang
        clone.querySelectorAll('*').forEach(el => {
            if (el.tagName.toLowerCase() !== 'i' && !el.classList.contains('fa') && !el.classList.contains('fas') && !el.classList.contains('fa-solid')) {
                // Jangan sampai merusak ikon
                el.style.setProperty('font-family', "'KalbeGeometric', system-ui, sans-serif", 'important');
                
                // Set ukuran Font ke 10px default dan 12px untuk title
                const tag = el.tagName.toLowerCase();
                if (['h1', 'h2', 'h3', 'h4', 'h5', 'h6'].includes(tag) || el.classList.contains('fsd-section-title')) {
                    el.style.setProperty('font-size', '12px', 'important');
                    el.style.setProperty('font-weight', 'bold', 'important');
                } else {
                    el.style.setProperty('font-size', '10px', 'important');
                }
            }
        });

        // 1. Memaksa Prototype HTML embed agar di-zoom-out 
        // sehingga seluruh kontennya mengecil dan menyesuaikan lebar A4 tanpa nabrak
        clone.querySelectorAll('.fsd-prototype-preview').forEach(p => {
            p.style.zoom = '0.75'; // kecilkan 25% agar muat mantap
            p.style.overflow = 'hidden';
            p.style.width = '100%';
            p.style.border = 'none'; // menghilangkan kotak luar tambahan jika ada
            p.style.background = 'transparent';
            
            // hindari komponen di dalam prototype (seperti card/row) yang melebihi lebar
            p.querySelectorAll('*').forEach(child => {
                if (child.style && child.clientWidth > 800) {
                    child.style.maxWidth = '100%';
                    child.style.height = 'auto';
                    child.style.whiteSpace = 'normal';
                }
            });
        });

        // Menghilangkan border berlebih untuk tampilan rapih
        const comps = clone.querySelectorAll('.fsd-comp');
        comps.forEach(c => {
            c.classList.remove('mb-4', 'border', 'rounded', 'bg-white');
            c.style.marginBottom = '25px';
            c.style.padding = '10px 0';
        });

        const container = el.parentElement;
        const oldDisplay = el.style.display;
        el.style.display = 'none'; // Sembunyikan canvas asli
        container.appendChild(clone); // Tempel clone di dalam container asli (tanpa trick document.body yg bikin blank)

        const currentP = FSD.pages.find(p => p.id === FSD.currentPageId);
        const safeName = 'FSD_' + (currentP ? currentP.name : 'Document').replace(/[^a-zA-Z0-9]/g, '_') + '.pdf';
        
        const opt = {
            margin: [10, 10, 10, 10], // top, left, bottom, right margins in mm
            filename: safeName,
            image: { type: 'jpeg', quality: 0.98 },
            html2canvas: { scale: 2, useCORS: true, logging: false, scrollY: 0 },
            jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' },
            pagebreak: { mode: ['css', 'legacy'], avoid: ['.fsd-comp', 'tr', '.erd-fsd-ent', '.fsd-header'] }
        };
        
        // Disable scrollbar menghindari tergesernya canvas ketika direkam
        const oldOverflow = document.body.style.overflow;
        document.body.style.overflow = 'hidden';
        
        setTimeout(() => {
            window.scrollTo(0,0);
            html2pdf().set(opt).from(clone).save().then(() => {
                container.removeChild(clone);
                document.body.style.overflow = oldOverflow;
                el.style.display = oldDisplay; // restore original FSD
            }).catch(err => {
                container.removeChild(clone);
                document.body.style.overflow = oldOverflow;
                el.style.display = oldDisplay;
            });
        }, 500);
    }

    function exportERD() {
        const sql = ERD.exportSQL();
        document.getElementById('exportCode').textContent = sql;
        document.querySelector('#htmlPreviewModal .modal-title').textContent = 'Export ERD (SQL)';
        const modal = document.getElementById('htmlPreviewModal');
        modal.style.display = 'flex'; modal.classList.add('show');
    }

    function renderPages() {
        const list = document.getElementById('pagesList');
        if (!list) return;
        list.innerHTML = '';
        pages.forEach((page) => {
            const isActive = page.id === currentPageId;
            const item = document.createElement('div');
            item.className = `page-item ${isActive ? 'active' : ''}`;
            item.onclick = () => switchPage(page.id);
            let html = `<span><i class="far fa-file-alt me-2"></i> <span contenteditable="${isActive}" onblur="renamePage('${page.id}', this.innerText)" onclick="event.stopPropagation()">${page.name}</span></span>`;
            if (pages.length > 1) html += `<button class="btn btn-sm text-danger p-0" onclick="event.stopPropagation(); deletePage('${page.id}')"><i class="fas fa-trash"></i></button>`;
            item.innerHTML = html;
            list.appendChild(item);
        });
    }

    function switchPage(id) {
        if (id === currentPageId) return;
        const cd = pages.find(p => p.id === currentPageId);
        if (cd) cd.html = document.getElementById('mainCanvas').innerHTML;
        currentPageId = id;
        const nd = pages.find(p => p.id === id);
        if (nd) document.getElementById('mainCanvas').innerHTML = nd.html;
        renderPages();
    }

    function addNewPage() {
        document.getElementById('newPageNameInput').value = 'New Page';
        const modal = bootstrap.Modal.getOrCreateInstance(document.getElementById('addPageModal'));
        modal.show();
        setTimeout(() => document.getElementById('newPageNameInput').select(), 300);
    }

    function confirmAddPage() {
        const name = document.getElementById('newPageNameInput').value.trim();
        if (!name) return;
        const newId = 'page-' + Date.now();
        const canvas = document.getElementById('mainCanvas');
        if (canvas) {
            const cd = pages.find(p => p.id === currentPageId);
            if (cd) cd.html = canvas.innerHTML;
            canvas.innerHTML = '';
        }
        pages.push({ id: newId, name: name, html: '' });
        currentPageId = newId;
        renderPages();
        const modal = bootstrap.Modal.getInstance(document.getElementById('addPageModal'));
        if (modal) modal.hide();
    }

    function deletePage(id) {
        if (confirm("Delete this page?")) {
            pages = pages.filter(p => p.id !== id);
            if (currentPageId === id) switchPage(pages[0].id);
            else renderPages();
        }
    }

    function renamePage(id, newName) {
        const page = pages.find(p => p.id === id);
        if (page) page.name = newName;
    }

